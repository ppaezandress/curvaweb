{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CURVA Tiempos",
  "version": "0.1.0",
  "identifier": "vc.curva.tiempos",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "CURVA Tiempos",
        "width": 460,
        "height": 820,
        "minWidth": 380,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
