# Copia este archivo a `.env` (local) y configura las mismas variables en Vercel.
# NUNCA subas credenciales reales al repo.

# --- Lead magnet "checklist 10 señales" (webhook n8n) ---
# POST JSON: { email, source, ts }
PUBLIC_LEADMAGNET_WEBHOOK=

# --- Chat IA (Vercel AI SDK + AI Gateway) ---
# Auth del Gateway: usa la API key en local; en Vercel funciona con OIDC.
AI_GATEWAY_API_KEY=
# Modelos (ids del Gateway). Por defecto un modelo open-weight.
LLM_MODEL=openai/gpt-oss-120b
LLM_TRANSCRIBE_MODEL=openai/whisper-1

# --- Leads del chat (Supabase, vía REST) ---
# Tablas: curva_leads, curva_chat_messages (ver src/lib/leads.ts).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Rate limit anti-abuso (Upstash Redis REST) — opcional, hay fallback ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Tienda de plantillas de Notion (Pendiente #1: proveedor de pago) ---
# Modo A: checkout hospedado (devuelve URL de pago).
# PLANTILLAS_CHECKOUT_URL=
# Modo B: webhook n8n que cobra + entrega por correo (fallback: usa el del lead magnet).
# PLANTILLAS_WEBHOOK=
