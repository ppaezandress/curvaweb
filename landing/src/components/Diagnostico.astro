  .dx-overlay.is-open .dx-cloud { animation: dx-cloud-in .7s var(--e-out) both, dx-cloud-bob 7s ease-in-out infinite; animation-delay: calc(0.15s + var(--i) * 0.05s), calc(1s + var(--dly)); }
