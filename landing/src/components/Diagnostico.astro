<!-- GLOBAL: el rayo lo crea el JS con createElement, así que su CSS NO puede ser scoped
     (Astro no le pondría el atributo de scope al elemento dinámico → el selector no matchea).
     Por eso vive aquí en un bloque is:global. -->
<style is:global>
  /* Rayo minimalista al tocar una ficha: hebra fina que "cae" sobre la nube, se dibuja rápido
     y se apaga. Elegante, sin rebote ni caricatura. La punta queda en el punto tocado. */
  .dx-bolt {
    position: fixed; z-index: 95; pointer-events: none; margin: -2rem 0 0 -0.6rem;
    color: #eaf7ff; will-change: transform, opacity;
    filter: drop-shadow(0 0 6px rgba(125, 211, 252, 0.95)) drop-shadow(0 0 16px rgba(56, 189, 248, 0.55));
    animation: dx-bolt-in 0.7s cubic-bezier(0.23, 1, 0.32, 1) forwards;
  }
  .dx-bolt svg { width: 1.2rem; height: 2rem; display: block; }
  .dx-bolt path { stroke-dasharray: 62; stroke-dashoffset: 62; animation: dx-bolt-draw 0.17s cubic-bezier(0.7, 0, 0.3, 1) forwards; }
  @keyframes dx-bolt-draw { to { stroke-dashoffset: 0; } }
  @keyframes dx-bolt-in {
    0%   { opacity: 0; transform: translateY(6px) scale(0.8); }
    18%  { opacity: 1; }
    55%  { opacity: 0.95; transform: translateY(0) scale(1); }
    100% { opacity: 0; transform: translateY(-8px) scale(1.04); }
  }
  @media (prefers-reduced-motion: reduce) {
    .dx-bolt { animation: none; opacity: 0; }
  }
</style>
