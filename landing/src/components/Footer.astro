---
import { areas } from '../data/areas';
interface Props {
  calLink: string;
  waLink: string;
}
const { calLink, waLink } = Astro.props;
const year = 2026;
---
<footer class="surface-ink text-sand-300 py-14 px-5">
  <div class="max-w-6xl mx-auto">
    <div class="flex flex-col sm:flex-row justify-between items-start gap-10">
      <div class="max-w-xs">
        <p class="display text-2xl font-semibold text-sand-50 mb-3">curva</p>
        <p class="text-sm text-sand-400 leading-relaxed">Transformación operativa y digital para empresas en crecimiento. Ponemos orden, lo digitalizamos y lo dejamos funcionando.</p>
      </div>
      <div class="flex flex-col sm:flex-row gap-10">
        <div>
          <p class="eyebrow text-sand-500 mb-4">Servicios</p>
          <nav class="flex flex-col gap-2.5">
            {areas.map((a) => (
              <a href={a.href} class="text-sm text-sand-300 hover:text-sand-50 transition-colors">{a.menuLabel}</a>
            ))}
          </nav>
        </div>
        <div>
          <p class="eyebrow text-sand-500 mb-4">CURVA</p>
          <nav class="flex flex-col gap-2.5">
            <a href="/nosotros" class="text-sm text-sand-300 hover:text-sand-50 transition-colors">Nosotros</a>
            <a href="/#casos" class="text-sm text-sand-300 hover:text-sand-50 transition-colors">Casos de éxito</a>
            <a href={calLink} target="_blank" rel="noopener" class="text-sm text-sand-300 hover:text-sand-50 transition-colors">Agendar llamada</a>
            <a href={waLink} target="_blank" rel="noopener" class="text-sm text-sand-300 hover:text-sand-50 transition-colors">WhatsApp</a>
          </nav>
        </div>
      </div>
    </div>
    <div class="mt-12 pt-6 border-t border-white/10 flex flex-col sm:flex-row justify-between items-center gap-3">
      <p class="text-xs text-sand-500">© {year} CURVA. Ciudad de México. · <a href="/aviso-privacidad" class="hover:text-sand-200 transition-colors underline underline-offset-2">Aviso de privacidad</a></p>
      <div class="flex gap-4">
        <a href="https://www.linkedin.com/company/curva" target="_blank" rel="noopener" aria-label="LinkedIn" class="text-sand-500 hover:text-sand-200 transition-colors">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"></path></svg>
        </a>
        <a href="https://www.instagram.com/curva" target="_blank" rel="noopener" aria-label="Instagram" class="text-sand-500 hover:text-sand-200 transition-colors">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"></path></svg>
        </a>
      </div>
    </div>
  </div>
</footer>
