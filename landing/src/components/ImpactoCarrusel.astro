---
// "Impacto real": carrusel de casos con la CIFRA como protagonista (estilo
// consultora). Accesible: teclado (flechas sobre el track), arrastre, botones
// prev/next (≥44px) y dots. Motion con significado (snap + lift). Lógica en
// scripts/carousel.ts. Datos (con placeholders marcados) en data/impacto.ts.
import { impacto } from '../data/impacto';

const hayEjemplos = impacto.some((c) => c.ejemplo);
// Sparkline decorativa (curva ascendente) para la cabecera de cada tarjeta.
const spark = 'M0,44 C40,42 70,30 120,18 C170,7 210,8 260,3';
---
<section id="impacto" data-carousel class="py-24 sm:py-36 relative overflow-hidden" aria-labelledby="impacto-title">
  <div class="mx-auto max-w-7xl px-6 sm:px-10">
    <!-- Encabezado + controles -->
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-8 mb-14 sm:mb-16">
      <div class="max-w-2xl">
        <p class="reveal eyebrow-lead text-ember mb-5">Impacto real</p>
        <h2 id="impacto-title" class="reveal display text-3xl sm:text-4xl lg:text-5xl font-semibold tracking-tight leading-[1.08] text-ink text-balance">Números que cambian el negocio.</h2>
        <p class="reveal mt-6 text-lg text-sand-600 leading-relaxed">No es teoría. Esto es lo que pasa cuando una operación deja de jalar a pulso.</p>
      </div>
      <!-- Controles prev/next (desktop) -->
      <div class="reveal hidden md:flex items-center gap-3 flex-shrink-0" aria-hidden="true">
        <button type="button" data-carousel-prev aria-label="Caso anterior" tabindex="-1"
          class="caso-nav w-12 h-12 rounded-full border border-sand-300 text-sand-700 flex items-center justify-center transition-[color,background-color,border-color,transform,opacity] duration-200 hover:bg-ember hover:border-ember hover:text-white active:scale-95 disabled:opacity-30 disabled:pointer-events-none">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5"></path></svg>
        </button>
        <button type="button" data-carousel-next aria-label="Caso siguiente" tabindex="-1"
          class="caso-nav w-12 h-12 rounded-full border border-sand-300 text-sand-700 flex items-center justify-center transition-[color,background-color,border-color,transform,opacity] duration-200 hover:bg-ember hover:border-ember hover:text-white active:scale-95 disabled:opacity-30 disabled:pointer-events-none">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"></path></svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Pista arrastrable (full-bleed: sangra a los bordes para el peek) -->
  <div class="reveal">
    <div data-carousel-track role="region" aria-roledescription="carrusel" aria-label="Casos de impacto" tabindex="0"
      class="caso-track flex gap-5 sm:gap-6 overflow-x-auto pb-2 px-6 sm:px-10 [scroll-padding-left:1.5rem] sm:[scroll-padding-left:2.5rem]">
      {impacto.map((c, i) => (
        <article class={`caso-card flip-card group snap-start shrink-0 w-[290px] sm:w-[340px]`}>
          <input type="checkbox" id={`flip-${i}`} class="flip-cb sr-only" aria-hidden="true" tabindex="-1" />
          <div class="flip-inner rounded-3xl">
            <!-- FRENTE: el dolor (el "antes") -->
            <label for={`flip-${i}`} class="flip-face flip-front rounded-3xl border border-sand-200 bg-white p-6 sm:p-7 flex flex-col cursor-pointer">
              <div class="flex items-center justify-between gap-3">
                <span class="inline-flex items-center gap-1.5 rounded-full bg-sand-100 text-sand-600 px-3 py-1 text-[11px] font-semibold tracking-wide">
                  <span class={`inline-block w-1.5 h-1.5 rounded-full accent-dot-${c.accent}`}></span>{c.categoria}
                </span>
                {c.ejemplo && <span class="inline-flex items-center rounded-full border border-sand-300 text-sand-500 px-2.5 py-1 text-[10px] font-bold uppercase tracking-wider">Ejemplo</span>}
              </div>
              <p class="eyebrow-lead text-sand-500 mt-6">El dolor</p>
              <p class="display mt-2 text-[19px] sm:text-[21px] font-semibold text-ink leading-snug text-balance">{c.dolor}</p>
              <span class="flip-hint mt-auto pt-6 inline-flex items-center gap-2 text-sm font-semibold text-ember">
                Ver qué hicimos
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 12a7.5 7.5 0 11-2.2-5.3M19.5 4.5V9h-4.5"></path></svg>
              </span>
            </label>
            <!-- REVERSO: la solución + la cifra -->
            <div class={`flip-face flip-back accent-${c.accent} rounded-3xl overflow-hidden text-white flex flex-col`}>
              <label for={`flip-${i}`} class="absolute top-4 right-4 z-20 grid place-items-center w-8 h-8 rounded-full bg-black/20 backdrop-blur-sm border border-white/25 text-white/90 cursor-pointer transition hover:bg-black/30" aria-label="Volver al dolor">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12a7.5 7.5 0 102.2-5.3M4.5 4.5V9H9"></path></svg>
              </label>
              <svg class="absolute left-0 right-0 top-1/3 w-full h-20 opacity-30 z-0" viewBox="0 0 260 48" fill="none" preserveAspectRatio="none" aria-hidden="true">
                <path d={spark} stroke="#fff" stroke-width="2" stroke-linecap="round"></path>
              </svg>
              <div class="relative z-10 p-6 sm:p-7 pt-7">
                <p class="display font-semibold leading-[0.9] tracking-tight tabular-nums text-[3rem] sm:text-[3.6rem]">{c.stat}</p>
                <p class="mt-2 text-[13px] sm:text-sm text-white/85 leading-snug max-w-[90%]">{c.statLabel}</p>
                <h3 class="display mt-6 text-lg font-semibold leading-snug">{c.title}</h3>
                <p class="mt-2 text-[14px] text-white/85 leading-relaxed">{c.desc}</p>
              </div>
              <a href={c.href} class="arrow-cta relative z-10 mt-auto p-6 sm:p-7 pt-0 inline-flex items-center gap-2 text-sm font-semibold text-white">
                Ver caso
                <svg data-arrow class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path></svg>
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- Dots -->
    <div class="mx-auto max-w-7xl px-6 sm:px-10 mt-8 flex items-center justify-between gap-4">
      <div data-carousel-dots class="flex items-center gap-2" role="tablist" aria-label="Ir a un caso"></div>
      {hayEjemplos && (
        <p class="text-xs text-sand-500 hidden sm:block"><span class="font-semibold text-ink">Ejemplo</span> = cifra ilustrativa. Los casos reales se muestran con permiso del cliente.</p>
      )}
    </div>
    {hayEjemplos && (
      <p class="sm:hidden mx-auto max-w-7xl px-6 mt-3 text-xs text-sand-500"><span class="font-semibold text-ink">Ejemplo</span> = cifra ilustrativa (placeholder).</p>
    )}
  </div>
</section>

<style>
  /* Los gradientes .accent-* viven en global.css (compartidos con Caminos). */

  /* Fondo de la sección: "wash" azul (Cobalto & aire) para que las tarjetas blancas
     resalten en vez de ser muchos blancos seguidos. Claro arriba (titular oscuro legible),
     más azul al centro (detrás de las tarjetas) y vuelve a aclarar abajo para fundir con
     la siguiente sección. Glows cobalto/cian en esquinas para dar profundidad. */
  #impacto {
    background:
      radial-gradient(55rem 38rem at 88% 14%, rgba(56, 189, 248, 0.20), transparent 60%),
      radial-gradient(50rem 42rem at 6% 86%, rgba(37, 99, 235, 0.22), transparent 62%),
      linear-gradient(180deg, #eef3fb 0%, #d8e6fc 30%, #bcd4f5 55%, #d2e2fb 80%, #eef3fb 100%);
  }

  /* ── Flip card: frente = dolor, reverso = solución + cifra ── */
  .flip-card { perspective: 1400px; }
  .flip-inner {
    position: relative;
    height: 430px;
    transition: transform 0.66s var(--ease-pitch, cubic-bezier(0.6, 0, 0.05, 1));
    transform-style: preserve-3d;
    will-change: transform;
  }
  .flip-face {
    position: absolute;
    inset: 0;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04), 0 12px 30px -18px rgba(15, 23, 42, 0.25);
  }
  .flip-back { transform: rotateY(180deg); }
  /* Voltea: hover (desktop) o checkbox marcado (toque/click) */
  @media (hover: hover) {
    .flip-card:hover .flip-inner { transform: rotateY(180deg); }
    .flip-card:hover .flip-hint svg { transform: rotate(-180deg); }
  }
  .flip-cb:checked ~ .flip-inner { transform: rotateY(180deg); }
  /* Teclado: al enfocar el enlace "Ver caso" (u otro control del reverso) la tarjeta
     se voltea para que ese foco quede visible y operable. */
  .flip-card:focus-within .flip-inner { transform: rotateY(180deg); }
  .flip-card:focus-within .flip-back a:focus-visible { outline: 2px solid #fff; outline-offset: 3px; border-radius: 6px; }
  .flip-cb:focus-visible ~ .flip-inner .flip-front { outline: 2px solid var(--color-ember); outline-offset: 3px; border-radius: 1.5rem; }
  .flip-hint svg { transition: transform 0.4s var(--ease-pitch, ease); }

  .accent-dot-ember { background: #2563eb; }
  .accent-dot-jade  { background: #0ea5b7; }
  .accent-dot-flare { background: #f97316; }

  @media (prefers-reduced-motion: reduce) {
    .flip-inner { transition: none; }
  }

  /* Ocultar la barra de scroll (el arrastre + dots + botones dan la pista) */
  .caso-track { scrollbar-width: none; scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch; }
  .caso-track::-webkit-scrollbar { display: none; }
  .caso-track:focus-visible { outline: 2px solid var(--color-ember); outline-offset: 4px; border-radius: 8px; }
  /* Al arrastrar, se desactiva el snap para un movimiento fluido (lo hace el JS) */
  .caso-track.is-dragging { scroll-snap-type: none; cursor: grabbing; }
  .caso-track.is-dragging a { pointer-events: none; }

  @media (prefers-reduced-motion: reduce) {
    .caso-track { scroll-behavior: auto; }
  }
</style>
