---
// "Impacto real": carrusel de casos con la CIFRA como protagonista (estilo
// consultora). Accesible: teclado (flechas sobre el track), arrastre, botones
// prev/next (≥44px) y dots. Motion con significado (snap + lift). Lógica en
// scripts/carousel.ts. Datos (con placeholders marcados) en data/impacto.ts.
import { impacto } from '../data/impacto';

const hayEjemplos = impacto.some((c) => c.ejemplo);
// Sparkline decorativa (curva ascendente) para la cabecera de cada tarjeta.
const spark = 'M0,44 C40,42 70,30 120,18 C170,7 210,8 260,3';
---
<section id="impacto" data-carousel class="py-24 sm:py-36 relative overflow-hidden" aria-labelledby="impacto-title">
  <div class="mx-auto max-w-7xl px-6 sm:px-10">
    <!-- Encabezado + controles -->
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-8 mb-12 sm:mb-16">
      <div class="max-w-2xl">
        <p class="reveal eyebrow-lead text-ember mb-5">Impacto real</p>
        <h2 id="impacto-title" class="reveal display text-3xl sm:text-4xl lg:text-5xl font-semibold tracking-tight leading-[1.08] text-ink text-balance">Números que cambian el negocio.</h2>
        <p class="reveal mt-5 text-lg text-sand-600 leading-relaxed">No es teoría. Esto es lo que pasa cuando una operación deja de jalar a pulso.</p>
      </div>
      <!-- Controles prev/next (desktop) -->
      <div class="reveal hidden md:flex items-center gap-3 flex-shrink-0" aria-hidden="true">
        <button type="button" data-carousel-prev aria-label="Caso anterior"
          class="caso-nav w-12 h-12 rounded-full border border-sand-300 text-sand-700 flex items-center justify-center transition-all hover:bg-ember hover:border-ember hover:text-white disabled:opacity-30 disabled:pointer-events-none">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5"></path></svg>
        </button>
        <button type="button" data-carousel-next aria-label="Caso siguiente"
          class="caso-nav w-12 h-12 rounded-full border border-sand-300 text-sand-700 flex items-center justify-center transition-all hover:bg-ember hover:border-ember hover:text-white disabled:opacity-30 disabled:pointer-events-none">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"></path></svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Pista arrastrable (full-bleed: sangra a los bordes para el peek) -->
  <div class="reveal">
    <div data-carousel-track role="region" aria-roledescription="carrusel" aria-label="Casos de impacto" tabindex="0"
      class="caso-track flex gap-5 sm:gap-6 overflow-x-auto pb-2 px-6 sm:px-10 [scroll-padding-left:1.5rem] sm:[scroll-padding-left:2.5rem]">
      {impacto.map((c) => (
        <article class={`caso-card group lift snap-start shrink-0 w-[290px] sm:w-[340px] rounded-3xl overflow-hidden border border-sand-200 bg-white`}>
          <a href={c.href} class="block focus:outline-none">
            <!-- Cabecera: la cifra manda -->
            <div class={`caso-head accent-${c.accent} relative p-6 sm:p-7 h-[220px] flex flex-col text-white overflow-hidden`}>
              <div class="flex items-start justify-between gap-3 relative z-10">
                <span class="inline-flex items-center rounded-full bg-black/20 backdrop-blur-sm border border-white/25 px-3 py-1 text-[11px] font-semibold tracking-wide">{c.categoria}</span>
                {c.ejemplo && <span class="inline-flex items-center gap-1 rounded-full bg-white/90 text-ink px-2.5 py-1 text-[10px] font-bold uppercase tracking-wider">Ejemplo</span>}
              </div>
              <!-- Sparkline decorativa -->
              <svg class="absolute left-0 right-0 bottom-14 w-full h-16 opacity-40 z-0" viewBox="0 0 260 48" fill="none" preserveAspectRatio="none" aria-hidden="true">
                <path d={spark} stroke="#fff" stroke-width="2" stroke-linecap="round"></path>
              </svg>
              <div class="mt-auto relative z-10">
                <p class="display font-semibold leading-[0.9] tracking-tight tabular-nums text-[2.9rem] sm:text-[3.4rem]">{c.stat}</p>
                <p class="mt-2 text-[13px] sm:text-sm text-white/85 leading-snug max-w-[85%]">{c.statLabel}</p>
              </div>
            </div>
            <!-- Cuerpo: la transformación -->
            <div class="p-6 sm:p-7 flex flex-col min-h-[210px]">
              <h3 class="display text-lg sm:text-xl font-semibold text-ink leading-snug">{c.title}</h3>
              <p class="mt-3 text-[15px] text-sand-600 leading-relaxed">{c.desc}</p>
              <span class="arrow-cta mt-auto pt-6 inline-flex items-center gap-2 text-sm font-semibold text-ember">
                Ver caso
                <svg data-arrow class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path></svg>
              </span>
            </div>
          </a>
        </article>
      ))}
    </div>

    <!-- Dots -->
    <div class="mx-auto max-w-7xl px-6 sm:px-10 mt-8 flex items-center justify-between gap-4">
      <div data-carousel-dots class="flex items-center gap-2" role="tablist" aria-label="Ir a un caso"></div>
      {hayEjemplos && (
        <p class="text-xs text-sand-500 hidden sm:block"><span class="font-semibold text-ink">Ejemplo</span> = cifra ilustrativa. Los casos reales se muestran con permiso del cliente.</p>
      )}
    </div>
    {hayEjemplos && (
      <p class="sm:hidden mx-auto max-w-7xl px-6 mt-3 text-xs text-sand-500"><span class="font-semibold text-ink">Ejemplo</span> = cifra ilustrativa (placeholder).</p>
    )}
  </div>
</section>

<style>
  /* Los gradientes .accent-* viven en global.css (compartidos con Caminos). */

  /* Ocultar la barra de scroll (el arrastre + dots + botones dan la pista) */
  .caso-track { scrollbar-width: none; scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch; }
  .caso-track::-webkit-scrollbar { display: none; }
  .caso-track:focus-visible { outline: 2px solid var(--color-ember); outline-offset: 4px; border-radius: 8px; }
  /* Al arrastrar, se desactiva el snap para un movimiento fluido (lo hace el JS) */
  .caso-track.is-dragging { scroll-snap-type: none; cursor: grabbing; }
  .caso-track.is-dragging a { pointer-events: none; }

  @media (prefers-reduced-motion: reduce) {
    .caso-track { scroll-behavior: auto; }
  }
</style>
