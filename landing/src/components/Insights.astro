---
// Grid editorial de "Ideas" (thought leadership, estilo insights de BCG).
// ⚠️ CONTENIDO PLACEHOLDER: aún no hay blog. Las notas están marcadas
// "Próximamente" y no enlazan a ningún lado (nada de links muertos). Cuando
// tengas artículos reales, cambia `pronto` por su `href` y quita el badge.
export interface Props { waLink?: string }
const { waLink = 'https://wa.me/5215611846200' } = Astro.props;

const ideas = [
  {
    categoria: 'Operación',
    accent: 'ember' as const,
    title: 'Cómo saber si tu negocio depende demasiado de ti',
    excerpt: 'Tres señales de que te convertiste en el cuello de botella —y el primer paso para soltarlo.',
    pronto: true,
  },
  {
    categoria: 'Inteligencia Artificial',
    accent: 'jade' as const,
    title: 'IA en tu operación: por dónde empezar sin quemar dinero',
    excerpt: 'No necesitas un equipo de datos. Necesitas un primer caso bien elegido que se pague solo.',
    pronto: true,
  },
  {
    categoria: 'Transformación',
    accent: 'flare' as const,
    title: 'Digitalizar no es comprar software',
    excerpt: 'Por qué meter una herramienta a fuerza casi siempre falla —y qué hacer en su lugar.',
    pronto: true,
  },
];

const accentText = { ember: 'text-ember', jade: 'text-jade', flare: 'text-flare' } as const;
const accentSoft = { ember: 'bg-ember/12', jade: 'bg-jade/15', flare: 'bg-flare/12' } as const;
---
<section id="ideas" class="py-24 sm:py-32 px-6 sm:px-10 relative overflow-hidden" aria-labelledby="ideas-title">
  <div class="mx-auto max-w-7xl">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-14 sm:mb-16">
      <div class="max-w-2xl">
        <p class="reveal eyebrow-lead text-ember mb-5">Ideas</p>
        <h2 id="ideas-title" class="reveal display text-3xl sm:text-4xl lg:text-5xl font-semibold tracking-tight leading-[1.08] text-ink text-balance">Lo que vamos compartiendo.</h2>
        <p class="reveal mt-5 text-lg text-sand-600 leading-relaxed">Notas cortas y directas sobre operación, IA y crecer con orden. Sin relleno.</p>
      </div>
      <a href={waLink} target="_blank" rel="noopener" class="reveal arrow-cta hidden md:inline-flex items-center gap-2 text-sm font-semibold text-ember flex-shrink-0">
        Avísame cuando publiquen
        <svg data-arrow class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path></svg>
      </a>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      {ideas.map((n, i) => (
        <article class={`reveal reveal-d${i + 1} lift rounded-3xl border border-sand-200 bg-white p-7 sm:p-8 flex flex-col min-h-[280px]`}>
          <div class="flex items-center justify-between gap-3 mb-6">
            <span class={`inline-flex items-center rounded-full ${accentSoft[n.accent]} ${accentText[n.accent]} px-3 py-1 text-[11px] font-semibold uppercase tracking-wide`}>{n.categoria}</span>
            {n.pronto && <span class="inline-flex items-center rounded-full border border-sand-300 text-sand-500 px-2.5 py-1 text-[10px] font-bold uppercase tracking-wider">Próximamente</span>}
          </div>
          <h3 class="display text-xl sm:text-[1.35rem] font-semibold text-ink leading-snug text-balance">{n.title}</h3>
          <p class="mt-3 text-[15px] text-sand-600 leading-relaxed">{n.excerpt}</p>
          <span class="mt-auto pt-6 inline-flex items-center gap-2 text-sm font-semibold text-sand-400">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            En preparación
          </span>
        </article>
      ))}
    </div>

    <p class="reveal md:hidden mt-8 text-center">
      <a href={waLink} target="_blank" rel="noopener" class="arrow-cta inline-flex items-center gap-2 text-sm font-semibold text-ember">
        Avísame cuando publiquen
        <svg data-arrow class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path></svg>
      </a>
    </p>
  </div>
</section>
