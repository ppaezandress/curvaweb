---
// Cortinilla "Líquido + rebote": el isotipo se LLENA como líquido (de abajo hacia
// arriba, superficie ondulante), el PUNTO BRINCA (rebota) a su lugar, y "curva"
// entra con barrido. Al cerrar, el TELÓN se retira barriendo hacia la DERECHA con
// un borde en forma de curva (la firma de la marca). Fondo blanco. 1ª visita/sesión.
import logoAnim from '../svg/curva-logo-anim.svg?raw';

const isoGroupRaw = logoAnim.match(/<g id="isotipo">[\s\S]*?<\/g>/)[0];
const trazoD = isoGroupRaw.match(/id="trazo" d="([^"]*)"/)[1];
const isoGroup = isoGroupRaw.replace('id="trazo"', 'id="trazo" mask="url(#liquid)"');

const isoSvg = `<svg viewBox="26 22 316 212" xmlns="http://www.w3.org/2000/svg" fill="currentColor">
  <defs>
    <linearGradient id="isoGrad" x1="0" y1="1" x2="1" y2="0">
      <stop offset="0" stop-color="#1d4ed8"/><stop offset="0.5" stop-color="#2563eb"/><stop offset="1" stop-color="#38bdf8"/>
    </linearGradient>
    <mask id="liquid">
      <g id="liquid-rise">
        <g id="liquid-ripple">
          <path d="M -180 40 q 30 -20 60 0 t 60 0 t 60 0 t 60 0 t 60 0 t 60 0 t 60 0 t 60 0 t 60 0 t 60 0 t 60 0 L 480 300 L -180 300 Z" fill="#fff"/>
        </g>
      </g>
    </mask>
  </defs>
  <path id="trazo-ghost" d="${trazoD}" fill="#e8f0ff"/>
  ${isoGroup}
</svg>`;

const wmGroup = logoAnim.match(/<g id="wordmark">[\s\S]*?<\/g>/)[0];
const wordSvg = `<svg viewBox="330 70 645 150" xmlns="http://www.w3.org/2000/svg" fill="currentColor">${wmGroup}</svg>`;
---
<div id="intro" class="intro-overlay" role="presentation" aria-hidden="true">
  <svg class="intro-curtain" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true">
    <path id="curtain" d="M 0 0 C 0 33, 0 67, 0 100 L 100 100 L 100 0 Z" fill="#ffffff"></path>
  </svg>
  <div class="intro-lockup">
    <span class="intro-iso" set:html={isoSvg}></span>
    <span class="intro-word-wrap"><span class="intro-word" set:html={wordSvg}></span></span>
  </div>
</div>

<style>
  .intro-overlay {
    position: fixed; inset: 0; z-index: 9999;
    display: flex; align-items: center; justify-content: center;
    background: transparent; overflow: hidden;
  }
  /* Telón: SVG blanco a pantalla completa; su borde izquierdo se transforma en
     curva y barre hacia la derecha revelando el hero. */
  .intro-curtain { position: absolute; inset: 0; width: 100%; height: 100%; z-index: 0; }
  .intro-overlay.intro-out #curtain { animation: sweep .9s cubic-bezier(0.7,0,0.25,1) forwards; }
  .intro-overlay.intro-out .intro-lockup { animation: lockup-out .62s cubic-bezier(0.7,0,0.3,1) forwards; }

  .intro-lockup {
    position: relative; z-index: 1; display: flex; flex-direction: column; align-items: center;
    gap: clamp(.7rem, 1.8vw, 1.2rem);
  }

  /* ---- Isotipo: se llena como líquido + el punto rebota ---- */
  .intro-iso { color: var(--color-ink); display: block; filter: drop-shadow(0 12px 28px rgba(37,99,235,0.16)); }
  .intro-iso :global(svg) { width: clamp(96px, 15vw, 148px); height: auto; display: block; overflow: visible; }
  .intro-iso :global(#trazo) { fill: url(#isoGrad); }
  .intro-iso :global(#punto) { fill: url(#isoGrad); opacity: 0; transform-box: fill-box; transform-origin: center bottom; transform: translateY(-95px); }

  /* el líquido: sube (rise) mientras su superficie ondula (ripple) */
  .intro-iso :global(#liquid-rise)   { transform: translateY(192px); }
  .intro-iso :global(#liquid-ripple) { transform: translateX(0); }

  /* ---- Wordmark "curva": barrido suave ---- */
  .intro-word-wrap { display: block; }
  .intro-word { color: var(--color-ink); display: block; clip-path: inset(-10% 102% -10% -2%); opacity: 0; transform: translateY(9px); }
  .intro-word :global(svg) { width: clamp(150px, 26vw, 268px); height: auto; display: block; }

  /* ---- Timeline (entrada) ---- */
  .intro-play .intro-iso :global(#liquid-rise)   { animation: liquid-rise 1.35s cubic-bezier(0.32,0.5,0.38,1) forwards .2s; }
  .intro-play .intro-iso :global(#liquid-ripple) { animation: liquid-ripple 1.2s linear infinite; }
  .intro-play .intro-iso :global(#punto)         { animation: bounce .95s forwards 1.2s; }
  .intro-play .intro-word                        { animation: word-in .85s cubic-bezier(0.16,1,0.3,1) forwards 2.05s; }

  @keyframes liquid-rise   { to { transform: translateY(-16px); } }
  @keyframes liquid-ripple { to { transform: translateX(-120px); } }
  /* el punto cae y REBOTA (2 botes decrecientes con squash sutil), glow naranja al impactar */
  @keyframes bounce {
    0%   { opacity: 0; transform: translateY(-95px) scale(1); filter: drop-shadow(0 0 0 rgba(249,115,22,0)); }
    12%  { opacity: 1; }
    40%  { transform: translateY(0) scale(1); filter: drop-shadow(0 0 11px rgba(249,115,22,.85)); }
    49%  { transform: translateY(0) scale(1.18, .84); }
    67%  { transform: translateY(-26px) scale(.96, 1.05); }
    82%  { transform: translateY(0) scale(1.09, .93); }
    92%  { transform: translateY(-7px) scale(1); }
    100% { opacity: 1; transform: translateY(0) scale(1); filter: drop-shadow(0 0 0 rgba(249,115,22,0)); }
  }
  @keyframes word-in { to { clip-path: inset(-10% -2% -10% -2%); opacity: 1; transform: translateY(0); } }

  /* ---- Salida: telón barre a la derecha con borde en curva; el logo lo acompaña ---- */
  @keyframes sweep {
    0%   { d: path("M 0 0 C 0 33, 0 67, 0 100 L 100 100 L 100 0 Z"); }
    100% { d: path("M 120 0 C 100 28, 140 72, 120 100 L 210 100 L 210 0 Z"); }
  }
  @keyframes lockup-out { to { transform: translateX(42vw) scale(.9); opacity: 0; } }

  @media (prefers-reduced-motion: reduce) { .intro-overlay { display: none; } }
</style>
