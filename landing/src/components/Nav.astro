---
import { frentes } from '../data/consultoria';
import { soluciones } from '../data/soluciones';

interface Props {
  overHero?: boolean;
  calLink: string;
}
const { overHero = false, calLink } = Astro.props;

// Consultoría: 2 frentes; cada frente muestra sus 3 pilares como anclas a la
// MISMA página del frente (no abre otra página, hace scroll al pilar).
const consultoria = frentes.map((f) => ({
  label: f.navLabel,
  href: `/consultoria/${f.slug}`,
  destacado: f.destacado,
  items: f.pilares.map((p) => ({ label: p.titulo, href: `/consultoria/${f.slug}#${p.id}` })),
}));

// Soluciones digitales: lista de soluciones (ancla dentro de /soluciones).
const solucionesMenu = soluciones.map((s) => ({ label: s.titulo, href: `/soluciones#${s.id}` }));
---

<div id="site-nav" class="nav-bar fixed top-0 inset-x-0 z-50 px-3 sm:px-4 pt-3" data-over-hero={overHero ? '' : undefined}>
  <nav class="nav-inner mx-auto max-w-6xl flex items-center justify-between rounded-2xl pl-5 pr-2.5 py-2.5" aria-label="Principal">
    <a href="/" class="nav-logo display text-xl font-semibold tracking-tight flex items-center gap-2">
      <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M2 18C6 18 7 6 12 6C17 6 18 18 22 18" stroke="url(#nv)" stroke-width="2.5" stroke-linecap="round"></path><defs><linearGradient id="nv" x1="2" y1="0" x2="22" y2="0"><stop stop-color="#2563eb"></stop><stop offset="0.5" stop-color="#3b82f6"></stop><stop offset="1" stop-color="#38bdf8"></stop></linearGradient></defs></svg>
      curva
    </a>

    <div class="flex items-center gap-1">
      <!-- Mega-menú Consultoría (2 frentes con sus pilares) -->
      <div data-dropdown class="hidden md:block">
        <button data-dropdown-trigger aria-haspopup="menu" aria-expanded="false" class="nav-link inline-flex items-center gap-1.5">
          Consultoría
          <svg class="w-3.5 h-3.5 opacity-70" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"></path></svg>
        </button>
        <div data-dropdown-menu role="menu" class="nav-mega fixed left-0 right-0 mx-auto top-[4.6rem] w-[min(94vw,52rem)] bg-white rounded-2xl shadow-2xl border border-sand-200 p-6">
          <div class="grid grid-cols-2 gap-5">
            {consultoria.map((frente) => (
              <div>
                <a href={frente.href} role="menuitem" class="menu-item flex items-center gap-2 text-[13px] font-semibold text-ink mb-3 px-3 py-2 rounded-lg">
                  {frente.label}
                  {frente.destacado && <span class="text-[10px] font-semibold uppercase tracking-wide text-ember bg-ember/10 rounded-full px-2 py-0.5">Fuerte</span>}
                </a>
                <ul class="space-y-0.5">
                  {frente.items.map((it) => (
                    <li><a href={it.href} role="menuitem" class="menu-item block text-sm text-sand-700 px-3 py-2 rounded-lg hover:text-ink">{it.label}</a></li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Soluciones digitales -->
      <div data-dropdown class="hidden md:block">
        <button data-dropdown-trigger aria-haspopup="menu" aria-expanded="false" class="nav-link inline-flex items-center gap-1.5">
          Soluciones digitales
          <svg class="w-3.5 h-3.5 opacity-70" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"></path></svg>
        </button>
        <div data-dropdown-menu role="menu" class="nav-menu absolute right-0 top-full mt-3 w-72 bg-white rounded-2xl shadow-2xl border border-sand-200 p-2">
          {solucionesMenu.map((p) => (
            <a href={p.href} role="menuitem" class="menu-item flex items-start gap-3 p-3 rounded-xl">
              <span class="w-9 h-9 rounded-lg bg-ember/10 flex items-center justify-center flex-shrink-0 mt-0.5"><span class="w-2.5 h-2.5 rounded-full bg-ember"></span></span>
              <span class="text-sm font-semibold block text-ink">{p.label}</span>
            </a>
          ))}
        </div>
      </div>

      <a href="/nosotros" class="nav-link hidden md:inline-flex">Nosotros</a>
      <a href={calLink} target="_blank" rel="noopener" class="nav-cta btn-arrow hidden sm:inline-flex items-center gap-1.5 text-sm font-semibold px-5 py-2.5 rounded-full transition-colors ml-1">
        Conversemos
        <svg data-arrow class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path></svg>
      </a>

      <button data-burger aria-label="Abrir menú" aria-expanded="false" aria-controls="mobile-menu" class="burger md:hidden flex flex-col gap-[5px] p-2.5">
        <span class="burger-line"></span>
        <span class="burger-line"></span>
        <span class="burger-line"></span>
      </button>
    </div>
  </nav>
</div>

<!-- Menú móvil -->
<div id="mobile-menu" class="mobile-menu md:hidden">
  <div class="flex flex-col h-full pt-24 px-7 pb-8 bg-sand-50 overflow-y-auto">
    <p class="eyebrow text-sand-500 mb-3">Consultoría</p>
    <nav class="flex flex-col" aria-label="Móvil">
      {consultoria.map((frente) => (
        <a href={frente.href} class="flex items-center gap-3 py-3 border-b border-sand-200 text-ink">
          <span class="w-2 h-2 rounded-full flex-shrink-0 bg-ember"></span>
          <span class="text-base font-semibold">{frente.label}</span>
        </a>
      ))}
    </nav>
    <p class="eyebrow text-sand-500 mb-3 mt-7">Soluciones digitales</p>
    <nav class="flex flex-col">
      {solucionesMenu.map((p) => (
        <a href={p.href} class="flex items-center gap-3 py-3 border-b border-sand-200 text-ink">
          <span class="w-2 h-2 rounded-full flex-shrink-0 bg-gold"></span>
          <span class="text-base font-semibold">{p.label}</span>
        </a>
      ))}
    </nav>
    <div class="flex flex-col mt-6">
      <a href="/nosotros" class="py-3.5 border-b border-sand-200 text-lg font-semibold text-sand-700">Nosotros</a>
    </div>
    <div class="mt-auto pt-8">
      <a href={calLink} target="_blank" rel="noopener" class="block w-full text-center text-base font-semibold bg-ink text-sand-50 px-6 py-4 rounded-full">Conversemos</a>
    </div>
  </div>
</div>

<style>
  .nav-inner {
    transition: background-color .35s ease, border-color .35s ease, box-shadow .35s ease;
    -webkit-backdrop-filter: blur(14px);
    backdrop-filter: blur(14px);
    background: rgba(15, 30, 61, 0.32);
    border: 1px solid rgba(255, 255, 255, 0.10);
  }
  .nav-bar .nav-logo { color: #fff; }
  .nav-bar .nav-link {
    color: rgba(255, 255, 255, 0.80);
    font-size: 0.875rem; font-weight: 500;
    padding: 0.5rem 0.85rem; border-radius: 9999px;
    transition: background-color .2s ease, color .2s ease;
  }
  .nav-bar .nav-link:hover { color: #fff; background: rgba(255, 255, 255, 0.12); }
  .nav-bar .nav-cta { background: #fff; color: var(--color-ink); }
  .nav-bar .nav-cta:hover { background: rgba(255, 255, 255, 0.88); }
  .nav-bar .burger-line { display: block; width: 20px; height: 2px; background: #fff; transition: transform .3s ease, opacity .3s ease, background-color .35s ease; }

  /* Scrolled: barra clara */
  .nav-bar.scrolled .nav-inner { background: rgba(245, 248, 255, 0.88); border-color: var(--color-sand-200); box-shadow: 0 10px 34px rgba(15, 30, 61, 0.10); }
  .nav-bar.scrolled .nav-logo { color: var(--color-ink); }
  .nav-bar.scrolled .nav-link { color: var(--color-sand-600); }
  .nav-bar.scrolled .nav-link:hover { color: var(--color-ink); background: var(--color-sand-100); }
  .nav-bar.scrolled .nav-cta { background: var(--color-ink); color: var(--color-sand-50); }
  .nav-bar.scrolled .nav-cta:hover { background: #1b3a6b; }
  .nav-bar.scrolled .burger-line { background: var(--color-ink); }

  /* visibility:hidden saca los enlaces del cerrado del orden de tabulación (a11y);
     se retrasa hasta que termina el fade para no cortar la animación. */
  .nav-menu, .nav-mega { opacity: 0; visibility: hidden; transform: translateY(-8px) scale(.98); pointer-events: none; transition: opacity .25s ease, transform .25s ease, visibility 0s .25s; transform-origin: top; }
  .nav-menu.open, .nav-mega.open { opacity: 1; visibility: visible; transform: none; pointer-events: auto; transition: opacity .25s ease, transform .25s ease, visibility 0s; }
  .menu-item { transition: background-color .15s ease, color .15s ease; }
  .menu-item:hover { background-color: var(--color-sand-50); }

  .mobile-menu { position: fixed; inset: 0; z-index: 40; visibility: hidden; transform: translateX(100%); transition: transform .35s var(--ease-curve), visibility 0s .35s; }
  .mobile-menu.open { visibility: visible; transform: translateX(0); transition: transform .35s var(--ease-curve), visibility 0s; }
</style>
