---
import { frentes } from '../data/consultoria';
import logoSvg from '../svg/curva-logo.svg?raw';

interface Props {
  overHero?: boolean;
  calLink: string;
}
const { overHero = false, calLink } = Astro.props;

// Los 2 frentes de Consultoría para el dropdown (única fuente: data/consultoria).
const consultoriaItems = [...frentes]
  .sort((a, b) => a.order - b.order)
  .map((f) => ({
    label: f.title,
    href: `/consultoria/${f.slug}`,
    desc: f.headline,
    destacado: !!f.destacado,
  }));

// Íconos de cada frente (trazo, 22×22).
const frenteIcon: Record<string, string> = {
  'transformacion-digital':
    '<rect x="3" y="4" width="18" height="13" rx="2"/><path d="M8 21h8M12 17v4"/><path d="M8.5 11.5l2 2 4-4"/>',
  'transformacion-de-negocio':
    '<circle cx="12" cy="12" r="9"/><path d="M12 3v3M12 18v3M3 12h3M18 12h3"/><path d="M15.5 8.5l-2.5 4.5-3.5 1 2.5-4.5 3.5-1z"/>',
};
const slugOf = (href: string) => href.split('/').pop() || '';
---

<div id="site-nav" class="nav-bar fixed top-0 inset-x-0 z-50 px-3 sm:px-4 pt-3" data-over-hero={overHero ? '' : undefined}>
  <nav class="nav-inner mx-auto max-w-6xl flex items-center justify-between rounded-2xl pl-5 pr-2.5 py-2.5" aria-label="Principal">
    <a href="/" class="nav-logo flex items-center" aria-label="curva · Inicio">
      <span class="nav-logo-svg" set:html={logoSvg}></span>
    </a>

    <!-- Links de escritorio: TODO vive aquí -->
    <div class="nav-links hidden lg:flex items-center gap-0.5">
      <a href="/#impacto" class="nav-toplink">Casos</a>

      <!-- Consultoría: único con dropdown -->
      <div class="nav-drop" data-nav-drop>
        <button type="button" class="nav-toplink nav-drop-btn" data-nav-drop-btn aria-haspopup="true" aria-expanded="false" aria-controls="nav-drop-consultoria">
          Consultoría
          <svg class="nav-chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"></path></svg>
        </button>

        <div id="nav-drop-consultoria" class="nav-drop-panel" data-nav-drop-panel role="menu">
          <p class="nav-drop-eyebrow">Dos frentes de consultoría</p>
          {consultoriaItems.map((c) => (
            <a href={c.href} class:list={["nav-drop-item", c.destacado && "is-featured"]} role="menuitem">
              <span class="nav-drop-ico" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" set:html={frenteIcon[slugOf(c.href)]}></svg>
              </span>
              <span class="nav-drop-text">
                <span class="nav-drop-item-title">
                  {c.label}
                  {c.destacado && <span class="nav-drop-tag">Empieza aquí</span>}
                </span>
                <span class="nav-drop-item-desc">{c.desc}</span>
              </span>
              <svg class="nav-drop-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M13.5 4.5L21 12l-7.5 7.5M21 12H3"></path></svg>
            </a>
          ))}
        </div>
      </div>

      <a href="/soluciones" class="nav-toplink">Soluciones</a>
      <a href="/nosotros" class="nav-toplink">Nosotros</a>
    </div>

    <div class="flex items-center gap-1.5">
      <a href={calLink} target="_blank" rel="noopener" class="nav-cta btn-arrow hidden sm:inline-flex items-center gap-1.5 text-sm font-semibold px-5 py-2.5 rounded-full transition-colors">
        Conversemos
        <svg data-arrow class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path></svg>
      </a>
      <!-- Hamburguesa: solo móvil/tablet -->
      <button type="button" class="nav-burger lg:hidden inline-flex items-center justify-center w-11 h-11 rounded-full" data-nav-burger aria-expanded="false" aria-controls="nav-mobile" aria-label="Abrir menú">
        <span class="nav-burger-ico" aria-hidden="true"><span></span><span></span><span></span></span>
      </button>
    </div>
  </nav>

  <!-- Panel móvil compacto (NO pantalla completa): baja desde la barra -->
  <div id="nav-mobile" class="nav-mobile lg:hidden mx-auto max-w-6xl" data-nav-mobile aria-hidden="true">
    <div class="nav-mobile-inner">
      <a href="/#impacto" class="nav-m-link" data-nav-m-link>Casos</a>

      <div class="nav-m-group" data-nav-m-group>
        <button type="button" class="nav-m-link nav-m-acc" data-nav-m-acc aria-expanded="false">
          Consultoría
          <svg class="nav-chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"></path></svg>
        </button>
        <div class="nav-m-sub" data-nav-m-sub>
          {consultoriaItems.map((c) => (
            <a href={c.href} class="nav-m-sublink" data-nav-m-link>
              <span class="nav-m-sub-title">{c.label}</span>
              <span class="nav-m-sub-desc">{c.desc}</span>
            </a>
          ))}
        </div>
      </div>

      <a href="/soluciones" class="nav-m-link" data-nav-m-link>Soluciones</a>
      <a href="/nosotros" class="nav-m-link" data-nav-m-link>Nosotros</a>
      <a href={calLink} target="_blank" rel="noopener" class="nav-m-cta" data-nav-m-link>
        Conversemos
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M13.5 4.5L21 12l-7.5 7.5M21 12H3"></path></svg>
      </a>
    </div>
  </div>
</div>

<style>
  /* ---------------- Barra ---------------- */
  .nav-inner {
    position: relative;
    transition: background-color .35s ease, border-color .35s ease, box-shadow .35s ease;
    -webkit-backdrop-filter: blur(14px);
    backdrop-filter: blur(14px);
    background: rgba(15, 30, 61, 0.32);
    border: 1px solid rgba(255, 255, 255, 0.10);
  }
  .nav-bar .nav-logo { color: #fff; }
  .nav-logo-svg { display: block; }
  .nav-logo-svg :global(svg) { height: 1.35rem; width: auto; display: block; }
  .nav-bar .nav-cta { background: #fff; color: var(--color-ink); }
  .nav-bar .nav-cta:hover { background: rgba(255, 255, 255, 0.88); }
  /* Press feedback: el CTA de conversión debe "responder al toque" (Emil). */
  .nav-cta { transition: background-color .2s ease, color .2s ease, transform .16s var(--ease-curve); }
  .nav-cta:active { transform: scale(0.97); }

  /* Links de nivel superior */
  .nav-toplink {
    display: inline-flex; align-items: center; gap: .3rem;
    color: rgba(255, 255, 255, 0.82); font-size: .875rem; font-weight: 500; letter-spacing: .01em;
    padding: .5rem .85rem; border-radius: 9999px; background: transparent; border: 0; cursor: pointer;
    transition: color .2s ease, background-color .2s ease;
  }
  .nav-toplink:hover { color: #fff; background: rgba(255,255,255,0.10); }
  .nav-chev { width: .8rem; height: .8rem; transition: transform .28s var(--ease-curve); }
  .nav-drop[data-open] .nav-drop-btn .nav-chev { transform: rotate(180deg); }

  .nav-bar.scrolled .nav-toplink { color: var(--color-sand-600); }
  .nav-bar.scrolled .nav-toplink:hover { color: var(--color-ink); background: var(--color-sand-100); }

  /* Scrolled: barra clara */
  .nav-bar.scrolled .nav-inner { background: rgba(245, 248, 255, 0.88); border-color: var(--color-sand-200); box-shadow: 0 10px 34px rgba(15, 30, 61, 0.10); }
  .nav-bar.scrolled .nav-logo { color: var(--color-ink); }
  .nav-bar.scrolled .nav-cta { background: var(--color-ink); color: var(--color-sand-50); }
  .nav-bar.scrolled .nav-cta:hover { background: #1b3a6b; }

  /* ---------------- Dropdown Consultoría (desktop) ---------------- */
  .nav-drop { position: relative; }
  .nav-drop-panel {
    position: absolute; top: calc(100% + .55rem); left: 50%;
    width: 24rem; transform: translateX(-50%) translateY(8px) scale(.98);
    transform-origin: top center;
    background: #fff; border: 1px solid var(--color-sand-200);
    border-radius: 1.15rem; padding: .85rem;
    box-shadow: 0 24px 60px -18px rgba(15, 30, 61, 0.32), 0 6px 18px -12px rgba(15,30,61,.2);
    opacity: 0; visibility: hidden; pointer-events: none;
    transition: opacity .22s var(--ease-curve), transform .28s var(--ease-curve), visibility 0s .28s;
  }
  .nav-drop[data-open] .nav-drop-panel {
    opacity: 1; visibility: visible; pointer-events: auto;
    transform: translateX(-50%) translateY(0) scale(1);
    transition: opacity .24s var(--ease-curve), transform .3s var(--ease-curve), visibility 0s;
  }
  /* Puentecito invisible para que el hover no se corte entre botón y panel */
  .nav-drop-panel::before { content: ''; position: absolute; top: -.7rem; left: 0; right: 0; height: .7rem; }
  /* Flechita del tooltip */
  .nav-drop-panel::after {
    content: ''; position: absolute; top: -.42rem; left: 50%; width: .84rem; height: .84rem;
    transform: translateX(-50%) rotate(45deg);
    background: #fff; border-left: 1px solid var(--color-sand-200); border-top: 1px solid var(--color-sand-200);
    border-top-left-radius: .2rem;
  }
  .nav-drop-eyebrow {
    font-size: .68rem; font-weight: 700; text-transform: uppercase; letter-spacing: .12em;
    color: var(--color-sand-400); padding: .35rem .6rem .55rem;
  }
  .nav-drop-item {
    display: flex; align-items: flex-start; gap: .8rem;
    padding: .8rem .7rem; border-radius: .85rem; position: relative;
    transition: background-color .18s ease, transform .18s ease;
  }
  .nav-drop-item:hover { background: var(--color-sand-100); }
  .nav-drop-ico {
    flex-shrink: 0; display: grid; place-items: center; width: 2.35rem; height: 2.35rem; border-radius: .7rem;
    background: color-mix(in srgb, var(--color-ember) 12%, #fff); color: var(--color-ember);
    transition: background-color .18s ease, color .18s ease;
  }
  .nav-drop-item.is-featured .nav-drop-ico { background: color-mix(in srgb, var(--color-ember) 14%, #fff); }
  .nav-drop-item:not(.is-featured) .nav-drop-ico { background: color-mix(in srgb, var(--color-gold) 14%, #fff); color: #0284c7; }
  .nav-drop-ico svg { width: 1.2rem; height: 1.2rem; }
  .nav-drop-text { display: flex; flex-direction: column; gap: .18rem; min-width: 0; }
  .nav-drop-item-title {
    display: inline-flex; align-items: center; gap: .5rem; flex-wrap: wrap;
    font-family: var(--font-display); font-weight: 600; font-size: .95rem; color: var(--color-ink); letter-spacing: -.01em;
  }
  .nav-drop-tag {
    font-size: .58rem; font-weight: 700; text-transform: uppercase; letter-spacing: .06em;
    color: #fff; background: var(--color-ember); border-radius: 9999px; padding: .1rem .42rem;
  }
  .nav-drop-item-desc { font-size: .82rem; color: var(--color-sand-500); line-height: 1.4; }
  .nav-drop-arrow {
    width: 1.05rem; height: 1.05rem; color: var(--color-sand-300); align-self: center; flex-shrink: 0;
    transition: transform .22s var(--ease-curve), color .18s ease;
  }
  .nav-drop-item:hover .nav-drop-arrow { color: var(--color-ember); transform: translateX(3px); }

  /* ---------------- Hamburguesa ---------------- */
  .nav-burger { color: #fff; background: rgba(255,255,255,0.10); border: 1px solid rgba(255,255,255,0.14); transition: background-color .2s ease, transform .16s var(--ease-curve); }
  .nav-burger:hover { background: rgba(255,255,255,0.18); }
  .nav-burger:active { transform: scale(0.92); }
  .nav-bar.scrolled .nav-burger { color: var(--color-ink); background: var(--color-sand-100); border-color: var(--color-sand-200); }
  .nav-burger-ico { display: grid; gap: 4px; width: 20px; place-content: center; }
  .nav-burger-ico span { display: block; width: 18px; height: 2px; border-radius: 2px; background: currentColor; transition: transform .3s var(--ease-curve), opacity .2s ease; }
  .nav-burger[aria-expanded="true"] .nav-burger-ico span:nth-child(1) { transform: translateY(6px) rotate(45deg); }
  .nav-burger[aria-expanded="true"] .nav-burger-ico span:nth-child(2) { opacity: 0; }
  .nav-burger[aria-expanded="true"] .nav-burger-ico span:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }

  /* ---------------- Panel móvil compacto ---------------- */
  .nav-mobile {
    padding: 0 .25rem; overflow: hidden;
    max-height: 0; opacity: 0;
    transition: max-height .38s var(--ease-curve), opacity .28s ease, margin-top .38s var(--ease-curve);
    margin-top: 0;
  }
  .nav-mobile[data-open] { max-height: 34rem; opacity: 1; margin-top: .5rem; }
  .nav-mobile-inner {
    background: rgba(245, 248, 255, 0.96); -webkit-backdrop-filter: blur(16px); backdrop-filter: blur(16px);
    border: 1px solid var(--color-sand-200); border-radius: 1.15rem; padding: .6rem;
    box-shadow: 0 20px 50px -16px rgba(15, 30, 61, 0.28);
    display: flex; flex-direction: column; gap: .1rem;
  }
  .nav-m-link {
    display: flex; align-items: center; justify-content: space-between;
    font-size: 1rem; font-weight: 600; color: var(--color-ink);
    padding: .85rem .9rem; border-radius: .8rem; background: transparent; border: 0; width: 100%; text-align: left; cursor: pointer;
    transition: background-color .18s ease;
  }
  .nav-m-link:hover, .nav-m-acc[aria-expanded="true"] { background: var(--color-sand-100); }
  .nav-m-group { display: flex; flex-direction: column; }
  .nav-m-acc .nav-chev { width: 1rem; height: 1rem; color: var(--color-sand-400); }
  .nav-m-acc[aria-expanded="true"] .nav-chev { transform: rotate(180deg); }
  .nav-m-sub {
    display: grid; grid-template-rows: 0fr; overflow: hidden;
    transition: grid-template-rows .32s var(--ease-curve);
    padding: 0 .4rem;
  }
  .nav-m-group[data-open] .nav-m-sub { grid-template-rows: 1fr; }
  .nav-m-sub > * { min-height: 0; }
  .nav-m-sublink {
    display: flex; flex-direction: column; gap: .1rem;
    padding: .7rem .8rem; border-radius: .7rem; border-left: 2px solid var(--color-sand-200); margin: .15rem 0;
    transition: background-color .18s ease, border-color .18s ease;
  }
  .nav-m-sublink:hover { background: var(--color-sand-100); border-color: var(--color-ember); }
  .nav-m-sub-title { font-family: var(--font-display); font-weight: 600; font-size: .92rem; color: var(--color-ink); }
  .nav-m-sub-desc { font-size: .8rem; color: var(--color-sand-500); line-height: 1.35; }
  .nav-m-cta {
    display: flex; align-items: center; justify-content: center; gap: .5rem;
    margin-top: .35rem; padding: .9rem 1rem; border-radius: .8rem;
    background: var(--color-ink); color: var(--color-sand-50); font-weight: 600; font-size: .95rem;
    transition: background-color .2s ease, transform .16s var(--ease-curve);
  }
  .nav-m-cta:hover { background: #1b3a6b; }
  .nav-m-cta:active { transform: scale(0.98); }
  .nav-m-cta svg { width: 1.05rem; height: 1.05rem; }

  @media (prefers-reduced-motion: reduce) {
    .nav-drop-panel, .nav-chev, .nav-mobile, .nav-m-sub, .nav-drop-arrow, .nav-burger-ico span { transition-duration: .01ms !important; }
  }
</style>
