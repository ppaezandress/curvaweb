---
// Segmented control interactivo (estilo Framer/Mobbin) para "Cómo trabajamos".
// La píldora se desliza al paso activo y el panel hace cross-fade. Lógica en scripts/tabs.ts.
interface Paso { num: string; title: string; desc: string; dur: string; }
interface Props { proceso: Paso[]; }
const { proceso } = Astro.props;
---
<div data-tabs class="reveal">
  <!-- Tablist (scrolleable en móvil para no romper la píldora) -->
  <div class="overflow-x-auto -mx-6 sm:mx-0 px-6 sm:px-0 pb-1 [scrollbar-width:none] [&::-webkit-scrollbar]:hidden">
    <div class="seg" role="tablist" aria-label="Cómo trabajamos">
      <span class="seg-pill" aria-hidden="true"></span>
      {proceso.map((s, i) => (
        <button
          class="seg-btn"
          role="tab"
          id={`proc-tab-${i}`}
          aria-controls={`proc-panel-${i}`}
          aria-selected={i === 0 ? 'true' : 'false'}
          tabindex={i === 0 ? 0 : -1}
          data-tab={i}
        >
          <span class="tabular-nums opacity-60 mr-1.5">{s.num}</span>{s.title}
        </button>
      ))}
    </div>
  </div>

  <!-- Panels -->
  <div class="seg-panels relative mt-10 sm:mt-14">
    {proceso.map((s, i) => (
      <div
        class={`tab-panel ${i === 0 ? 'is-active' : ''}`}
        role="tabpanel"
        id={`proc-panel-${i}`}
        aria-labelledby={`proc-tab-${i}`}
        data-panel={i}
        tabindex="0"
      >
        <div class="grid lg:grid-cols-[1.15fr_0.85fr] gap-10 lg:gap-16 items-center">
          <div>
            <div class="flex items-center gap-4 mb-6">
              <span class="display text-5xl sm:text-6xl font-semibold curve-text tabular-nums leading-none">{s.num}</span>
              <span class="inline-flex items-center gap-1.5 text-[11px] font-semibold text-sand-600 bg-white border border-sand-200 rounded-full px-2.5 py-1">
                <svg class="w-3 h-3 text-ember" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                {s.dur}
              </span>
            </div>
            <h3 class="display text-2xl sm:text-3xl lg:text-4xl font-semibold tracking-tight leading-[1.1] mb-4 text-ink">{s.title}</h3>
            <p class="text-lg text-sand-600 leading-relaxed max-w-xl">{s.desc}</p>
          </div>

          <!-- Mini-escena: progreso del paso sobre la curva -->
          <div class="relative rounded-3xl border border-sand-200 bg-white shadow-sm p-7 sm:p-9 overflow-hidden">
            <span class="absolute -right-12 -top-12 w-40 h-40 rounded-full bg-ember/10 blur-2xl"></span>
            <p class="eyebrow text-ember mb-5 relative">Paso {s.num} de {String(proceso.length).padStart(2, '0')}</p>
            <svg viewBox="0 0 320 120" fill="none" class="w-full relative" aria-hidden="true">
              <defs>
                <linearGradient id={`pt-${i}`} x1="0" y1="0" x2="1" y2="0">
                  <stop stop-color="#2563eb"></stop><stop offset="0.5" stop-color="#3b82f6"></stop><stop offset="1" stop-color="#2563eb"></stop>
                </linearGradient>
              </defs>
              <path d="M8,108 C70,108 96,40 160,40 C224,40 250,12 312,12" stroke="rgba(15,30,61,0.10)" stroke-width="2.5" stroke-linecap="round" stroke-dasharray="2 9"></path>
              <path d="M8,108 C70,108 96,40 160,40 C224,40 250,12 312,12" stroke={`url(#pt-${i})`} stroke-width="3" stroke-linecap="round" pathLength="1" style={`stroke-dasharray:1;stroke-dashoffset:${(1 - (i + 1) / proceso.length).toFixed(3)};transition:stroke-dashoffset .6s var(--ease-draw)`}></path>
              {proceso.map((_, k) => {
                const t = (k + 1) / proceso.length;
                const x = 8 + t * 304;
                const y = 108 - t * 96;
                return <circle cx={x} cy={y} r={k === i ? 6 : 3.5} fill={k <= i ? '#2563eb' : '#ffffff'} stroke={k <= i ? '#ffffff' : 'rgba(15,30,61,0.22)'} stroke-width="2.5"></circle>;
              })}
            </svg>
          </div>
        </div>
      </div>
    ))}
  </div>
</div>
