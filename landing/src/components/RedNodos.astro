---
// "Al final, se trata de personas": diagrama de nodos que conecta a quién
// tocamos (fundadores · equipo · clientes) con lo que cambia en su vida
// (sentirse · trabajar · vivir mejor). CURVA es el nodo central que transforma.
// Desktop: grafo SVG con conectores que "fluyen". Móvil: versión apilada.
// Idea de Emiliano. Motion con significado, respeta prefers-reduced-motion.
// Íconos (24×24, trazo). set:html los inyecta dentro de cada nodo.
const icons: Record<string, string> = {
  founder: '<circle cx="12" cy="8" r="4"/><path d="M4 21a8 8 0 0 1 16 0"/>',
  team: '<circle cx="9" cy="9" r="3"/><circle cx="16.4" cy="9.6" r="2.5"/><path d="M3 20c0-3 2.7-5.2 6-5.2s6 2.2 6 5.2"/><path d="M15.4 20c0-2.4 1.3-4.4 3.6-5"/>',
  client: '<path d="M6.4 8h11.2l-1 11.5h-9.2L6.4 8Z"/><path d="M9 8V6.2a3 3 0 0 1 6 0V8"/>',
  calm: '<circle cx="12" cy="12" r="9"/><path d="M8 14.5a5 5 0 0 0 8 0"/><path d="M9 9.6h.01M15 9.6h.01"/>',
  spark: '<path d="M13 2 4 14h7l-2 8 9-12h-7l2-8Z"/>',
  star: '<path d="M12 3l1.9 4.4L18 9l-4.1 1.6L12 15l-1.9-4.4L6 9l4.1-1.6L12 3Z"/>',
};

const personas = [
  { label: 'Fundadores', icon: 'founder', y: 104 },
  { label: 'Equipo', icon: 'team', y: 220 },
  { label: 'Clientes', icon: 'client', y: 336 },
];
const resultados = [
  { title: 'Sentirse mejor', sub: 'Menos estrés', icon: 'calm', y: 104 },
  { title: 'Trabajar mejor', sub: 'Mayor motivación', icon: 'spark', y: 220 },
  { title: 'Vivir mejor', sub: 'Mayor calidad de vida', icon: 'star', y: 336 },
];

// Geometría (viewBox 0 0 920 440). Pastillas de 232×78, huecos simétricos al hub.
const hub = { x: 460, y: 220, r: 66 };
const pillW = 232;
const pillH = 78;
const leftX = 45;                 // borde izq. de las pastillas de personas (der. = 277)
const rightX = 643;               // borde izq. de las pastillas de resultados (der. = 875)
const toHub = (y: number) => `M${leftX + pillW},${y} C345,${y} 356,${hub.y} ${hub.x - hub.r},${hub.y}`;
const fromHub = (y: number) => `M${hub.x + hub.r},${hub.y} C564,${hub.y} 575,${y} ${rightX},${y}`;
---
<section id="personas" data-anim-gate class="bg-sand-50 py-24 sm:py-32 px-6 sm:px-10 relative overflow-hidden" aria-labelledby="personas-title">
  <div class="mx-auto max-w-6xl">
    <div class="max-w-2xl mb-14 sm:mb-16">
      <p class="reveal eyebrow-lead text-ember mb-5">Por qué lo hacemos</p>
      <h2 id="personas-title" class="reveal display text-3xl sm:text-4xl lg:text-5xl font-semibold tracking-tight leading-[1.08] text-ink text-balance">
        Al final, se trata de <span class="bg-gradient-to-r from-ember to-jade bg-clip-text text-transparent">personas</span>.
      </h2>
      <p class="reveal mt-5 text-lg text-sand-600 leading-relaxed">
        Cuando la operación fluye, no gana solo el negocio. Gana quien lo dirige, quien lo trabaja y quien lo compra.
      </p>
    </div>

    <!-- ── Grafo (desktop) ── -->
    <div class="reveal hidden md:block" data-red-nodos>
      <svg viewBox="0 0 920 440" class="w-full h-auto" role="img"
        aria-label="Diagrama: fundadores, equipo y clientes pasan por CURVA y ganan bienestar: menos estrés, mayor motivación y mayor calidad de vida.">
        <defs>
          <linearGradient id="rn-flow" x1="0" y1="0" x2="1" y2="0">
            <stop offset="0" stop-color="#1d4ed8"></stop>
            <stop offset="0.5" stop-color="#2563eb"></stop>
            <stop offset="1" stop-color="#38bdf8"></stop>
          </linearGradient>
          <linearGradient id="rn-hub" x1="0" y1="0" x2="1" y2="1">
            <stop offset="0" stop-color="#1d4ed8"></stop>
            <stop offset="1" stop-color="#38bdf8"></stop>
          </linearGradient>
          <linearGradient id="rn-pill-grad" x1="0" y1="0" x2="1" y2="1">
            <stop offset="0" stop-color="#2f6bf0"></stop>
            <stop offset="1" stop-color="#38bdf8"></stop>
          </linearGradient>
          <linearGradient id="rn-pill-hi" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0" stop-color="#ffffff" stop-opacity="0.32"></stop>
            <stop offset="0.55" stop-color="#ffffff" stop-opacity="0"></stop>
          </linearGradient>
          <filter id="rn-glow" x="-40%" y="-40%" width="180%" height="180%">
            <feGaussianBlur stdDeviation="6" result="b"></feGaussianBlur>
            <feMerge><feMergeNode in="b"></feMergeNode><feMergeNode in="SourceGraphic"></feMergeNode></feMerge>
          </filter>
          <filter id="rn-shadow" x="-30%" y="-30%" width="160%" height="200%">
            <feDropShadow dx="0" dy="8" stdDeviation="12" flood-color="#1e40af" flood-opacity="0.28"></feDropShadow>
          </filter>
          <filter id="rn-shadow-soft" x="-30%" y="-30%" width="160%" height="200%">
            <feDropShadow dx="0" dy="6" stdDeviation="11" flood-color="#1e293b" flood-opacity="0.10"></feDropShadow>
          </filter>
          <radialGradient id="rn-hub-glow" cx="50%" cy="50%" r="50%">
            <stop offset="0" stop-color="#38bdf8" stop-opacity="0.5"></stop>
            <stop offset="60%" stop-color="#2563eb" stop-opacity="0.15"></stop>
            <stop offset="100%" stop-color="#2563eb" stop-opacity="0"></stop>
          </radialGradient>
        </defs>

        <!-- Halo del hub (respira detrás de CURVA) -->
        <circle class="rn-hub-halo" cx={hub.x} cy={hub.y} r="120" fill="url(#rn-hub-glow)"></circle>

        <!-- Conectores base -->
        <g fill="none" stroke="url(#rn-flow)" stroke-width="2" stroke-linecap="round">
          {personas.map((p) => (
            <path d={toHub(p.y)} class="rn-link" opacity="0.38"></path>
          ))}
          {resultados.map((r) => (
            <path d={fromHub(r.y)} class="rn-link rn-link--out" opacity="0.38"></path>
          ))}
        </g>

        <!-- Pulsos de energía: personas → CURVA → resultados -->
        {personas.map((p, i) => (
          <circle class="rn-pulse" r="4.5" fill="#38bdf8" style={`offset-path:path('${toHub(p.y)}');--i:${i}`}></circle>
        ))}
        {resultados.map((r, i) => (
          <circle class="rn-pulse rn-pulse--out" r="4.5" fill="#2563eb" style={`offset-path:path('${fromHub(r.y)}');--i:${i}`}></circle>
        ))}

        <!-- Nodos: personas (izquierda) -->
        {personas.map((p, i) => (
          <g class="rn-node" aria-label={p.label} style={`--i:${i}`}>
            <rect x={leftX} y={p.y - pillH / 2} width={pillW} height={pillH} rx={pillH / 2}
              fill="#ffffff" stroke="#dbe4f5" stroke-width="1.5" filter="url(#rn-shadow-soft)"></rect>
            <circle cx={leftX + 40} cy={p.y} r="19" fill="#eaf1fd"></circle>
            <g transform={`translate(${leftX + 40 - 11},${p.y - 11}) scale(0.92)`} fill="none" stroke="#2563eb" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={icons[p.icon]} />
            <text x={leftX + 74} y={p.y} dominant-baseline="central" class="rn-title" fill="#12213f">{p.label}</text>
          </g>
        ))}

        <!-- Anillos que irradian del hub -->
        <circle class="rn-hub-ring" cx={hub.x} cy={hub.y} r={hub.r} fill="none" stroke="#38bdf8" stroke-width="2"></circle>
        <circle class="rn-hub-ring rn-hub-ring--2" cx={hub.x} cy={hub.y} r={hub.r} fill="none" stroke="#38bdf8" stroke-width="2"></circle>

        <!-- Hub central: logo de CURVA -->
        <g class="rn-hub">
          <circle cx={hub.x} cy={hub.y} r={hub.r} fill="url(#rn-hub)" filter="url(#rn-glow)"></circle>
          <circle cx={hub.x} cy={hub.y} r={hub.r} fill="none" stroke="#ffffff" stroke-opacity="0.35" stroke-width="1.5"></circle>
          <svg x={hub.x - 30} y={hub.y - 34} width="60" height="60" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M2 18C6 18 7 6 12 6C17 6 18 18 22 18" stroke="#ffffff" stroke-width="2.5" stroke-linecap="round"></path>
          </svg>
          <text x={hub.x} y={hub.y + 20} text-anchor="middle" dominant-baseline="central"
            class="rn-hub-text" fill="#ffffff">curva</text>
        </g>

        <!-- Satélite en órbita alrededor del hub -->
        <g class="rn-orbit">
          <circle cx={hub.x} cy={hub.y - 84} r="4.5" fill="#2563eb" filter="url(#rn-glow)"></circle>
        </g>

        <!-- Nodos: resultados (derecha) -->
        {resultados.map((r, i) => (
          <g class="rn-node rn-node--out" aria-label={`${r.title}: ${r.sub}`} style={`--i:${i}`}>
            <rect x={rightX} y={r.y - pillH / 2} width={pillW} height={pillH} rx={pillH / 2}
              fill="url(#rn-pill-grad)" filter="url(#rn-shadow)"></rect>
            <rect x={rightX} y={r.y - pillH / 2} width={pillW} height={pillH} rx={pillH / 2}
              fill="url(#rn-pill-hi)" stroke="#ffffff" stroke-opacity="0.2" stroke-width="1"></rect>
            <circle cx={rightX + 40} cy={r.y} r="19" fill="#ffffff" fill-opacity="0.22"></circle>
            <g transform={`translate(${rightX + 40 - 11},${r.y - 11}) scale(0.92)`} fill="none" stroke="#ffffff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={icons[r.icon]} />
            <text x={rightX + 74} y={r.y - 10} dominant-baseline="central" class="rn-title" fill="#ffffff">{r.title}</text>
            <text x={rightX + 74} y={r.y + 13} dominant-baseline="central" class="rn-sub" fill="#ffffff" fill-opacity="0.88">{r.sub}</text>
          </g>
        ))}
      </svg>
    </div>

    <!-- ── Versión apilada (móvil) ── -->
    <div class="reveal md:hidden" data-red-nodos-mobile>
      <div class="grid grid-cols-3 gap-2 text-center">
        {personas.map((p) => (
          <div class="rounded-2xl border border-sand-200 bg-white px-2 py-3 text-[13px] font-semibold text-ink">{p.label}</div>
        ))}
      </div>
      <div class="flex justify-center py-2" aria-hidden="true">
        <svg width="24" height="34" viewBox="0 0 24 34" fill="none"><path d="M12 2v22m0 0l-6-6m6 6l6-6" stroke="url(#rn-flow-m)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"></path><defs><linearGradient id="rn-flow-m" x1="0" y1="0" x2="0" y2="1"><stop stop-color="#1d4ed8"></stop><stop offset="1" stop-color="#38bdf8"></stop></linearGradient></defs></svg>
      </div>
      <div class="mx-auto w-full rounded-2xl bg-[linear-gradient(120deg,#1d4ed8,#38bdf8)] px-5 py-3 flex items-center justify-center gap-2 text-white font-semibold display tracking-tight">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M2 18C6 18 7 6 12 6C17 6 18 18 22 18" stroke="#ffffff" stroke-width="2.5" stroke-linecap="round"></path></svg>
        curva
      </div>
      <div class="flex justify-center py-2" aria-hidden="true">
        <svg width="24" height="34" viewBox="0 0 24 34" fill="none"><path d="M12 2v22m0 0l-6-6m6 6l6-6" stroke="url(#rn-flow-m)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"></path></svg>
      </div>
      <div class="grid grid-cols-3 gap-2 text-center">
        {resultados.map((r) => (
          <div class="rounded-2xl bg-[linear-gradient(120deg,#1d4ed8,#38bdf8)] px-2 py-3 text-white">
            <p class="text-[13px] font-semibold leading-tight">{r.title}</p>
            <p class="mt-0.5 text-[11px] text-white/80 leading-tight">{r.sub}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  /* Conectores: guiones tenues estáticos (la energía la dan los pulsos) */
  .rn-link { stroke-dasharray: 4 8; }

  /* Pulsos de energía que viajan por cada conector (offset-path en el markup) */
  .rn-pulse {
    offset-rotate: 0deg; offset-distance: 0%; opacity: 0;
    filter: drop-shadow(0 0 5px #38bdf8);
    animation: rn-travel 2.8s cubic-bezier(0.5, 0, 0.3, 1) infinite;
    animation-delay: calc(var(--i) * 0.55s);
    will-change: offset-distance, opacity;
  }
  /* Los de salida arrancan después: energía entra → CURVA → sale transformada */
  .rn-pulse--out {
    filter: drop-shadow(0 0 5px #2563eb);
    animation-delay: calc(1.1s + var(--i) * 0.55s);
  }
  @keyframes rn-travel {
    0%   { offset-distance: 0%;   opacity: 0; }
    14%  { opacity: 1; }
    82%  { offset-distance: 100%; opacity: 1; }
    100% { offset-distance: 100%; opacity: 0; }
  }

  /* Halo del hub: respira */
  .rn-hub-halo { transform-box: fill-box; transform-origin: center; animation: rn-halo 4.4s ease-in-out infinite; }
  @keyframes rn-halo {
    0%, 100% { opacity: 0.6; transform: scale(0.9); }
    50%      { opacity: 1;   transform: scale(1.08); }
  }
  /* Anillos que irradian del hub */
  .rn-hub-ring { transform-box: fill-box; transform-origin: center; opacity: 0; animation: rn-ring 3.6s ease-out infinite; }
  .rn-hub-ring--2 { animation-delay: 1.8s; }
  @keyframes rn-ring {
    0%   { transform: scale(1);    opacity: 0.55; }
    70%  { opacity: 0; }
    100% { transform: scale(1.95); opacity: 0; }
  }
  /* Satélite en órbita */
  .rn-orbit { transform-box: view-box; transform-origin: 450px 200px; animation: rn-orbit 11s linear infinite; }
  @keyframes rn-orbit { to { transform: rotate(360deg); } }
  /* Núcleo del hub: latido sutil */
  .rn-hub circle:first-child { animation: rn-pulse 3.4s ease-in-out infinite; transform-box: fill-box; transform-origin: center; }
  @keyframes rn-pulse { 0%, 100% { opacity: 1; transform: scale(1); } 50% { opacity: 0.9; transform: scale(1.02); } }

  /* Nodos (pastillas): el grupo entero se eleva (no cada hijo, para no romper el transform del ícono) */
  .rn-node { cursor: default; transition: transform 0.4s var(--ease-pitch, ease); }
  .rn-node:hover, .rn-node:focus-visible { transform: translateY(-3px); outline: none; }
  .rn-node:focus-visible rect:first-of-type { stroke: #2563eb; stroke-width: 2.5; }
  .rn-title { font: 700 17px/1 'Poppins', system-ui, sans-serif; letter-spacing: -0.01em; }
  .rn-sub { font: 500 13px/1 'Inter', system-ui, sans-serif; }
  .rn-hub-text { font: 700 20px/1 'Poppins', system-ui, sans-serif; letter-spacing: 0.02em; }

  @media (prefers-reduced-motion: reduce) {
    .rn-pulse, .rn-hub-halo, .rn-hub-ring, .rn-orbit, .rn-hub circle:first-child { animation: none !important; }
    .rn-hub-halo { opacity: 0.7; }
    .rn-hub-ring { opacity: 0; }
  }
</style>
