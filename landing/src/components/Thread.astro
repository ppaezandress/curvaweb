---
// A1 — El hilo continuo: curva-S fija en el borde izquierdo que se dibuja con el
// progreso global de scroll. Decorativo (pointer-events:none). Oculto en móvil.
// El trazo llena el alto (preserveAspectRatio="none"); el punto es HTML (sin deformar),
// lo posiciona scripts/thread.ts. Solo se monta en la home.
---
<div class="thread hidden sm:block" aria-hidden="true">
  <svg viewBox="0 0 100 1000" preserveAspectRatio="none">
    <defs>
      <linearGradient id="thread-grad" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0" stop-color="#2563eb"></stop>
        <stop offset="0.5" stop-color="#3b82f6"></stop>
        <stop offset="1" stop-color="#2563eb"></stop>
      </linearGradient>
    </defs>
    <!-- Riel tenue -->
    <path d="M 56 -12 C 56 170, 14 300, 26 500 C 38 700, 86 800, 68 1012"
          fill="none" stroke="rgba(37, 99, 235,0.14)" stroke-width="2" />
    <!-- Trazo firma (lo dibuja el scroll) -->
    <path class="thread-line" d="M 56 -12 C 56 170, 14 300, 26 500 C 38 700, 86 800, 68 1012"
          fill="none" stroke="url(#thread-grad)" stroke-width="2.5" stroke-linecap="round" pathLength="1" />
  </svg>
  <span class="thread-dot"></span>
</div>
