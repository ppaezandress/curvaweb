---
import '@fontsource/poppins/500.css';
import '@fontsource/poppins/600.css';
import '@fontsource/poppins/700.css';
import '@fontsource/poppins/800.css';
import '@fontsource-variable/inter';
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Seo from '../components/Seo.astro';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';

interface Props {
  title: string;
  description: string;
  image?: string;
  type?: 'website' | 'article';
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  bodyClass?: string;
}

const {
  title,
  description,
  image,
  type,
  jsonLd,
  bodyClass = '',
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#1a1410" />
    <Seo title={title} description={description} image={image} type={type} jsonLd={jsonLd} />
    <ClientRouter />
  </head>

  <body class={`bg-sand-50 text-ink antialiased overflow-x-hidden ${bodyClass}`}>
    <!-- Glow ambiental del cursor (persistente entre navegaciones) -->
    <div id="cursor-glow" class="cursor-glow" aria-hidden="true" transition:persist></div>

    <slot />

    <Analytics />
    <SpeedInsights />

    <script>
      import { initReveal } from '../scripts/reveal';
      import { initCursorGlow } from '../scripts/cursor-glow';
      import { initLenis, resetLenis } from '../scripts/lenis';
      import { initCurveDraw } from '../scripts/curve-draw';
      import { initCurveScene } from '../scripts/curve-scene';
      import { initTilt } from '../scripts/tilt';
      import { initNav } from '../scripts/nav';
      import { initVideos, initAudioToggle } from '../scripts/media';
      import { initHome } from '../scripts/home';
      import { initTracking } from '../scripts/track';
      import { initLeadMagnet } from '../scripts/leadmagnet';
      import { initCount } from '../scripts/count';
      import { initWordFade } from '../scripts/wordfade';
      import { initParallax } from '../scripts/parallax';
      import { initTabs } from '../scripts/tabs';
      import { initMagnetic } from '../scripts/magnetic';

      // Persistentes: se inicializan una vez (guard idempotente dentro de cada init).
      initLenis();
      initCursorGlow();
      initTracking();

      // Efímeros: re-armar en cada carga y tras cada navegación con View Transitions.
      document.addEventListener('astro:page-load', () => {
        initReveal();
        initCursorGlow();
        initCurveDraw();
        initCurveScene();
        initTilt();
        initNav();
        initVideos();
        initAudioToggle();
        initHome();
        initLeadMagnet();
        initCount();
        initWordFade();
        initParallax();
        initTabs();
        initMagnetic();
        // Dispara el page-load orquestado (data-load) en el primer pintado.
        requestAnimationFrame(() =>
          requestAnimationFrame(() => document.body.classList.add('is-loaded'))
        );
      });

      // Sincronizar Lenis tras el swap del router.
      document.addEventListener('astro:after-swap', () => {
        resetLenis();
      });
    </script>
  </body>
</html>
