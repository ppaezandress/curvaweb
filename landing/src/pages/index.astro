---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Curve from '../components/Curve.astro';
import HeroAsk from '../components/HeroAsk.astro';
import ImpactoCarrusel from '../components/ImpactoCarrusel.astro';
import Caminos from '../components/Caminos.astro';
import RedNodos from '../components/RedNodos.astro';
import Intro from '../components/Intro.astro';

const calLink = 'https://cal.com/andres-paez/30min';
const waLink = 'https://wa.me/5215611846200?text=Hola%2C%20me%20interesa%20saber%20m%C3%A1s%20sobre%20CURVA';

const accentText = { ember: 'text-ember', gold: 'text-gold', jade: 'text-jade' } as const;
const accentBar = { ember: 'bg-ember', gold: 'bg-gold', jade: 'bg-jade' } as const;
const accentBorder = { ember: 'border-ember', gold: 'border-gold', jade: 'border-jade' } as const;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: 'CURVA',
  description: 'Consultoría de transformación digital y de negocio para empresas en crecimiento.',
  areaServed: 'México',
  address: { '@type': 'PostalAddress', addressLocality: 'Ciudad de México', addressCountry: 'MX' },
  serviceType: ['Consultoría empresarial', 'Digitalización', 'Automatización con IA'],
  founder: { '@type': 'Person', name: 'Andrés Páez Cortazar' },
};

// Interruptor pains→gains (sección "¿Te suena algo de esto?"): el mismo punto,
// "antes" (dolor) → "después" (con CURVA). Gains de la auditoría de Emiliano.
const pares = [
  { pain: 'El negocio depende de pocas personas para no detenerse.', gain: 'El negocio no depende de ti: puede funcionar solo.' },
  { pain: 'Los procesos viven en la cabeza, no en un sistema.',       gain: 'El conocimiento se centraliza en un solo lugar, para todo el equipo.' },
  { pain: 'Cada venta nueva trae más trabajo y desorden, no más claridad.', gain: 'Sostienes más ventas sin perder el orden, con una dirección clara.' },
  { pain: 'Hay con qué crecer, pero falta la estructura para lograrlo.', gain: 'Tienes los cimientos y la estructura para crecer.' },
];

// Hitos sobre la curva (coords % sobre la Bézier del viewBox 1280x420).
// `at` = fracción del recorrido en que se "enciende" (sincroniza con el trazo); `href` = su servicio.
const hitosCurva = [
  { n: '01', label: 'Exploración',    cap: 'Entendemos tu operación a fondo.',      left: 27.3, top: 79.8, at: 0.24, href: '/consultoria/transformacion-de-negocio' },
  { n: '02', label: 'Diagnóstico',    cap: 'Vemos qué se traba y por qué.',          left: 51.6, top: 59.5, at: 0.50, href: '/consultoria/transformacion-de-negocio#procesos' },
  { n: '03', label: 'Implementación', cap: 'Lo armamos y se queda funcionando solo.', left: 75.7, top: 31.9, at: 0.74, href: '/consultoria/transformacion-digital' },
];

// Mismo viaje como timeline vertical para móvil (la gráfica horizontal se aplana en pantallas chicas).
const paradas = [
  { eyebrow: 'Hoy', label: 'Operación por sensación', accent: 'ember' as const },
  { eyebrow: '01', label: 'Exploración', accent: 'ember' as const },
  { eyebrow: '02', label: 'Diagnóstico', accent: 'ember' as const },
  { eyebrow: '03', label: 'Implementación', accent: 'gold' as const },
  { eyebrow: 'Con CURVA', label: 'Operación por sistema', accent: 'gold' as const },
  { eyebrow: 'La cima', label: 'Cambio de vida', accent: 'gold' as const },
];

// Cinta animada representativa de lo que hace CURVA (sin logos — feedback de Pau).
const capacidades = ['Diagnóstico operativo', 'Procesos y estructura', 'Automatización', 'Agentes con IA', 'ERPs implementados', 'Gobernanza', 'Capacitación', 'Acompañamiento'];

// Path firma de la sección "La curva" (coincide con offset-path de .curve-dot en global.css).
const curvePath = 'M40,360 C320,360 380,330 660,250 C940,170 1010,80 1240,70';

// Producto propio = prueba ("no entregamos PDFs, construimos software"). Curva Tiempos.
const producto = {
  // PLACEHOLDER: pásame la URL pública de Curva Tiempos y una captura real para /public.
  link: '#',                 // TODO: URL real de Curva Tiempos
  shot: '',                  // TODO: ruta a captura en /public (ej. '/tiempos-shot.png'); vacío = mockup placeholder
};
---

<BaseLayout
  title="CURVA. Transformación digital y de negocio"
  description="Tu empresa, por sistema. Menos esfuerzo, más estructura. Ordenamos y digitalizamos la operación de empresas en crecimiento para que el dueño recupere el control y el negocio jale sin él encima."
  jsonLd={jsonLd}
  thread
>
  <div class="flow-bg" aria-hidden="true"></div>
  <Intro />
  <Nav calLink={calLink} />

  <a href="#contenido" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:bg-ember focus:text-white focus:px-4 focus:py-2 focus:rounded-full focus:text-sm focus:font-semibold">Saltar al contenido</a>

  <main id="contenido" tabindex="-1">

  <!-- ============================== HERO — claro, estilo Pitch, con chat IA ============================== -->
  <section class="hero-lite hero-blue relative min-h-[100svh] flex flex-col justify-center overflow-hidden">
    <!-- Lienzo generativo: líneas BLANCAS elegantes ALREDEDOR del texto (centro limpio), se esculpen con el cursor -->
    <canvas id="hero-canvas" class="pointer-events-none absolute inset-0 w-full h-full z-[1]" aria-hidden="true"></canvas>
    <div class="hero-veil absolute inset-0 z-[2] pointer-events-none"></div>

    <div class="mx-auto max-w-5xl w-full px-6 sm:px-10 relative z-10 text-center translate-y-[4vh] sm:translate-y-[5vh]">
      <p data-load="1" class="eyebrow-lead text-jade-300 mb-8">Transformación digital y de negocio</p>
      <h1 class="hero-phrase display tracking-[-0.03em] leading-[0.82] text-white">
        <span class="hero-line hero-word-strong">Construye</span>
        <span class="hero-line hero-line-2 hero-word-strong"><span class="hero-tu">tu</span> <span class="hero-empresa">empresa<svg class="hero-underline" viewBox="0 0 300 24" preserveAspectRatio="none" aria-hidden="true"><defs><linearGradient id="hu" x1="0" y1="0" x2="1" y2="0"><stop offset="0" stop-color="#7dd3fc"></stop><stop offset="0.55" stop-color="#38bdf8"></stop><stop offset="1" stop-color="#60a5fa"></stop></linearGradient></defs><path pathLength="1" d="M3 15 C 55 5, 105 22, 155 13 S 250 4, 297 13" fill="none" stroke="url(#hu)" stroke-width="6" stroke-linecap="round"></path></svg></span></span>
      </h1>
      <!-- Composer IA inline: escribe o dicta y la IA responde aquí mismo -->
      <HeroAsk calLink={calLink} />

      <p data-load="5" class="mt-5 text-sm text-sand-200">o <a href={calLink} target="_blank" rel="noopener" class="text-jade-300 font-semibold link-underline">agenda una llamada</a></p>
    </div>

    <div data-hero-scrollhint class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center" data-load="5">
      <a href="#problema" aria-label="Bajar al contenido" class="animate-bounce"><svg class="w-5 h-5 text-white/60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5L12 21m0 0l-7.5-7.5M12 21V3"></path></svg></a>
    </div>
  </section>

  <!-- ============================== CINTA (qué hace CURVA — 2 filas opuestas, bordes difuminados) ============================== -->
  <div class="cinta py-7 select-none border-y border-sand-200 space-y-3" aria-hidden="true">
    {[capacidades, [...capacidades].reverse()].map((row, r) => (
      <div class="overflow-hidden whitespace-nowrap">
        <div class={`marquee-track inline-flex items-center ${r === 1 ? 'marquee-rev' : ''}`}>
          {Array.from({ length: 2 }).map(() => (
            <span class="inline-flex items-center">
              {row.map((c) => (
                <span class="inline-flex items-center text-sand-600">
                  <span class="display text-lg sm:text-xl font-medium">{c}</span>
                  <span class="mx-7 text-ember/50">·</span>
                </span>
              ))}
            </span>
          ))}
        </div>
      </div>
    ))}
  </div>

  <!-- ============================== EL PROBLEMA ============================== -->
  <section id="problema" class="py-24 sm:py-36 px-6 sm:px-10 relative overflow-hidden">
    <div class="glow-orb" style="width:30rem;height:30rem;top:-6rem;right:-8rem;background:radial-gradient(circle,rgba(37, 99, 235,0.12),transparent 70%);mix-blend-mode:normal;opacity:0.8;"></div>
    <div class="glow-orb" style="width:26rem;height:26rem;bottom:-8rem;left:-6rem;background:radial-gradient(circle,rgba(37,99,235,0.10),transparent 70%);mix-blend-mode:normal;opacity:0.8;animation-delay:-8s;"></div>
    <div class="mx-auto max-w-7xl grid lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] gap-12 lg:gap-24 relative z-10">
      <div class="lg:sticky lg:top-28 self-start">
        <p class="reveal eyebrow-lead text-ember mb-5">Para quién es esto</p>
        <h2 class="reveal display text-3xl sm:text-4xl lg:text-5xl font-semibold leading-[1.08] tracking-tight text-ink text-balance">¿Te suena algo de esto?</h2>
        <p class="reveal mt-6 text-lg text-sand-600 leading-relaxed max-w-md">Si te late seguido, el problema no es falta de esfuerzo. Es falta de sistema.</p>
      </div>
      <!-- Interruptor pains→gains: papeles sueltos (dolor) → sistema ordenado (con CURVA).
           Se alterna solo (pgauto.ts) y se pausa al pasar el cursor. -->
      <div class="pg reveal self-center w-full" data-pg>
        <input type="checkbox" id="pg-toggle" class="sr-only" aria-label="Alternar entre el problema de hoy y lo que hace CURVA" />

        <div class="pg-head">
          <label for="pg-toggle" class="pg-switch">
            <span class="pg-off">Así se siente hoy</span>
            <span class="pg-track">
              <span class="pg-knob"></span>
            </span>
            <span class="pg-on">Esto es lo que hace CURVA</span>
          </label>
          <div class="pg-progress" aria-hidden="true"><span class="pg-progress-bar"></span></div>
          <span class="pg-hint" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" width="13" height="13"><path d="M3 12a9 9 0 1015.5-6.2M18.5 3v3h-3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg>
            se alterna solo · pásale el cursor para pausar
          </span>
        </div>

        <ul class="pg-list" role="list">
          {pares.map((p, i) => (
            <li class="pg-item" style={`--i:${i}`}>
              <span class="pg-rail">
                <span class="pg-dot">
                  <svg class="pg-check" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 13l4 4L19 7" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"></path></svg>
                </span>
              </span>
              <div class="pg-card">
                <span class="pg-num">0{i + 1}</span>
                <div class="pg-texts">
                  <p class="pg-pain">{p.pain}</p>
                  <p class="pg-gain">{p.gain}</p>
                </div>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- ============================== LA CURVA (transformación) ============================== -->
  <section id="la-curva" data-anim-gate class="zone-solid py-28 sm:py-36 px-6 sm:px-10 relative overflow-hidden scroll-mt-24">
    <div class="glow-orb" style="width:28rem;height:28rem;top:18%;left:50%;transform:translateX(-50%);background:radial-gradient(circle,rgba(37,99,235,0.10),transparent 70%);"></div>
    <div class="mx-auto max-w-6xl relative z-10">
      <div class="max-w-2xl mb-4">
        <p class="reveal eyebrow-lead text-jade-300 mb-5">La curva</p>
        <h2 class="reveal display text-3xl sm:text-4xl lg:text-5xl font-semibold tracking-tight leading-[1.08] text-balance text-white">Hoy estás <span class="whitespace-nowrap"><span class="word-before text-jade-300">aquí</span>.</span> Te llevamos <span class="whitespace-nowrap"><span class="word-after text-jade-300">acá</span>.</span></h2>
        <p data-wordfade class="mt-5 text-lg sm:text-xl text-sand-100 leading-relaxed">Cada etapa te quita un peso de encima. Hasta que dejas de ser el cuello de botella de tu propia empresa.</p>
      </div>

      <!-- Escena horizontal (desktop): la curva se dibuja al hacer scroll -->
      <div class="reveal reveal-scale relative w-full mt-8 pt-12 pb-16 hidden sm:block">
        <!-- Con CURVA: arriba-derecha, junto al final ALTO de la curva (el éxito) -->
        <div class="absolute top-0 right-0 max-w-[52%] text-right">
          <p class="eyebrow text-jade-300 mb-1.5 text-sm">La cima · Con CURVA</p>
          <p class="display text-2xl lg:text-3xl font-semibold text-white leading-[1.05]">Operación por <span class="word-after">sistema</span></p>
          <p class="mt-2 text-sm text-sand-100/90">Y con eso, un <span class="font-semibold text-jade-300">cambio de vida</span>.</p>
        </div>
        <svg viewBox="0 0 1280 420" fill="none" class="w-full h-auto block overflow-visible parallax" data-parallax="10" aria-hidden="true">
          <defs>
            <linearGradient id="curve-stage-grad" x1="0" y1="0" x2="1" y2="0">
              <stop offset="0" stop-color="#60a5fa"></stop>
              <stop offset="0.45" stop-color="#bae6fd"></stop>
              <stop offset="1" stop-color="#ffffff"></stop>
            </linearGradient>
            <linearGradient id="curve-comet-grad" x1="0" y1="0" x2="1" y2="0">
              <stop offset="0" stop-color="#7dd3fc" stop-opacity="0"></stop>
              <stop offset="1" stop-color="#ffffff"></stop>
            </linearGradient>
            <radialGradient id="summit-aura" cx="50%" cy="50%" r="50%">
              <stop offset="0" stop-color="#bae6fd" stop-opacity="0.55"></stop>
              <stop offset="55%" stop-color="#60a5fa" stop-opacity="0.18"></stop>
              <stop offset="100%" stop-color="#2563eb" stop-opacity="0"></stop>
            </radialGradient>
            <linearGradient id="curve-area" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0" stop-color="#ffffff" stop-opacity="0.20"></stop>
              <stop offset="1" stop-color="#ffffff" stop-opacity="0"></stop>
            </linearGradient>
            <pattern id="grid" width="48" height="48" patternUnits="userSpaceOnUse">
              <path d="M48 0 H0 V48" fill="none" stroke="rgba(255,255,255,0.12)" stroke-width="1"></path>
            </pattern>
            <radialGradient id="grid-fade" cx="42%" cy="40%" r="70%">
              <stop offset="0" stop-color="#fff"></stop>
              <stop offset="100%" stop-color="#000"></stop>
            </radialGradient>
            <mask id="grid-mask"><rect width="1280" height="420" fill="url(#grid-fade)"></rect></mask>
            <filter id="curve-glow" x="-20%" y="-60%" width="140%" height="220%">
              <feGaussianBlur stdDeviation="7" result="b"></feGaussianBlur>
              <feMerge><feMergeNode in="b"></feMergeNode><feMergeNode in="SourceGraphic"></feMergeNode></feMerge>
            </filter>
          </defs>

          <!-- Aura de la cima (respira detrás del nodo final) -->
          <ellipse class="summit-aura" cx="1240" cy="70" rx="220" ry="170" fill="url(#summit-aura)"></ellipse>
          <!-- Plano técnico de fondo -->
          <rect width="1280" height="420" fill="url(#grid)" mask="url(#grid-mask)"></rect>
          <!-- Eje base -->
          <line x1="40" y1="392" x2="1240" y2="392" stroke="rgba(255,255,255,0.18)" stroke-width="1"></line>

          <!-- Partículas / puntos de dato -->
          <circle cx="180" cy="300" r="2.5" fill="#93c5fd" class="twinkle"></circle>
          <circle cx="520" cy="190" r="2" fill="#60a5fa" class="twinkle" style="animation-delay:-1.2s"></circle>
          <circle cx="760" cy="320" r="2" fill="#60a5fa" class="twinkle" style="animation-delay:-2.1s"></circle>
          <circle cx="1080" cy="150" r="2.5" fill="#60a5fa" class="twinkle" style="animation-delay:-0.6s"></circle>
          <circle cx="340" cy="120" r="1.8" fill="#93c5fd" class="twinkle" style="animation-delay:-3s"></circle>
          <circle cx="980" cy="300" r="1.8" fill="#60a5fa" class="twinkle" style="animation-delay:-1.8s"></circle>

          <!-- Área de crecimiento bajo la curva -->
          <path d={`${curvePath} L1240,392 L40,392 Z`} fill="url(#curve-area)"></path>
          <!-- Riel tenue -->
          <path d={curvePath} stroke="rgba(255,255,255,0.20)" stroke-width="2" stroke-linecap="round" stroke-dasharray="2 10"></path>
          <!-- Trazo firma: se dibuja con el scroll (curve-draw.ts) -->
          <path d={curvePath} stroke="url(#curve-stage-grad)" stroke-width="3.5" stroke-linecap="round" filter="url(#curve-glow)" pathLength="1" data-curve-draw="scroll" data-hito-path style="stroke-dasharray:1;stroke-dashoffset:1;"></path>
          <!-- Estela de energía que recorre la curva en bucle (ambient) -->
          <path class="curve-streak" d={curvePath} stroke="url(#curve-comet-grad)" stroke-width="4" stroke-linecap="round" fill="none" filter="url(#curve-glow)" pathLength="100"></path>

          <!-- Hitos sobre la curva (coords exactas las coloca hitos.ts con getPointAtLength) -->
          <circle data-hito cx="350" cy="335" r="5" fill="#ffffff" stroke="#ffffff" stroke-width="2.5"></circle>
          <circle data-hito cx="660" cy="250" r="5" fill="#ffffff" stroke="#ffffff" stroke-width="2.5"></circle>
          <circle data-hito cx="969" cy="134" r="5" fill="#ffffff" stroke="#ffffff" stroke-width="2.5"></circle>

          <!-- Nodo inicio (hoy) -->
          <circle cx="40" cy="360" r="9" fill="#ffffff" stroke="rgba(255,255,255,0.35)" stroke-width="7"></circle>

          <!-- Cima (con CURVA): anillos que irradian + nodo que brilla -->
          <circle class="summit-ring" cx="1240" cy="70" r="12" fill="none" stroke="#bae6fd" stroke-width="2"></circle>
          <circle class="summit-ring summit-ring--2" cx="1240" cy="70" r="12" fill="none" stroke="#bae6fd" stroke-width="2"></circle>
          <circle class="summit-node" cx="1240" cy="70" r="11" fill="#ffffff" stroke="#7dd3fc" stroke-width="3"></circle>

          <!-- Cometa viajero: sube la curva en bucle (offset-path = curvePath) -->
          <circle class="curve-comet curve-comet--t3" r="3" fill="#7dd3fc" style={`offset-path: path('${curvePath}');`}></circle>
          <circle class="curve-comet curve-comet--t2" r="4" fill="#bae6fd" style={`offset-path: path('${curvePath}');`}></circle>
          <circle class="curve-comet curve-comet--t1" r="5" fill="#e0f2fe" style={`offset-path: path('${curvePath}');`}></circle>
          <circle class="curve-comet curve-comet--head" r="6" fill="#ffffff" filter="url(#curve-glow)" style={`offset-path: path('${curvePath}');`}></circle>
        </svg>

        <!-- Hitos: chip flotante clickeable que se "enciende" al pasar el trazo (solo desktop) -->
        {hitosCurva.map((m) => (
          <div class="milestone hidden sm:block" data-at={m.at} style={`left:${m.left}%;top:${m.top}%`}>
            <a href={m.href} class="lm-chip group absolute left-1/2 -translate-x-1/2 bottom-full mb-4 flex items-center gap-1.5 whitespace-nowrap rounded-full bg-white border border-sand-200 px-3 py-1.5 text-[11px] font-semibold text-sand-700 shadow-lg transition-all hover:border-ember-300/50 hover:-translate-y-0.5">
              <span class="lm-num text-ember tabular-nums transition-colors">{m.n}</span>{m.label}
              <svg class="lm-arrow w-3 h-3 opacity-0 -ml-1 transition-all group-hover:opacity-100 group-hover:ml-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path></svg>
            </a>
          </div>
        ))}

        <!-- Hoy: abajo-izquierda, junto al inicio BAJO de la curva (punto de partida) -->
        <div class="absolute bottom-0 left-0 max-w-[46%]">
          <p class="eyebrow text-jade-300 mb-1.5 text-sm">Hoy</p>
          <p class="display text-2xl lg:text-3xl font-semibold text-white leading-[1.05]">Operación por <span class="word-before">sensación</span></p>
        </div>
      </div>

      <!-- Escena vertical (móvil): mismo viaje como timeline -->
      <div class="reveal sm:hidden mt-10 relative pl-9">
        <span class="absolute left-[13px] top-3 bottom-3 w-px bg-gradient-to-b from-ember to-gold"></span>
        <ul class="space-y-8">
          {paradas.map((p) => (
            <li class="relative">
              <span class={`absolute -left-9 top-0.5 w-[26px] h-[26px] rounded-full border-2 ${accentBorder[p.accent]} bg-white flex items-center justify-center`}>
                <span class={`w-2 h-2 rounded-full ${accentBar[p.accent]}`}></span>
              </span>
              <p class={`eyebrow ${accentText[p.accent]} mb-1`}>{p.eyebrow}</p>
              <p class="display text-lg font-semibold text-ink leading-tight">{p.label}</p>
            </li>
          ))}
        </ul>
      </div>

      <!-- (Los cuadritos "Dónde estás hoy / A dónde llegas" se quitaron — feedback de
           Emiliano: darle más énfasis a la curva del proceso, menos texto redundante.) -->
    </div>
  </section>

  <!-- ============================== ÁREAS (cómo te ayudamos — mosaico claro) ============================== -->
  <Caminos calLink={calLink} />

  <!-- ============================== IMPACTO REAL (carrusel de casos con cifra) ============================== -->
  <ImpactoCarrusel />

  <!-- ============================== PERSONAS (diagrama de nodos: por qué lo hacemos) ============================== -->
  <RedNodos />

  <!-- ============================== PRODUCTO (ventaja injusta) ============================== -->
  <section class="text-ink py-24 sm:py-32 px-6 sm:px-10 relative overflow-hidden">
    <div class="glow-orb" style="width:30rem;height:30rem;top:-6rem;right:-6rem;background:radial-gradient(circle,rgba(37, 99, 235,0.10),transparent 70%);"></div>
    <div class="mx-auto max-w-7xl relative z-10 grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <div>
        <p class="reveal eyebrow-lead text-ember mb-5">Nuestra ventaja</p>
        <h2 class="reveal display text-3xl sm:text-4xl lg:text-5xl font-semibold tracking-tight leading-[1.08] text-balance text-ink">Lo que hacemos se adapta a tu operación. <span class="curve-text">No al revés.</span></h2>
        <p class="reveal mt-6 text-lg text-sand-600 leading-relaxed">
          No te metemos una herramienta a fuerza ni te copiamos la receta de otro. Entendemos cómo trabaja tu
          gente y armamos lo que de verdad les sirve. Y lo digital no llega solo: viene con capacitación,
          cercanía y acompañamiento hasta que tu equipo lo hace suyo.
        </p>
        <ul class="reveal reveal-d1 mt-8 space-y-3">
          {['Nos adaptamos a tu operación, no tú a nosotros', 'Capacitación y acompañamiento, no solo entregables', 'Cercanía real: estamos contigo durante el cambio'].map((p) => (
            <li class="flex gap-3 text-sand-700">
              <svg class="w-5 h-5 flex-shrink-0 mt-0.5 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"></path></svg>
              <span>{p}</span>
            </li>
          ))}
        </ul>
        {producto.link !== '#' && (
          <a href={producto.link} target="_blank" rel="noopener" class="reveal reveal-d2 arrow-cta mt-8 inline-flex items-center gap-2 text-sm font-semibold text-ember link-underline">
            Conocer Curva Tiempos
            <svg data-arrow class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path></svg>
          </a>
        )}
      </div>

      {/* Captura real (producto.shot) o mockup placeholder de marca */}
      <div class="reveal reveal-scale reveal-d1">
        <div class="stack">
          <span class="stack-layer l1" aria-hidden="true"></span>
          <span class="stack-layer l2" aria-hidden="true"></span>
          <div class="stack-front parallax" data-parallax="14">
        {producto.shot ? (
          <img src={producto.shot} alt="Curva Tiempos" class="rounded-2xl border border-sand-200 shadow-2xl w-full" />
        ) : (
          <div class="rounded-2xl border border-sand-200 bg-white overflow-hidden shadow-2xl">
            <div class="flex items-center gap-1.5 px-4 py-3 border-b border-sand-200">
              <span class="w-2.5 h-2.5 rounded-full bg-sand-300"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-sand-300"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-sand-300"></span>
              <span class="ml-3 text-[11px] text-sand-500">curva-tiempos</span>
            </div>
            <div class="aspect-[16/10] p-6 sm:p-8 flex flex-col justify-between bg-gradient-to-br from-ember/10 via-transparent to-gold/10">
              <div class="flex items-center gap-2">
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none"><path d="M2 18C6 18 7 6 12 6C17 6 18 18 22 18" stroke="url(#pt)" stroke-width="2.5" stroke-linecap="round"></path><defs><linearGradient id="pt" x1="2" y1="0" x2="22" y2="0"><stop stop-color="#93c5fd"></stop><stop offset="0.5" stop-color="#60a5fa"></stop><stop offset="1" stop-color="#60a5fa"></stop></linearGradient></defs></svg>
                <span class="display font-semibold text-ink">Curva Tiempos</span>
              </div>
              <svg viewBox="0 0 320 90" fill="none" class="w-full" aria-hidden="true">
                <path d="M0,80 C70,80 90,40 160,38 C230,36 250,60 320,20" stroke="url(#ptc)" stroke-width="2.5" stroke-linecap="round"></path>
                <defs><linearGradient id="ptc" x1="0" y1="0" x2="1" y2="0"><stop stop-color="#2563eb"></stop><stop offset="0.5" stop-color="#3b82f6"></stop><stop offset="1" stop-color="#2563eb"></stop></linearGradient></defs>
              </svg>
              <div class="grid grid-cols-3 gap-3">
                {['Horas','Tareas','Equipo'].map((t) => (
                  <div class="rounded-lg bg-sand-50 border border-sand-200 px-3 py-2">
                    <span class="block text-[10px] text-sand-500">{t}</span>
                    <span class="block h-1.5 mt-1.5 rounded-full bg-gradient-to-r from-ember to-gold opacity-70"></span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        )}
          </div>
        </div>
        {!producto.shot && <p class="text-[11px] text-sand-500 mt-3 text-center">Vista de muestra — sustituir por captura real de Curva Tiempos.</p>}
      </div>
    </div>
  </section>

  <!-- ============================== CTA ============================== -->
  <section class="zone-color py-28 sm:py-36 px-6 sm:px-10 relative overflow-hidden">
    <Curve variant="band" draw="scroll" stroke={1.4} class="pointer-events-none absolute inset-x-0 top-0 w-full h-[18vh] opacity-25" />
    <div class="mx-auto max-w-3xl text-center relative z-10">
      <p class="reveal eyebrow text-jade-300 mb-5">Tu empresa, por sistema. Menos esfuerzo, más estructura.</p>
      <h2 class="reveal display text-4xl sm:text-5xl lg:text-6xl font-semibold tracking-tight leading-[1.04] text-balance text-white">Cuéntanos de tu empresa.</h2>
      <p class="reveal mt-6 text-lg text-sand-200 max-w-md mx-auto leading-relaxed">30 minutos. Nos cuentas cómo está la operación y te decimos derecho si te podemos ayudar o no.</p>
    </div>
    <!-- Calendario embebido (sin salir de la página) -->
    <div class="reveal mx-auto max-w-3xl mt-10 relative z-10">
      <div class="rounded-3xl overflow-hidden border border-sand-200 bg-white shadow-2xl">
        <iframe src={`${calLink}?embed=true`} title="Agenda tu llamada de exploración" loading="lazy" class="w-full h-[640px] border-0"></iframe>
      </div>
      <p class="mt-6 text-center text-sm text-sand-200">¿Todavía no para la llamada?
        <a href={waLink} target="_blank" rel="noopener" class="text-white font-semibold underline underline-offset-2 hover:text-jade-300">Escríbenos por WhatsApp.</a>
      </p>
    </div>
  </section>

  <a href={waLink} target="_blank" rel="noopener" data-magnetic="0.2" class="fixed bottom-6 right-6 z-50 w-14 h-14 bg-[#25D366] rounded-full flex items-center justify-center shadow-lg hover:scale-105 transition-all" aria-label="Contactar por WhatsApp">
    <svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"></path></svg>
  </a>

  </main>

  <Footer calLink={calLink} waLink={waLink} />
</BaseLayout>

