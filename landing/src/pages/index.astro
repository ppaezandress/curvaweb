<style>
  .cinta {
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 7%, #000 93%, transparent);
    mask-image: linear-gradient(90deg, transparent, #000 7%, #000 93%, transparent);
  }
  .marquee-track { animation: marquee 36s linear infinite; }
  .marquee-track.marquee-rev { animation-duration: 30s; animation-direction: reverse; }
  @keyframes marquee { to { transform: translateX(-50%); } }
  @media (max-width: 640px) { .marquee-track { animation-duration: 24s; } .marquee-track.marquee-rev { animation-duration: 20s; } }
  @media (prefers-reduced-motion: reduce) { .marquee-track { animation: none; } }
  .text-balance { text-wrap: balance; }

  /* Scroll-hint: deriva suave (sin rebote) con la curva de la marca */
  .hint-drift { animation: hint-drift 2.4s var(--ease-curve) infinite; }
  @keyframes hint-drift {
    0%, 100% { transform: translateY(0);   opacity: 0.75; }
    50%      { transform: translateY(7px); opacity: 1; }
  }
  @media (prefers-reduced-motion: reduce) { .hint-drift { animation: none; } }

  /* ===================== El viaje por la curva (#viaje) =====================
     Desktop (sm+): escena horizontal — la curva se dibuja con el scroll, el
     isotipo la escala (climb.ts) y las 5 fases son chips-nodo con ficha estilo
     diccionario en hover/focus. Móvil: timeline vertical (.viajem). */

  /* --- El isotipo trepador --- */
  .climber {
    position: absolute; top: 0; left: 0;
    width: clamp(26px, 2.7vw, 34px);
    opacity: 0; pointer-events: none; z-index: 5;
    will-change: transform;
    transition: opacity 0.45s var(--ease-curve);
  }
  .climber.is-on { opacity: 1; }
  .climber :global(svg) {
    width: 100%; height: auto; display: block; color: #fff;
    /* La sombra ink sutil mantiene legible el isotipo cuando cruza chips blancos */
    filter: drop-shadow(0 1px 2px rgba(15, 30, 61, 0.55)) drop-shadow(0 0 6px rgba(125, 211, 252, 0.9)) drop-shadow(0 4px 16px rgba(56, 189, 248, 0.45));
    transition: filter 0.6s var(--ease-curve);
  }
  .summit-reached .climber :global(svg) {
    filter: drop-shadow(0 0 10px rgba(255, 255, 255, 0.95)) drop-shadow(0 4px 22px rgba(125, 211, 252, 0.7));
  }

  /* --- Fases: chip-nodo + ficha diccionario --- */
  .fase { display: none; }
  @media (min-width: 640px) { .fase { display: block; } }
  .fase:hover, .fase:focus-within { z-index: 20; }

  .fase-stack {
    position: absolute; left: 50%; bottom: 13px; transform: translateX(-50%);
    display: flex; flex-direction: column; align-items: center; gap: 0.6rem;
  }
  .fase-chip {
    display: inline-flex; align-items: center; gap: 0.45rem; white-space: nowrap;
    cursor: help; border-radius: 9999px;
    background: #fff; color: var(--color-sand-700);
    border: 1px solid var(--color-sand-200);
    box-shadow: 0 12px 28px -14px rgba(2, 8, 23, 0.65);
    padding: 0.42rem 0.85rem;
    font-size: 11.5px; font-weight: 600; letter-spacing: 0.01em;
    font-family: var(--font-sans);
    transition: opacity 0.5s var(--ease-curve), border-color 0.5s var(--ease-curve),
      box-shadow 0.5s var(--ease-curve), transform 0.3s var(--ease-pitch);
  }
  .fase-chip:hover { transform: translateY(-2px); }
  .fase-num { color: var(--color-ember); }
  /* Con climb.ts armado, las fases aún no alcanzadas van tenues; .lit las enciende */
  .is-armed .fase:not(.lit) .fase-chip { opacity: 0.45; }
  .fase.lit .fase-chip {
    border-color: color-mix(in srgb, var(--color-jade) 55%, #fff);
    box-shadow: 0 0 26px -4px color-mix(in srgb, var(--color-jade) 80%, transparent);
  }

  /* Ficha estilo diccionario: palabra + etiqueta en itálica + definición */
  .fase-tip {
    width: 15.5rem; max-width: 58vw; text-align: left; position: relative;
    background: #fff; border: 1px solid var(--color-sand-200); border-radius: 0.9rem;
    padding: 0.85rem 1rem 0.9rem;
    box-shadow: 0 24px 48px -18px rgba(2, 8, 23, 0.65);
    opacity: 0; visibility: hidden; transform: translateY(7px) scale(0.97);
    transform-origin: bottom center; pointer-events: none;
    transition: opacity 0.35s var(--ease-pitch), transform 0.35s var(--ease-pitch),
      visibility 0s linear 0.35s;
  }
  .fase-tip::after {
    content: ""; position: absolute; left: 50%; top: 100%;
    transform: translateX(-50%);
    border: 7px solid transparent; border-top-color: #fff;
  }
  .fase:hover .fase-tip,
  .fase:focus-within .fase-tip { opacity: 1; visibility: visible; transform: none; transition-delay: 0s; }
  .fase-tip-word { font-size: 1rem; font-weight: 600; color: var(--color-ink); letter-spacing: -0.01em; }
  .fase-tip-tag { margin-top: 0.1rem; font-size: 11px; font-style: italic; color: var(--color-sand-500); }
  .fase-tip-def {
    margin-top: 0.5rem; padding-top: 0.5rem; border-top: 1px solid var(--color-sand-100);
    font-size: 13px; line-height: 1.55; color: var(--color-sand-600);
  }

  /* --- La cima: bandera + anillos (celebración al llegar el isotipo) --- */
  .cima-flag {
    opacity: 0; transform: translateY(10px) scale(0.7);
    transform-box: fill-box; transform-origin: bottom left;
    transition: opacity 0.5s var(--ease-pitch), transform 0.65s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .summit-reached .cima-flag { opacity: 1; transform: none; }
  .cima-cloth { transform-box: fill-box; transform-origin: left center; }
  .summit-reached .cima-cloth { animation: cima-wave 2.6s ease-in-out infinite 0.55s; }
  @keyframes cima-wave {
    0%, 100% { transform: scaleX(1) skewY(0deg); }
    50%      { transform: scaleX(0.9) skewY(-4deg); }
  }
  .cima-ring { transform-box: fill-box; transform-origin: center; opacity: 0; }
  .summit-reached .cima-ring { animation: cima-ring 2.6s ease-out infinite; }
  .summit-reached .cima-ring--2 { animation-delay: 1.3s; }
  @keyframes cima-ring {
    0%   { transform: scale(1);   opacity: 0.75; }
    70%  { opacity: 0; }
    100% { transform: scale(3.4); opacity: 0; }
  }
  .cima-node { transform-box: fill-box; transform-origin: center; transition: filter 0.5s var(--ease-curve); }
  .summit-reached .cima-node { filter: drop-shadow(0 0 13px rgba(186, 230, 253, 0.95)); }

  /* --- Móvil: timeline vertical del mismo viaje --- */
  .viajem { padding-left: 2.6rem; }
  .viajem-rail {
    position: absolute; left: 12px; top: 12px; bottom: 12px; width: 2px; border-radius: 2px;
    background: linear-gradient(to bottom, rgba(255, 255, 255, 0.22), var(--color-jade));
  }
  .viajem-item { position: relative; transition-delay: calc(var(--i) * 70ms); }
  .viajem-item + .viajem-item { margin-top: 1.9rem; }
  .viajem-node {
    position: absolute; top: 0.05rem; left: calc(-2.6rem + 0.5px);
    width: 25px; height: 25px; border-radius: 9999px;
    border: 2px solid var(--color-jade); background: var(--color-ink);
    display: grid; place-items: center; color: #fff;
  }
  .viajem-num { font-size: 10px; font-weight: 700; color: var(--color-jade-300); }
  .viajem-node--hoy { border-color: rgba(255, 255, 255, 0.45); }
  .viajem-node--hoy::after { content: ""; width: 7px; height: 7px; border-radius: 9999px; background: #fff; }
  .viajem-node--cima {
    border-color: transparent;
    background: linear-gradient(135deg, var(--color-ember), var(--color-jade));
    box-shadow: 0 0 16px rgba(56, 189, 248, 0.55);
  }
  .viajem-node--cima svg { width: 13px; height: 13px; color: #fff; }

  @media (prefers-reduced-motion: reduce) {
    .climber { transition: none; }
    .fase-tip { transition: none; }
    .cima-flag, .cima-node { transition: none; }
    .summit-reached .cima-cloth, .summit-reached .cima-ring { animation: none; }
    .summit-reached .cima-ring { opacity: 0; }
    .viajem-item { transition-delay: 0s; }
  }
</style>
