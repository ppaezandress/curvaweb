---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Curve from '../components/Curve.astro';
import LeadMagnet from '../components/LeadMagnet.astro';
import { areas } from '../data/areas';
import { casos } from '../data/casos';

const calLink = 'https://cal.com/andres-paez/30min';
const waLink = 'https://wa.me/5215611846200?text=Hola%2C%20me%20interesa%20saber%20m%C3%A1s%20sobre%20CURVA';

const accentText = { ember: 'text-ember', gold: 'text-gold', jade: 'text-jade' } as const;
const accentBar = { ember: 'bg-ember', gold: 'bg-gold', jade: 'bg-jade' } as const;
const accentSoft = { ember: 'bg-ember/12', gold: 'bg-gold/15', jade: 'bg-jade/12' } as const;
const accentBorder = { ember: 'border-ember', gold: 'border-gold', jade: 'border-jade' } as const;

const icons: Record<string, string> = {
  compass: 'M12 21a9 9 0 100-18 9 9 0 000 18zm3.5-12.5l-2 5.5-5.5 2 2-5.5 5.5-2z',
  bolt: 'M13 2L4.5 13.5H11l-1 8.5L19.5 10H13l0-8z',
  spark: 'M12 2l2.1 6.3L20 10l-5.9 1.7L12 18l-2.1-6.3L4 10l5.9-1.7L12 2z',
};

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: 'CURVA',
  description: 'Consultoría de transformación operativa y digital para empresas en crecimiento.',
  areaServed: 'México',
  address: { '@type': 'PostalAddress', addressLocality: 'Ciudad de México', addressCountry: 'MX' },
  serviceType: ['Consultoría empresarial', 'Digitalización', 'Automatización con IA'],
  founder: { '@type': 'Person', name: 'Andrés Páez Cortazar' },
};

const problema = [
  'El negocio depende de pocas personas para no detenerse.',
  'Los procesos viven en la cabeza, no en un sistema.',
  'Cada venta nueva trae más trabajo y desorden, no más claridad.',
  'Hay con qué crecer, pero falta la estructura para lograrlo.',
];

// La curva: el "antes" y el "después" que recorre el cliente con nosotros.
const hoy = [
  'Si tú paras, todo para.',
  'El día se te va apagando incendios.',
  'Vendes más y el caos crece igual.',
];
const despues = [
  'El negocio corre sin ti encima.',
  'Cada quien sabe qué hacer, sin preguntarte.',
  'Creces con números, no con corazonadas.',
];

// Hitos sobre la curva (coords % sobre la Bézier del viewBox 1280x420).
// `at` = fracción del recorrido en que se "enciende" (sincroniza con el trazo); `href` = su servicio.
const hitosCurva = [
  { n: '01', label: 'Diagnóstico',    left: 27.3, top: 79.8, at: 0.24, href: '/servicios/diagnostico' },
  { n: '02', label: 'Estructura',     left: 51.6, top: 59.5, at: 0.50, href: '/servicios/procesos' },
  { n: '03', label: 'Digitalización', left: 75.7, top: 31.9, at: 0.74, href: '/servicios/digitalizacion' },
];

// Mismo viaje como timeline vertical para móvil (la gráfica horizontal se aplana en pantallas chicas).
const paradas = [
  { eyebrow: 'Hoy', label: 'Operación a pulso', accent: 'ember' as const },
  { eyebrow: '01', label: 'Diagnóstico', accent: 'ember' as const },
  { eyebrow: '02', label: 'Estructura', accent: 'gold' as const },
  { eyebrow: '03', label: 'Digitalización', accent: 'jade' as const },
  { eyebrow: 'Con CURVA', label: 'Operación por sistema', accent: 'jade' as const },
];

const proceso = [
  { num: '01', title: 'Diagnóstico', desc: 'Nos metemos a tu operación y vemos qué está pasando de verdad.', dur: '1–3 semanas' },
  { num: '02', title: 'Ruta por módulos', desc: 'Atacamos primero lo que duele. Nada de planes de 200 páginas.', dur: 'Contigo, en 1 sesión' },
  { num: '03', title: 'Implementación', desc: 'Lo armamos contigo: sistemas, procesos y tu equipo entrenado.', dur: 'Según el alcance' },
  { num: '04', title: 'Acompañamiento', desc: 'No desaparecemos. Nos quedamos hasta que camina solo.', dur: 'Hasta que jala solo' },
];
const marqueeItems = ['Diagnóstico','Procesos','Gobernanza','ERPs','Automatización','Agentes IA','Cultura','Liderazgo'];

// Path firma de la sección "La curva" (coincide con offset-path de .curve-dot en global.css).
const curvePath = 'M40,360 C320,360 380,330 660,250 C940,170 1010,80 1240,70';

// Banda de números globales. ⚠️ VALORES PLACEHOLDER — reemplazar con cifras reales (ver lista de pendientes).
const numeros = [
  { value: '15+',    label: 'Empresas atendidas',       accent: 'ember', spark: 'M0,30 C22,28 38,22 58,14 C78,7 90,6 100,4' },
  { value: '20+',    label: 'Sistemas en producción',   accent: 'gold',  spark: 'M0,31 C20,30 36,24 56,15 C76,8 90,9 100,3' },
  { value: '500+',   label: 'Horas ahorradas al mes',   accent: 'jade',  spark: 'M0,29 C24,27 40,20 60,12 C80,6 92,7 100,5' },
  { value: '2,300+', label: 'Operaciones digitalizadas', accent: 'gold', spark: 'M0,30 C25,29 42,23 62,13 C82,6 93,5 100,4' },
] as const;

// Producto propio = prueba ("no entregamos PDFs, construimos software"). Curva Tiempos.
const producto = {
  // PLACEHOLDER: pásame la URL pública de Curva Tiempos y una captura real para /public.
  link: '#',                 // TODO: URL real de Curva Tiempos
  shot: '',                  // TODO: ruta a captura en /public (ej. '/tiempos-shot.png'); vacío = mockup placeholder
};
---

<BaseLayout
  title="CURVA. Transformación operativa y digital"
  description="Ordenamos y digitalizamos la operación de empresas en crecimiento para que el dueño recupere el control y el negocio jale sin él encima."
  jsonLd={jsonLd}
>
  <Nav overHero calLink={calLink} />

  <a href="#problema" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:bg-ember focus:text-white focus:px-4 focus:py-2 focus:rounded-full focus:text-sm focus:font-semibold">Saltar al contenido</a>

  <!-- ============================== HERO ============================== -->
  <section class="surface-ink grain text-sand-50 relative min-h-[94vh] flex flex-col justify-center overflow-hidden">
    <div class="glow-orb" style="width:34rem;height:34rem;top:-8rem;left:-6rem;background:radial-gradient(circle,rgba(124,58,237,0.55),transparent 70%);"></div>
    <div class="glow-orb" style="width:30rem;height:30rem;bottom:-10rem;right:-4rem;background:radial-gradient(circle,rgba(16,185,129,0.42),transparent 70%);animation-delay:-7s;"></div>

    <Curve variant="hero" draw="auto" stroke={1.6} class="pointer-events-none absolute inset-x-0 bottom-0 w-full h-[30vh] opacity-40 z-[2]" />

    <div class="mx-auto max-w-6xl w-full px-6 sm:px-10 relative z-10 pt-24">
      <p data-load="1" class="eyebrow text-ember-300 mb-7 inline-flex items-center gap-2.5">
        <span class="inline-block w-7 h-px bg-ember-300/60"></span>
        Transformación operativa y digital
      </p>
      <h1 data-load="2" class="display text-[2.7rem] leading-[1.04] sm:text-5xl lg:text-[4rem] font-semibold max-w-4xl tracking-tight text-balance">
        Que tu empresa funcione por <span class="curve-text-live">estructura</span>, no por esfuerzo.
      </h1>
      <p data-load="3" class="mt-7 text-lg sm:text-xl text-sand-300 leading-relaxed max-w-xl">
        Ponemos orden, lo conectamos con tecnología y lo dejamos funcionando. Para que dejes de cargar la empresa en la espalda.
      </p>
      <div data-load="4" class="mt-10 flex flex-col sm:flex-row sm:items-center gap-x-6 gap-y-4">
        <a href={calLink} target="_blank" rel="noopener" class="btn-shine group inline-flex w-fit items-center justify-center gap-2 text-base font-semibold bg-ember text-white px-7 py-4 rounded-full hover:bg-ember-600 transition-all hover:gap-3">
          Agendar llamada de exploración
          <svg class="w-4 h-4 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path></svg>
        </a>
        <a href="#la-curva" class="text-base font-medium text-sand-300 hover:text-sand-50 transition-colors link-underline">Ver cómo funciona →</a>
      </div>
      <div data-load="5" class="mt-14 flex flex-wrap items-center gap-x-8 gap-y-3 text-sand-400 text-[13px]">
        <span class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-ember"></span> Consultoría y estructura</span>
        <span class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-gold"></span> Digitalización y automatización</span>
        <span class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-jade"></span> Agentes con IA</span>
      </div>
    </div>
    <a href="#problema" aria-label="Bajar" class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce z-10"><svg class="w-6 h-6 text-sand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5L12 21m0 0l-7.5-7.5M12 21V3"></path></svg></a>
  </section>

  <!-- ============================== MARQUEE ============================== -->
  <div class="py-4 bg-ink text-sand-50 select-none overflow-hidden whitespace-nowrap border-y border-white/5">
    <div class="marquee-track inline-block text-[12px] font-medium tracking-[0.2em] uppercase text-sand-500">
      {Array.from({ length: 2 }).map(() => (
        <span>{marqueeItems.map((m) => (<Fragment><span class="mx-5">{m}</span><span class="text-ember/50">/</span></Fragment>))}</span>
      ))}
    </div>
  </div>

  <!-- ============================== EL PROBLEMA ============================== -->
  <section id="problema" class="py-24 sm:py-36 px-6 sm:px-10 bg-sand-50">
    <div class="mx-auto max-w-7xl grid lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] gap-12 lg:gap-24">
      <div class="lg:sticky lg:top-28 self-start">
        <p class="reveal eyebrow text-ember mb-5">Para quién es esto</p>
        <h2 class="reveal display text-3xl sm:text-4xl lg:text-5xl font-semibold leading-[1.08] tracking-tight text-ink text-balance">Ya operas y vendes. Pero la estructura no aguanta.</h2>
        <p class="reveal mt-6 text-lg text-sand-600 leading-relaxed max-w-md">Si te suena, el problema no es falta de esfuerzo. Es falta de sistema.</p>
      </div>
      <ul class="border-t border-sand-200 self-center">
        {problema.map((item, i) => (
          <li class="reveal flex gap-6 items-baseline py-7 border-b border-sand-200 group">
            <span class={`display text-base font-semibold tabular-nums ${accentText[areas[i % areas.length].accent]}`}>0{i + 1}</span>
            <p class="text-xl sm:text-2xl text-ink leading-snug group-hover:translate-x-1 transition-transform">{item}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ============================== LA CURVA (transformación) ============================== -->
  <section id="la-curva" class="surface-ink grain text-sand-50 py-24 sm:py-36 px-6 sm:px-10 relative overflow-hidden scroll-mt-24">
    <div class="glow-orb" style="width:28rem;height:28rem;top:18%;left:50%;transform:translateX(-50%);background:radial-gradient(circle,rgba(37,99,235,0.32),transparent 70%);"></div>
    <div class="mx-auto max-w-6xl relative z-10">
      <div class="max-w-2xl mb-4">
        <p class="reveal eyebrow text-ember-300 mb-5">La curva</p>
        <h2 class="reveal display text-3xl sm:text-4xl lg:text-5xl font-semibold tracking-tight leading-[1.08] text-balance">Hoy estás <span class="text-ember-300">aquí</span>. Te llevamos <span class="curve-text-live">acá</span>.</h2>
        <p class="reveal mt-5 text-lg text-sand-400 leading-relaxed">Cada etapa te quita un peso de encima. Hasta que dejas de ser el cuello de botella de tu propia empresa.</p>
      </div>

      <!-- Escena horizontal (desktop): gráfica con punto viajero -->
      <div class="reveal relative mt-12 sm:mt-20 hidden sm:block">
        <svg viewBox="0 0 1280 420" fill="none" class="w-full h-auto block overflow-visible" aria-hidden="true">
          <defs>
            <linearGradient id="curve-stage-grad" x1="0" y1="0" x2="1" y2="0">
              <stop offset="0" stop-color="#7c3aed"></stop>
              <stop offset="0.5" stop-color="#2563eb"></stop>
              <stop offset="1" stop-color="#10b981"></stop>
            </linearGradient>
            <linearGradient id="curve-area" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0" stop-color="#2563eb" stop-opacity="0.22"></stop>
              <stop offset="1" stop-color="#2563eb" stop-opacity="0"></stop>
            </linearGradient>
            <pattern id="grid" width="48" height="48" patternUnits="userSpaceOnUse">
              <path d="M48 0 H0 V48" fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="1"></path>
            </pattern>
            <radialGradient id="grid-fade" cx="42%" cy="40%" r="70%">
              <stop offset="0" stop-color="#fff"></stop>
              <stop offset="100%" stop-color="#000"></stop>
            </radialGradient>
            <mask id="grid-mask"><rect width="1280" height="420" fill="url(#grid-fade)"></rect></mask>
            <filter id="curve-glow" x="-20%" y="-60%" width="140%" height="220%">
              <feGaussianBlur stdDeviation="7" result="b"></feGaussianBlur>
              <feMerge><feMergeNode in="b"></feMergeNode><feMergeNode in="SourceGraphic"></feMergeNode></feMerge>
            </filter>
          </defs>

          <!-- Plano técnico de fondo -->
          <rect width="1280" height="420" fill="url(#grid)" mask="url(#grid-mask)"></rect>
          <!-- Eje base -->
          <line x1="40" y1="392" x2="1240" y2="392" stroke="rgba(255,255,255,0.12)" stroke-width="1"></line>

          <!-- Partículas / puntos de dato -->
          <circle cx="180" cy="300" r="2.5" fill="#a78bfa" class="twinkle"></circle>
          <circle cx="520" cy="190" r="2" fill="#60a5fa" class="twinkle" style="animation-delay:-1.2s"></circle>
          <circle cx="760" cy="320" r="2" fill="#60a5fa" class="twinkle" style="animation-delay:-2.1s"></circle>
          <circle cx="1080" cy="150" r="2.5" fill="#6ee7b7" class="twinkle" style="animation-delay:-0.6s"></circle>
          <circle cx="340" cy="120" r="1.8" fill="#a78bfa" class="twinkle" style="animation-delay:-3s"></circle>
          <circle cx="980" cy="300" r="1.8" fill="#6ee7b7" class="twinkle" style="animation-delay:-1.8s"></circle>

          <!-- Área de crecimiento bajo la curva -->
          <path d={`${curvePath} L1240,392 L40,392 Z`} fill="url(#curve-area)"></path>
          <!-- Riel tenue -->
          <path d={curvePath} stroke="rgba(255,255,255,0.10)" stroke-width="2" stroke-linecap="round" stroke-dasharray="2 10"></path>
          <!-- Trazo firma ligado al scroll -->
          <path d={curvePath} stroke="url(#curve-stage-grad)" stroke-width="3.5" stroke-linecap="round" filter="url(#curve-glow)" pathLength="1" data-curve-draw="scroll" style="stroke-dasharray:1;stroke-dashoffset:1;"></path>

          <!-- Hitos sobre la curva -->
          <circle cx="350" cy="335" r="5" fill="#0b0a14" stroke="#8b5cf6" stroke-width="2.5"></circle>
          <circle cx="660" cy="250" r="5" fill="#0b0a14" stroke="#3b82f6" stroke-width="2.5"></circle>
          <circle cx="969" cy="134" r="5" fill="#0b0a14" stroke="#22c79a" stroke-width="2.5"></circle>

          <!-- Nodo inicio (hoy) -->
          <circle cx="40" cy="360" r="9" fill="#0b0a14" stroke="#a78bfa" stroke-width="3"></circle>
          <!-- Nodo fin (con CURVA) -->
          <circle cx="1240" cy="70" r="11" fill="#10b981" stroke="#6ee7b7" stroke-width="3"></circle>

          <!-- Punto viajero (con halo) -->
          <circle class="curve-dot" r="6" fill="#fff" stroke="rgba(255,255,255,0.22)" stroke-width="9"></circle>
        </svg>

        <!-- Hitos: chip flotante clickeable que se "enciende" al pasar el trazo (solo desktop) -->
        {hitosCurva.map((m) => (
          <div class="milestone hidden sm:block" data-at={m.at} style={`left:${m.left}%;top:${m.top}%`}>
            <a href={m.href} class="lm-chip group absolute left-1/2 -translate-x-1/2 bottom-full mb-4 flex items-center gap-1.5 whitespace-nowrap rounded-full bg-ink-2/80 backdrop-blur-md border border-white/10 px-3 py-1.5 text-[11px] font-semibold text-sand-200 shadow-xl shadow-black/40 transition-all hover:border-ember-300/50 hover:-translate-y-0.5">
              <span class="lm-num text-ember-300 tabular-nums transition-colors">{m.n}</span>{m.label}
              <svg class="lm-arrow w-3 h-3 opacity-0 -ml-1 transition-all group-hover:opacity-100 group-hover:ml-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path></svg>
            </a>
          </div>
        ))}

        <!-- Extremos -->
        <div class="absolute left-0 -bottom-2 sm:bottom-0 max-w-[46%]">
          <p class="eyebrow text-ember-300 mb-2">Hoy</p>
          <p class="display text-lg sm:text-2xl font-semibold text-sand-200 leading-tight">Operación a pulso</p>
        </div>
        <div class="absolute right-0 top-0 max-w-[46%] text-right">
          <p class="eyebrow text-jade-300 mb-2">Con CURVA</p>
          <p class="display text-lg sm:text-2xl font-semibold text-jade-300 leading-tight">Operación por sistema</p>
        </div>
      </div>

      <!-- Escena vertical (móvil): mismo viaje como timeline -->
      <div class="reveal sm:hidden mt-10 relative pl-9">
        <span class="absolute left-[13px] top-3 bottom-3 w-px bg-gradient-to-b from-ember via-gold to-jade"></span>
        <ul class="space-y-8">
          {paradas.map((p) => (
            <li class="relative">
              <span class={`absolute -left-9 top-0.5 w-[26px] h-[26px] rounded-full border-2 ${accentBorder[p.accent]} bg-ink flex items-center justify-center`}>
                <span class={`w-2 h-2 rounded-full ${accentBar[p.accent]}`}></span>
              </span>
              <p class={`eyebrow ${accentText[p.accent]} mb-1`}>{p.eyebrow}</p>
              <p class="display text-lg font-semibold text-sand-100 leading-tight">{p.label}</p>
            </li>
          ))}
        </ul>
      </div>

      <!-- Antes / después en dos columnas -->
      <div class="grid sm:grid-cols-2 gap-5 sm:gap-8 mt-14 sm:mt-20">
        <div class="reveal rounded-3xl border border-white/10 bg-white/[0.03] p-7 sm:p-9 backdrop-blur-sm">
          <p class="eyebrow text-ember-300 mb-6">Dónde estás hoy</p>
          <ul class="space-y-4">
            {hoy.map((h) => (
              <li class="flex gap-3 text-sand-300 leading-relaxed">
                <svg class="w-5 h-5 flex-shrink-0 mt-0.5 text-ember-300/70" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path></svg>
                <span>{h}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="reveal reveal-d1 rounded-3xl border border-jade/25 bg-jade/[0.06] p-7 sm:p-9 backdrop-blur-sm">
          <p class="eyebrow text-jade-300 mb-6">A dónde llegas</p>
          <ul class="space-y-4">
            {despues.map((d) => (
              <li class="flex gap-3 text-sand-200 leading-relaxed">
                <svg class="w-5 h-5 flex-shrink-0 mt-0.5 text-jade-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"></path></svg>
                <span>{d}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================== SERVICIOS ============================== -->
  <section id="servicios" class="py-24 sm:py-36 px-6 sm:px-10 bg-white border-t border-sand-200">
    <div class="mx-auto max-w-7xl">
      <div class="max-w-2xl mb-16">
        <p class="reveal eyebrow text-ember mb-5">Qué hacemos</p>
        <h2 class="reveal display text-3xl sm:text-4xl lg:text-5xl font-semibold tracking-tight leading-[1.08] text-ink text-balance">Estrategia, tecnología y personas. Lo que tu operación pida.</h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 max-w-4xl">
        {areas.map((a, i) => (
          <a href={a.href} data-tilt="3" class={`reveal reveal-d${i + 1} group relative rounded-3xl bg-sand-50 border border-sand-200 p-9 flex flex-col min-h-[300px] overflow-hidden hover:shadow-2xl hover:border-sand-300 transition-all`}>
            <span class={`absolute inset-x-0 top-0 h-1 ${accentBar[a.accent]}`}></span>
            <span class={`absolute -right-10 -top-10 w-40 h-40 rounded-full ${accentSoft[a.accent]} blur-2xl opacity-0 group-hover:opacity-100 transition-opacity`}></span>
            <div class={`relative w-14 h-14 rounded-2xl ${accentSoft[a.accent]} flex items-center justify-center mb-7`}>
              <svg class={`w-7 h-7 ${accentText[a.accent]}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6"><path stroke-linecap="round" stroke-linejoin="round" d={icons[a.icon]}></path></svg>
            </div>
            <h3 class="relative display text-2xl font-semibold mb-3 text-ink">{a.title}</h3>
            <p class="relative text-sand-600 text-[15px] leading-relaxed">{a.desc}</p>
            <div class="relative mt-5 flex flex-wrap gap-2">
              {a.tags.map((t) => (<span class="text-[11px] font-medium text-sand-600 bg-white border border-sand-200 rounded-full px-2.5 py-1">{t}</span>))}
            </div>
            <span class={`relative mt-auto pt-7 inline-flex items-center gap-2 text-sm font-semibold ${accentText[a.accent]} group-hover:gap-3 transition-all`}>
              Ver más
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================== CÓMO TRABAJAMOS ============================== -->
  <section class="surface-ink-soft text-sand-50 py-24 sm:py-36 px-6 sm:px-10">
    <div class="mx-auto max-w-7xl">
      <div class="max-w-2xl mb-16">
        <p class="reveal eyebrow text-ember-300 mb-5">Cómo trabajamos</p>
        <h2 class="reveal display text-3xl sm:text-4xl lg:text-5xl font-semibold tracking-tight leading-[1.08] text-balance">No te dejamos un PDF. <span class="text-sand-500">Nos quedamos hasta que funcione.</span></h2>
      </div>
      <div class="relative grid sm:grid-cols-2 lg:grid-cols-4 gap-x-8 gap-y-14">
        <!-- Línea-recorrido que conecta los nodos (desktop) -->
        <div class="hidden lg:block absolute top-7 left-[11%] right-[11%] h-px bg-gradient-to-r from-ember via-gold to-jade opacity-50"></div>
        {proceso.map((s, i) => (
          <div class={`reveal reveal-d${i + 1} relative`}>
            <div class="relative z-10 w-14 h-14 rounded-full flex items-center justify-center mb-6 bg-ink-2 border border-white/15 shadow-[0_0_30px_-6px_rgba(124,58,237,0.5)]">
              <span class="display font-semibold text-lg curve-text">{s.num}</span>
              <span class="absolute inset-0 rounded-full border border-white/10"></span>
            </div>
            <h3 class="display font-semibold text-lg mb-2">{s.title}</h3>
            <p class="text-sand-400 text-[15px] leading-relaxed mb-3">{s.desc}</p>
            <span class="inline-flex items-center gap-1.5 text-[11px] font-semibold text-sand-300 bg-white/5 border border-white/10 rounded-full px-2.5 py-1">
              <svg class="w-3 h-3 text-ember-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
              {s.dur}
            </span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================== NÚMEROS (banda de impacto) ============================== -->
  {/* ⚠ VALORES PLACEHOLDER en `numeros` (frontmatter) — reemplazar con cifras reales antes de publicar. */}
  <section class="py-16 sm:py-24 px-6 sm:px-10 bg-white border-t border-sand-200">
    <div class="mx-auto max-w-7xl">
      <p class="reveal eyebrow text-ember mb-12 text-center">CURVA en números</p>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-x-6 gap-y-12">
        {numeros.map((n, i) => (
          <div class={`reveal reveal-d${(i % 4) + 1} text-center`}>
            <svg class="w-28 h-9 mx-auto mb-3" viewBox="0 0 100 32" fill="none" preserveAspectRatio="none" aria-hidden="true">
              <path d={n.spark} stroke="currentColor" stroke-width="2.5" stroke-linecap="round" class={accentText[n.accent]}></path>
            </svg>
            <p class="display text-4xl sm:text-5xl font-semibold text-ink tabular-nums">{n.value}</p>
            <p class="text-sm text-sand-500 mt-2 leading-snug">{n.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================== CASOS ============================== -->
  <section id="casos" class="py-24 sm:py-36 px-6 sm:px-10 bg-sand-50">
    <div class="mx-auto max-w-7xl">
      <div class="mb-14 max-w-2xl">
        <p class="reveal eyebrow text-ember mb-5">Resultados</p>
        <h2 class="reveal display text-3xl sm:text-4xl lg:text-5xl font-semibold tracking-tight leading-[1.08] text-ink text-balance">Lo que hemos construido.</h2>
        <p class="reveal mt-5 text-lg text-sand-600 leading-relaxed">Casos reales, con números reales. Lo que pasa cuando una operación deja de jalar a pulso.</p>
      </div>

      <div class="space-y-8">
        {casos.map((c, i) => (
          <article class={`reveal reveal-d${i + 1} rounded-3xl border border-sand-200 bg-white overflow-hidden grid lg:grid-cols-[1.5fr_1fr] hover:shadow-xl transition-shadow`}>
            {/* Historia: reto → qué hicimos → resultado */}
            <div class="p-8 sm:p-10 lg:border-r border-sand-200">
              <div class="flex items-center gap-3 mb-6">
                <span class={`px-3 py-1 rounded-full ${accentSoft[c.accent]} ${accentText[c.accent]} text-[11px] font-semibold uppercase tracking-wide`}>{c.categoria}</span>
                {c.logo ? <img src={c.logo} alt="" class="h-6 opacity-80" /> : null}
              </div>
              <h3 class="display text-2xl sm:text-3xl font-semibold mb-8 text-ink leading-tight">{c.title}</h3>
              <dl class="space-y-5">
                <div class="sm:flex gap-5">
                  <dt class={`flex-shrink-0 w-28 eyebrow ${accentText[c.accent]} pt-1 mb-1 sm:mb-0`}>El reto</dt>
                  <dd class="text-sand-700 leading-relaxed">{c.reto}</dd>
                </div>
                <div class="sm:flex gap-5">
                  <dt class={`flex-shrink-0 w-28 eyebrow ${accentText[c.accent]} pt-1 mb-1 sm:mb-0`}>Qué hicimos</dt>
                  <dd class="text-sand-700 leading-relaxed">{c.hicimos}</dd>
                </div>
                <div class="sm:flex gap-5">
                  <dt class={`flex-shrink-0 w-28 eyebrow ${accentText[c.accent]} pt-1 mb-1 sm:mb-0`}>Resultado</dt>
                  <dd class="text-ink font-medium leading-relaxed">{c.resultado}</dd>
                </div>
              </dl>
            </div>
            {/* Prueba: métricas + testimonial con autor */}
            <div class="p-8 sm:p-10 bg-sand-50 flex flex-col">
              <div class="grid grid-cols-2 gap-x-6 gap-y-7">
                {c.metrics.map((m) => (<div><p class="display text-3xl font-semibold text-ink tabular-nums">{m.value}</p><p class="text-xs text-sand-500 mt-1 leading-snug">{m.label}</p></div>))}
              </div>
              {c.quote && (
                <blockquote class="mt-8 pt-7 border-t border-sand-200">
                  <p class="text-ink text-[15px] leading-snug font-medium mb-4">{c.quote}</p>
                  {c.autor && (
                    <figcaption class="flex items-center gap-3">
                      <span class={`w-9 h-9 rounded-full ${accentSoft[c.accent]} ${accentText[c.accent]} flex items-center justify-center flex-shrink-0`}>
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.5 20.25a7.5 7.5 0 0115 0v.75H4.5v-.75z"></path></svg>
                      </span>
                      <span class="text-[13px] leading-tight">
                        <span class="block font-semibold text-ink">{c.autor.nombre === 'PENDIENTE' ? 'Cliente de CURVA' : c.autor.nombre}</span>
                        <span class="block text-sand-500">{c.autor.cargo}{c.autor.empresa !== 'PENDIENTE' ? ` · ${c.autor.empresa}` : ''}</span>
                      </span>
                    </figcaption>
                  )}
                </blockquote>
              )}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================== PRODUCTO (ventaja injusta) ============================== -->
  <section class="surface-ink grain text-sand-50 py-24 sm:py-32 px-6 sm:px-10 relative overflow-hidden">
    <div class="glow-orb" style="width:30rem;height:30rem;top:-6rem;right:-6rem;background:radial-gradient(circle,rgba(124,58,237,0.40),transparent 70%);"></div>
    <div class="mx-auto max-w-7xl relative z-10 grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <div>
        <p class="reveal eyebrow text-ember-300 mb-5">Nuestra ventaja</p>
        <h2 class="reveal display text-3xl sm:text-4xl lg:text-5xl font-semibold tracking-tight leading-[1.08] text-balance">No solo asesoramos. <span class="curve-text-live">Construimos.</span></h2>
        <p class="reveal mt-6 text-lg text-sand-300 leading-relaxed">
          La mayoría de las consultoras te dejan un PDF y se van. Nosotros construimos software de verdad —
          tan en serio que tenemos el nuestro: <strong class="text-sand-50 font-semibold">Curva Tiempos</strong>,
          el sistema con el que medimos cómo trabaja un equipo. Si lo usamos en casa, imagínate en tu operación.
        </p>
        <ul class="reveal reveal-d1 mt-8 space-y-3">
          {['Sistemas que tu equipo sí usa a diario', 'Construido por nosotros, no subcontratado', 'Lo probamos en nuestra propia operación primero'].map((p) => (
            <li class="flex gap-3 text-sand-200">
              <svg class="w-5 h-5 flex-shrink-0 mt-0.5 text-jade-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"></path></svg>
              <span>{p}</span>
            </li>
          ))}
        </ul>
        {producto.link !== '#' && (
          <a href={producto.link} target="_blank" rel="noopener" class="reveal reveal-d2 mt-8 inline-flex items-center gap-2 text-sm font-semibold text-ember-300 hover:gap-3 transition-all link-underline">
            Conocer Curva Tiempos
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path></svg>
          </a>
        )}
      </div>

      {/* Captura real (producto.shot) o mockup placeholder de marca */}
      <div class="reveal reveal-d1">
        {producto.shot ? (
          <img src={producto.shot} alt="Curva Tiempos" class="rounded-2xl border border-white/15 shadow-2xl w-full" />
        ) : (
          <div class="rounded-2xl border border-white/15 bg-ink-2/70 backdrop-blur overflow-hidden shadow-2xl">
            <div class="flex items-center gap-1.5 px-4 py-3 border-b border-white/10">
              <span class="w-2.5 h-2.5 rounded-full bg-white/20"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-white/20"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-white/20"></span>
              <span class="ml-3 text-[11px] text-sand-500">curva-tiempos</span>
            </div>
            <div class="aspect-[16/10] p-6 sm:p-8 flex flex-col justify-between bg-gradient-to-br from-ember/15 via-transparent to-jade/15">
              <div class="flex items-center gap-2">
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none"><path d="M2 18C6 18 7 6 12 6C17 6 18 18 22 18" stroke="url(#pt)" stroke-width="2.5" stroke-linecap="round"></path><defs><linearGradient id="pt" x1="2" y1="0" x2="22" y2="0"><stop stop-color="#a78bfa"></stop><stop offset="0.5" stop-color="#60a5fa"></stop><stop offset="1" stop-color="#6ee7b7"></stop></linearGradient></defs></svg>
                <span class="display font-semibold text-sand-100">Curva Tiempos</span>
              </div>
              <svg viewBox="0 0 320 90" fill="none" class="w-full" aria-hidden="true">
                <path d="M0,80 C70,80 90,40 160,38 C230,36 250,60 320,20" stroke="url(#ptc)" stroke-width="2.5" stroke-linecap="round"></path>
                <defs><linearGradient id="ptc" x1="0" y1="0" x2="1" y2="0"><stop stop-color="#7c3aed"></stop><stop offset="0.5" stop-color="#2563eb"></stop><stop offset="1" stop-color="#10b981"></stop></linearGradient></defs>
              </svg>
              <div class="grid grid-cols-3 gap-3">
                {['Horas','Tareas','Equipo'].map((t) => (
                  <div class="rounded-lg bg-white/5 border border-white/10 px-3 py-2">
                    <span class="block text-[10px] text-sand-500">{t}</span>
                    <span class="block h-1.5 mt-1.5 rounded-full bg-gradient-to-r from-ember to-jade opacity-70"></span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        )}
        {!producto.shot && <p class="text-[11px] text-sand-500 mt-3 text-center">Vista de muestra — sustituir por captura real de Curva Tiempos.</p>}
      </div>
    </div>
  </section>

  <!-- ============================== LEAD MAGNET (baja fricción) ============================== -->
  <LeadMagnet />

  <!-- ============================== CTA ============================== -->
  <section class="surface-ink grain text-sand-50 py-28 sm:py-36 px-6 sm:px-10 relative overflow-hidden">
    <Curve variant="band" draw="scroll" stroke={1.4} class="pointer-events-none absolute inset-x-0 top-0 w-full h-[18vh] opacity-30" />
    <div class="reveal mx-auto max-w-3xl text-center relative z-10">
      <h2 class="display text-4xl sm:text-5xl lg:text-6xl font-semibold tracking-tight leading-[1.04] text-balance">Cuéntanos de tu empresa.</h2>
      <p class="mt-6 text-lg text-sand-300 max-w-md mx-auto leading-relaxed">30 minutos. Nos cuentas cómo está la operación y te decimos derecho si te podemos ayudar o no.</p>
      <div class="mt-9 flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a href={calLink} target="_blank" rel="noopener" class="btn-shine group inline-flex items-center gap-2 text-base font-semibold bg-ember text-white px-9 py-4 rounded-full hover:bg-ember-600 transition-all hover:gap-3">
          Agendar llamada de exploración
          <svg class="w-4 h-4 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path></svg>
        </a>
        <a href={waLink} target="_blank" rel="noopener" class="group inline-flex items-center gap-2.5 text-base font-semibold text-sand-100 border border-white/20 px-8 py-4 rounded-full hover:bg-white/5 hover:border-white/40 transition-all">
          <svg class="w-5 h-5 text-[#25D366]" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"></path></svg>
          Escríbenos por WhatsApp
        </a>
      </div>
      <p class="mt-6 text-sm text-sand-400">¿Todavía no para la llamada? Un WhatsApp también jala.</p>
    </div>
  </section>

  <a href={waLink} target="_blank" rel="noopener" class="fixed bottom-6 right-6 z-50 w-14 h-14 bg-[#25D366] rounded-full flex items-center justify-center shadow-lg hover:scale-105 transition-all" aria-label="Contactar por WhatsApp">
    <svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"></path></svg>
  </a>

  <Footer calLink={calLink} waLink={waLink} />
</BaseLayout>

<style>
  .marquee-track { animation: marquee 34s linear infinite; }
  @keyframes marquee { to { transform: translateX(-50%); } }
  .cases-track { display: flex; gap: 1.5rem; overflow-x: auto; scroll-snap-type: x mandatory; scrollbar-width: none; }
  .cases-track::-webkit-scrollbar { display: none; }
  .case-card { scroll-snap-align: start; flex: 0 0 88%; max-width: 540px; }
  @media (min-width: 640px) { .case-card { flex: 0 0 48%; } }
  @media (min-width: 1024px) { .case-card { flex: 0 0 31.5%; } }
  .dot-active { background-color: var(--color-ember); }
  @media (max-width: 640px) { .marquee-track { animation-duration: 24s; } }
  .text-balance { text-wrap: balance; }
</style>
