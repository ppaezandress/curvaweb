---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Curve from '../components/Curve.astro';

const calLink = 'https://cal.com/andres-paez/30min';
import { waLink as buildWa } from '../data/site';
const waLink = buildWa();

const siEs = [
  'Consultora de transformación digital y de negocio.',
  'Copiloto cercano de los fundadores: del lado del cliente.',
  'Quien sabe y hace: te aconsejamos y lo construimos contigo.',
  'Socio para empresas que ya crecieron, pero necesitan orden.',
];
const noEs = [
  'Agencia de marketing generalista.',
  'Un proveedor que entrega un sistema y se va.',
  'Consultora abstracta que aconseja sin implementar.',
  'Un intermediario que cobra comisiones.',
];

const cercania = [
  { t: 'Metidos en tu día a día', d: 'En tu WhatsApp, en tus juntas, en la cancha. No el consultor que ves una vez al mes.' },
  { t: 'Manos a la obra', d: 'No solo decimos qué hacer. Lo hacemos contigo, hombro con hombro.' },
  { t: 'Hasta que jala solo', d: 'No nos vamos cuando entregamos. Nos quedamos hasta que funciona sin nosotros.' },
  { t: 'Sin humo', d: 'Te decimos derecho si te podemos ayudar o no. Y lo que hacemos, se nota.' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: 'Nosotros · CURVA',
  description: 'Quiénes somos, en qué creemos y hacia dónde vamos.',
};
---

<BaseLayout title="Nosotros · CURVA" description="Quiénes somos, en qué creemos y hacia dónde vamos. Una consultora de transformación digital y de negocio para empresas en crecimiento." jsonLd={jsonLd} thread>
  <Nav calLink={calLink} />

  <a href="#contenido" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:bg-ember focus:text-white focus:px-4 focus:py-2 focus:rounded-full focus:text-sm focus:font-semibold">Saltar al contenido</a>

  <main id="contenido" tabindex="-1" class="ns">

  <!-- ============================================================ -->
  <!-- HERO — el manifiesto abre                                    -->
  <!-- ============================================================ -->
  <section class="ns-hero grain">
    <!-- Atmósfera: mesh + halos que flotan, con parallax de cursor -->
    <div class="ns-hero-atmos" aria-hidden="true">
      <div class="ns-hero-mesh"></div>
      <div class="parallax" data-parallax="30"><div class="glow-orb ns-orb-a"></div></div>
      <div class="parallax" data-parallax="-18"><div class="glow-orb ns-orb-b"></div></div>
    </div>

    <!-- Palabra fantasma editorial, enorme, detrás del titular -->
    <span class="ns-ghost parallax" data-parallax="12" aria-hidden="true">copiloto</span>

    <!-- Etiqueta vertical de manifiesto (detalle editorial, solo desktop) -->
    <span class="ns-rail" aria-hidden="true">Manifiesto — 2026</span>

    <div class="ns-hero-inner">
      <p class="ns-kicker" data-load="1"><span class="ns-kicker-dot"></span>Nosotros · en qué creemos</p>

      <h1 class="ns-h1">
        <span class="hero-line ns-line">Somos tu <span class="curve-text">copiloto</span>.</span>
        <span class="hero-line hero-line-2 ns-line ns-line-2">No un <span class="ns-strike-word">proveedor</span>.</span>
      </h1>

      <p data-wordfade class="ns-lede" data-load="4">Ayudamos a quien tiene un sueño a darle forma y un camino — con tecnología, conocimiento fresco, estructura y un equipo proactivo. Del lado del cliente, hasta que el resultado funciona.</p>

      <div class="ns-hero-cta" data-load="5">
        <a href={calLink} target="_blank" rel="noopener" data-magnetic="0.3" class="ns-btn ns-btn--primary btn-shine btn-pop group">
          Agenda una exploración
          <span class="ns-btn-ico"><svg data-arrow class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path></svg></span>
        </a>
        <a href="#manifiesto" class="ns-btn ns-btn--ghost">Lee el manifiesto</a>
      </div>
    </div>

    <div class="ns-hero-curve parallax" data-parallax="10" aria-hidden="true">
      <Curve variant="hero" draw="scroll" stroke={2.5} class="w-full h-full" />
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- MANIFIESTO — Sí es / No es (díptico kinético)                -->
  <!-- ============================================================ -->
  <section id="manifiesto" class="ns-ledger">
    <div class="ns-ledger-head">
      <p class="ns-tag">Posicionamiento</p>
      <h2 class="ns-h2 reveal">
        <span class="word-before">Claros</span> <span class="word-after">en lo que somos.</span>
      </h2>
      <p class="ns-ledger-sub reveal reveal-d1">Dos columnas. Una promesa y sus límites. Lo que hacemos — y lo que nunca vamos a ser.</p>
    </div>

    <div class="ns-ledger-grid">
      <!-- SÍ — presencia -->
      <div class="ns-panel ns-panel--yes reveal">
        <div class="ns-panel-head">
          <span class="ns-panel-glyph ns-panel-glyph--yes" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"></path></svg>
          </span>
          <span class="ns-panel-word">Sí es</span>
        </div>
        <ul class="ns-list">
          {siEs.map((item, i) => (
            <li class={`ns-item ns-item--yes reveal reveal-d${i + 1}`}>
              <span class="ns-item-idx" aria-hidden="true">{`0${i + 1}`}</span>
              <span class="ns-item-text">{item}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- NO — ausencia (tachado, en retirada) -->
      <div class="ns-panel ns-panel--no reveal reveal-d2">
        <div class="ns-panel-head">
          <span class="ns-panel-glyph ns-panel-glyph--no" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path></svg>
          </span>
          <span class="ns-panel-word">No es</span>
        </div>
        <ul class="ns-list">
          {noEs.map((item, i) => (
            <li class={`ns-item ns-item--no reveal reveal-d${i + 1}`}>
              <span class="ns-item-idx" aria-hidden="true">{`0${i + 1}`}</span>
              <span class="ns-item-text"><s>{item}</s></span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- MISIÓN / VISIÓN — clímax oscuro y atmosférico               -->
  <!-- ============================================================ -->
  <section class="ns-vision surface-ink grain" data-anim-gate>
    <Curve variant="band" draw="scroll" stroke={1.4} class="pointer-events-none absolute inset-x-0 top-0 w-full h-[16vh] opacity-25" />
    <div class="ns-vision-atmos" aria-hidden="true">
      <div class="parallax" data-parallax="34"><div class="glow-orb ns-orb-c"></div></div>
      <div class="parallax" data-parallax="-22"><div class="glow-orb ns-orb-d"></div></div>
    </div>

    <div class="ns-vision-inner">
      <p class="ns-tag ns-tag--onink reveal">Hacia dónde vamos</p>
      <h2 class="ns-vision-lead reveal reveal-d1">
        Liberar a fundadores y equipos para <span class="curve-text-live">crecer con orden</span>.
      </h2>

      <div class="ns-vision-grid">
        <article class="ns-vblock reveal reveal-d1">
          <span class="ns-vblock-num" aria-hidden="true">01</span>
          <p class="ns-vblock-label">Misión</p>
          <p class="ns-vblock-body">Que el dueño recupere <span class="ns-hl">claridad y control</span>, y que la empresa crezca sin depender de él. Con sistemas, automatización y acompañamiento de verdad, hasta que jala solo.</p>
        </article>

        <article class="ns-vblock reveal reveal-d2">
          <span class="ns-vblock-num" aria-hidden="true">02</span>
          <p class="ns-vblock-label">Visión</p>
          <p class="ns-vblock-body">Ser la consultora de referencia en <span class="ns-hl">Latinoamérica</span> en transformación digital y de negocio para empresas en crecimiento.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- CERCANÍA — el diferenciador como manifiesto numerado        -->
  <!-- ============================================================ -->
  <section class="ns-close">
    <div class="ns-close-head">
      <p class="ns-tag">Lo que nos hace distintos</p>
      <h2 class="ns-h2 reveal ns-close-title">
        <span class="word-before">La cercanía</span> <span class="word-after">no es un extra. Es como trabajamos.</span>
      </h2>
    </div>

    <ol class="ns-path">
      {cercania.map((c, i) => (
        <li class={`ns-step reveal reveal-d${i + 1}`}>
          <div class="ns-step-rail" aria-hidden="true">
            <span class="ns-step-node">{`0${i + 1}`}</span>
          </div>
          <div class="ns-step-body">
            <h3 class="ns-step-title">{c.t}</h3>
            <p class="ns-step-desc">{c.d}</p>
          </div>
        </li>
      ))}
    </ol>
  </section>

  <!-- ============================================================ -->
  <!-- CTA                                                          -->
  <!-- ============================================================ -->
  <section class="ns-cta surface-ink grain">
    <span class="ns-cta-ghost parallax" data-parallax="10" aria-hidden="true">hablemos</span>
    <div class="ns-cta-atmos" aria-hidden="true">
      <div class="parallax" data-parallax="28"><div class="glow-orb ns-orb-e"></div></div>
      <div class="parallax" data-parallax="-18"><div class="glow-orb ns-orb-f"></div></div>
    </div>
    <div class="ns-cta-inner reveal">
      <h2 class="ns-cta-title">Cuéntanos de tu empresa.</h2>
      <p class="ns-cta-sub">Media hora, sin compromiso. Te decimos derecho si te podemos ayudar.</p>
      <a href={calLink} target="_blank" rel="noopener" data-magnetic="0.35" class="ns-btn ns-btn--primary ns-btn--lg btn-shine btn-pop group">
        Agendar llamada de exploración
        <span class="ns-btn-ico"><svg data-arrow class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path></svg></span>
      </a>
    </div>
    <Curve variant="band" draw="scroll" stroke={1.6} class="ns-cta-curve" />
  </section>

  <a href={waLink} target="_blank" rel="noopener" class="fixed bottom-6 right-6 z-50 w-14 h-14 bg-[#25D366] rounded-full flex items-center justify-center shadow-lg hover:scale-105 transition-all" aria-label="Contactar por WhatsApp">
    <svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"></path></svg>
  </a>

  </main>

  <Footer calLink={calLink} waLink={waLink} />
</BaseLayout>

<style>
  /* ============================================================
     NOSOTROS — manifiesto editorial-kinético
     Todo scoped. Tokens y utilidades de marca vienen de global.css.
     ============================================================ */
  .ns {
    --ns-ease: var(--ease-pitch);
    --ns-ink: var(--color-ink);
    --ns-line: color-mix(in srgb, var(--color-ink) 12%, transparent);
  }

  .ns-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.24em;
    font-size: 0.68rem;
    font-weight: 600;
    color: var(--color-ember);
  }
  .ns-tag::before {
    content: "";
    width: 1.9rem;
    height: 1px;
    background: currentColor;
    opacity: 0.55;
  }
  .ns-tag--onink { color: var(--color-ember-300); }

  /* ----------------------------- HERO ----------------------------- */
  .ns-hero {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    padding: clamp(8.5rem, 18vh, 12rem) 1.5rem clamp(5rem, 12vh, 8rem);
    background: linear-gradient(180deg, #ffffff 0%, var(--color-sand-50) 58%, #eaf1ff 100%);
  }
  @media (min-width: 640px) { .ns-hero { padding-inline: 2.5rem; } }

  .ns-hero-atmos { position: absolute; inset: 0; z-index: -1; pointer-events: none; }
  .ns-hero-mesh {
    position: absolute; inset: -10%;
    background:
      radial-gradient(46% 40% at 82% 8%, rgba(56, 189, 248, 0.20), transparent 62%),
      radial-gradient(50% 46% at 6% 20%, rgba(37, 99, 235, 0.16), transparent 64%),
      radial-gradient(42% 38% at 96% 92%, rgba(147, 197, 253, 0.20), transparent 62%);
  }
  .ns-orb-a { width: 34rem; height: 34rem; top: -10rem; right: -8rem; background: radial-gradient(circle, rgba(37,99,235,0.16), transparent 70%); }
  .ns-orb-b { width: 26rem; height: 26rem; bottom: -6rem; left: -6rem; background: radial-gradient(circle, rgba(56,189,248,0.16), transparent 70%); animation-delay: -6s; }

  /* Palabra fantasma detrás del titular */
  .ns-ghost {
    position: absolute;
    z-index: -1;
    top: clamp(6rem, 14vh, 10rem);
    right: -0.08em;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(6rem, 22vw, 20rem);
    letter-spacing: -0.05em;
    line-height: 0.8;
    color: transparent;
    -webkit-text-stroke: 1px color-mix(in srgb, var(--color-ember) 16%, transparent);
    pointer-events: none;
    user-select: none;
    white-space: nowrap;
  }

  /* Etiqueta vertical de manifiesto */
  .ns-rail {
    position: absolute;
    top: 50%; right: clamp(1rem, 2.5vw, 2.4rem);
    transform: translateY(-50%) rotate(180deg);
    writing-mode: vertical-rl;
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.42em;
    font-size: 0.66rem;
    font-weight: 600;
    color: var(--color-sand-400);
  }
  @media (max-width: 900px) { .ns-rail { display: none; } }

  .ns-hero-inner { position: relative; max-width: 72rem; margin-inline: auto; }

  .ns-kicker {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.82rem;
    letter-spacing: -0.01em;
    color: var(--color-sand-600);
    margin-bottom: clamp(1.4rem, 3vh, 2.2rem);
  }
  .ns-kicker-dot {
    width: 8px; height: 8px; border-radius: 999px;
    background: var(--color-ember);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--color-ember) 14%, transparent);
  }

  .ns-h1 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2.9rem, 8.4vw, 6.4rem);
    line-height: 0.94;
    letter-spacing: -0.035em;
    color: var(--ns-ink);
    text-wrap: balance;
    max-width: 16ch;
  }
  .ns-line { display: block; }
  .ns-line-2 { color: var(--color-sand-500); font-weight: 300; }
  .ns-line-2 .ns-strike-word {
    position: relative;
    color: var(--ns-ink);
    font-weight: 700;
    white-space: nowrap;
  }
  .ns-line-2 .ns-strike-word::after {
    content: "";
    position: absolute;
    left: -0.04em; right: -0.04em;
    top: 54%;
    height: 0.07em;
    background: var(--color-ember);
    border-radius: 2px;
    transform: scaleX(0);
    transform-origin: left;
    animation: ns-strike 0.7s var(--ns-ease) both 1.05s;
  }
  @keyframes ns-strike { to { transform: scaleX(1); } }

  .ns-lede {
    margin-top: clamp(1.8rem, 3.5vh, 2.6rem);
    max-width: 46ch;
    font-size: clamp(1.15rem, 1.9vw, 1.5rem);
    line-height: 1.42;
    font-weight: 450;
    color: var(--color-sand-700);
    text-wrap: pretty;
  }

  .ns-hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: clamp(2rem, 4vh, 2.8rem);
  }

  .ns-hero-curve {
    position: absolute;
    left: 0; right: 0; bottom: -1px;
    height: clamp(6rem, 12vh, 10rem);
    z-index: -1;
    opacity: 0.7;
    pointer-events: none;
  }
  .ns-hero-curve :global(svg) { width: 100%; height: 100%; }

  /* ----------------------------- Botones ----------------------------- */
  .ns-btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.98rem;
    letter-spacing: -0.01em;
    padding: 0.92rem 1.5rem;
    border-radius: 999px;
    transition: background-color 0.3s ease, color 0.3s ease, box-shadow 0.3s ease;
  }
  .ns-btn--primary {
    background: var(--color-ember);
    color: #fff;
    box-shadow: 0 14px 30px -14px color-mix(in srgb, var(--color-ember) 80%, transparent);
  }
  .ns-btn--primary:hover { background: var(--color-ember-600); }
  .ns-btn--ghost {
    color: var(--ns-ink);
    border: 1px solid var(--ns-line);
    background: color-mix(in srgb, #fff 60%, transparent);
    -webkit-backdrop-filter: blur(6px);
    backdrop-filter: blur(6px);
  }
  .ns-btn--ghost:hover { border-color: color-mix(in srgb, var(--color-ember) 45%, transparent); color: var(--color-ember); }
  .ns-btn--lg { font-size: 1.02rem; padding: 1rem 1.7rem; }
  .ns-btn-ico {
    display: grid; place-items: center;
    width: 1.65rem; height: 1.65rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.18);
    margin-right: -0.35rem;
    transition: transform 0.35s var(--ns-ease);
  }
  @media (hover: hover) and (pointer: fine) {
    .ns-btn--primary.group:hover .ns-btn-ico { transform: translateX(2px); }
  }

  /* ----------------------------- LEDGER — díptico Sí / No ----------------------------- */
  .ns-ledger {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    padding: clamp(5rem, 13vh, 9rem) 1.5rem;
    background: linear-gradient(180deg, #fff 0%, var(--color-sand-50) 100%);
    border-top: 1px solid var(--ns-line);
  }
  @media (min-width: 640px) { .ns-ledger { padding-inline: 2.5rem; } }

  .ns-ledger-head { position: relative; max-width: 72rem; margin-inline: auto; margin-bottom: clamp(2.5rem, 6vh, 4.5rem); }
  .ns-h2 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2.1rem, 5.2vw, 4rem);
    line-height: 1.02;
    letter-spacing: -0.03em;
    color: var(--ns-ink);
    margin-top: 1.1rem;
    text-wrap: balance;
  }
  .ns-h2 .word-after { color: var(--color-sand-500); font-weight: 400; }
  .ns-ledger-sub {
    margin-top: 1.3rem;
    max-width: 48ch;
    font-size: 1.08rem;
    line-height: 1.5;
    color: var(--color-sand-600);
  }

  .ns-ledger-grid {
    position: relative;
    max-width: 72rem;
    margin-inline: auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1.25rem, 3vw, 2rem);
  }
  @media (min-width: 880px) {
    .ns-ledger-grid { grid-template-columns: 1fr 1fr; gap: clamp(1.5rem, 3vw, 2.5rem); align-items: start; }
  }

  .ns-panel {
    position: relative;
    border-radius: 1.25rem;
    padding: clamp(1.6rem, 3vw, 2.5rem);
    border: 1px solid var(--ns-line);
    overflow: hidden;
  }
  .ns-panel--yes {
    background: linear-gradient(180deg, color-mix(in srgb, var(--color-ember) 6%, #fff) 0%, #fff 60%);
    border-color: color-mix(in srgb, var(--color-ember) 22%, var(--color-sand-200));
  }
  /* barra firma arriba = "presencia" del sí */
  .ns-panel--yes::before {
    content: "";
    position: absolute;
    inset: 0 0 auto 0;
    height: 3px;
    background: var(--gradient-curve);
  }
  .ns-panel--no { background: color-mix(in srgb, var(--color-sand-100) 45%, #fff); }

  .ns-panel-head { display: flex; align-items: center; gap: 0.8rem; margin-bottom: 1.5rem; }
  .ns-panel-glyph { display: grid; place-items: center; width: 2.1rem; height: 2.1rem; border-radius: 999px; flex: none; }
  .ns-panel-glyph svg { width: 1.05rem; height: 1.05rem; }
  .ns-panel-glyph--yes {
    background: var(--color-ember); color: #fff;
    box-shadow: 0 10px 20px -8px color-mix(in srgb, var(--color-ember) 80%, transparent);
  }
  .ns-panel-glyph--no { background: var(--color-sand-200); color: var(--color-sand-500); }
  .ns-panel-word {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.4rem;
    letter-spacing: -0.02em;
