---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Curve from '../components/Curve.astro';
import { Picture } from 'astro:assets';
import andresImg from '../assets/andres.jpg';
import ivanaImg from '../assets/ivana.jpg';

const calLink = 'https://cal.com/andres-paez/30min';
const waLink = 'https://wa.me/5215611846200?text=Hola%2C%20me%20interesa%20saber%20m%C3%A1s%20sobre%20CURVA';

const siEs = [
  'Consultora de transformación operativa y digital.',
  'Aliado cercano de los fundadores.',
  'Diseñador de sistemas internos.',
  'Socio para empresas que ya crecieron, pero necesitan orden.',
];
const noEs = [
  'Agencia de marketing generalista.',
  'Software house tradicional.',
  'Consultora abstracta sin implementación.',
  'Un parche para negocios que todavía no venden.',
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: 'Nosotros — CURVA',
  description: 'Quiénes somos, en qué creemos y hacia dónde vamos.',
};
---

<BaseLayout title="Nosotros — CURVA" description="Quiénes somos, en qué creemos y hacia dónde vamos. Una consultora de transformación operativa y digital para empresas en crecimiento." jsonLd={jsonLd}>
  <Nav calLink={calLink} />

  <!-- HERO -->
  <section class="pt-36 pb-20 sm:pt-44 sm:pb-28 px-6 sm:px-10 bg-sand-50 relative overflow-hidden">
    <div class="mx-auto max-w-7xl relative z-10">
      <p class="reveal eyebrow text-ember mb-5">Nosotros</p>
      <h1 class="reveal display text-4xl sm:text-5xl lg:text-6xl font-semibold tracking-tight leading-[1.05] text-ink max-w-3xl">Un aliado cercano para fundadores que quieren crecer con orden.</h1>
    </div>
    <Curve variant="divider" draw="scroll" class="pointer-events-none absolute -bottom-2 inset-x-0 w-full h-20 opacity-60" />
  </section>

  <!-- POSICIONAMIENTO -->
  <section class="py-24 sm:py-32 px-6 sm:px-10 bg-white border-t border-sand-200">
    <div class="mx-auto max-w-7xl grid lg:grid-cols-[minmax(0,0.85fr)_minmax(0,1.15fr)] gap-12 lg:gap-24">
      <div class="lg:sticky lg:top-28 self-start">
        <p class="eyebrow text-ember mb-5">Posicionamiento</p>
        <h2 class="display text-3xl sm:text-4xl lg:text-5xl font-semibold tracking-tight leading-[1.08] text-ink">Claros en lo que somos.</h2>
      </div>
      <div class="grid sm:grid-cols-2 gap-12">
        <div>
          <h3 class="display text-lg font-semibold mb-6 flex items-center gap-2 text-ink"><span class="w-6 h-6 rounded-full bg-gold/15 flex items-center justify-center"><svg class="w-3.5 h-3.5 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"></path></svg></span>Sí es</h3>
          <ul class="space-y-5">
            {siEs.map((item) => (<li class="text-[15px] text-sand-800 leading-relaxed border-l-2 border-gold/30 pl-4">{item}</li>))}
          </ul>
        </div>
        <div>
          <h3 class="display text-lg font-semibold mb-6 flex items-center gap-2 text-ink"><span class="w-6 h-6 rounded-full bg-rose-500/12 flex items-center justify-center"><svg class="w-3.5 h-3.5 text-rose-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path></svg></span>No es</h3>
          <ul class="space-y-5">
            {noEs.map((item) => (<li class="text-[15px] text-sand-500 leading-relaxed border-l-2 border-rose-200 pl-4">{item}</li>))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- MISIÓN / VISIÓN -->
  <section class="surface-ink text-sand-50 py-28 sm:py-36 px-6 sm:px-10">
    <div class="mx-auto max-w-7xl">
      <p class="reveal eyebrow text-ember-300 mb-7">Hacia dónde vamos</p>
      <h2 class="reveal display text-3xl sm:text-4xl lg:text-[3.4rem] font-semibold leading-[1.08] max-w-4xl">Liberar a fundadores y equipos para <span class="curve-text">crecer con orden</span>.</h2>
      <div class="mt-20 grid md:grid-cols-2 gap-12 lg:gap-20 border-t border-white/12 pt-14">
        <div>
          <p class="eyebrow text-sand-400 mb-4">Misión</p>
          <p class="text-lg sm:text-xl text-sand-300 leading-relaxed">Que el dueño recupere <span class="text-sand-50">claridad y control</span>, y que la empresa crezca sin depender de él. Con sistemas, automatización y acompañamiento de verdad —hasta que jala solo.</p>
        </div>
        <div>
          <p class="eyebrow text-sand-400 mb-4">Visión</p>
          <p class="text-lg sm:text-xl text-sand-300 leading-relaxed">Ser la consultora de referencia en <span class="text-sand-50">Latinoamérica</span> en transformación operativa y digital para empresas en crecimiento.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- EQUIPO -->
  <section class="py-24 sm:py-32 px-6 sm:px-10 bg-white">
    <div class="mx-auto max-w-7xl grid lg:grid-cols-[minmax(0,0.65fr)_minmax(0,1.35fr)] gap-12 lg:gap-24">
      <div class="lg:sticky lg:top-28 self-start">
        <p class="eyebrow text-ember mb-5">Equipo</p>
        <h2 class="display text-3xl sm:text-4xl lg:text-5xl font-semibold tracking-tight leading-[1.08] text-ink">Quiénes están detrás.</h2>
      </div>
      <div class="grid sm:grid-cols-2 gap-10">
        <div class="reveal">
          <div class="w-full aspect-[4/5] overflow-hidden rounded-3xl bg-sand-100 mb-5 shadow-lg"><Picture src={andresImg} formats={['avif', 'webp']} alt="Andrés Páez Cortazar" width={640} height={800} class="w-full h-full object-cover object-top" loading="lazy" /></div>
          <h3 class="display font-semibold text-lg text-ink">Andrés Páez Cortazar</h3>
          <p class="text-ember text-sm font-semibold mb-2">Fundador</p>
          <p class="text-sand-600 text-[15px] leading-relaxed">Estrategia y Transformación de Negocios, Tec de Monterrey. IA aplicada a negocios. Ponente en Global Money Week 2025 (OECD).</p>
        </div>
        <div class="reveal reveal-d1">
          <div class="w-full aspect-[4/5] overflow-hidden rounded-3xl bg-sand-100 mb-5 shadow-lg"><Picture src={ivanaImg} formats={['avif', 'webp']} alt="Ivana Garduño Mayo" width={640} height={800} class="w-full h-full object-cover object-top" loading="lazy" /></div>
          <h3 class="display font-semibold text-lg text-ink">Ivana Garduño Mayo</h3>
          <p class="text-ember text-sm font-semibold mb-2">Co-Founder</p>
          <p class="text-sand-600 text-[15px] leading-relaxed">Organización y ejecución de proyectos de transformación. Gobernanza y estructura organizacional.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="surface-ink text-sand-50 py-24 sm:py-32 px-6 sm:px-10">
    <div class="reveal mx-auto max-w-3xl text-center">
      <h2 class="display text-3xl sm:text-4xl lg:text-5xl font-semibold tracking-tight leading-[1.06]">Cuéntanos de tu empresa.</h2>
      <a href={calLink} target="_blank" rel="noopener" class="btn-shine group mt-8 inline-flex items-center gap-2 text-base font-semibold bg-ember text-white px-8 py-4 rounded-full hover:bg-ember-600 transition-all hover:gap-3">
        Agendar llamada de exploración
        <svg class="w-4 h-4 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path></svg>
      </a>
    </div>
  </section>

  <a href={waLink} target="_blank" rel="noopener" class="fixed bottom-6 right-6 z-50 w-14 h-14 bg-[#25D366] rounded-full flex items-center justify-center shadow-lg hover:scale-105 transition-all" aria-label="Contactar por WhatsApp">
    <svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"></path></svg>
  </a>

  <Footer calLink={calLink} waLink={waLink} />
</BaseLayout>
