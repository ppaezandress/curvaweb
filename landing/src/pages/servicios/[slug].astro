---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import Curve from '../../components/Curve.astro';
import VideoReel from '../../components/VideoReel.astro';
import { servicios, prevNext } from '../../data/servicios';

export function getStaticPaths() {
  return servicios.map((s) => ({ params: { slug: s.slug }, props: { servicio: s } }));
}

const { servicio: s } = Astro.props;
const { prev, next } = prevNext(s.slug);

const calLink = 'https://cal.com/andres-paez/30min';
const waLink = 'https://wa.me/5215611846200?text=Hola%2C%20me%20interesa%20saber%20m%C3%A1s%20sobre%20CURVA';

// jade remapeado a azul (gold) — paleta v2 morado+azul, sin esmeralda.
const accentText = { ember: 'text-ember', gold: 'text-gold', jade: 'text-gold' } as const;
const accentBar = { ember: 'bg-ember', gold: 'bg-gold', jade: 'bg-gold' } as const;
const accentSoft = { ember: 'bg-ember/12', gold: 'bg-gold/12', jade: 'bg-gold/12' } as const;

const origin = (Astro.site ?? new URL(Astro.url.origin)).origin;
const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'Service', name: s.title, description: s.description, serviceType: s.tagline, areaServed: 'México', provider: { '@type': 'ProfessionalService', name: 'CURVA', url: origin } },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: origin + '/' },
    { '@type': 'ListItem', position: 2, name: 'Servicios', item: origin + '/#servicios' },
    { '@type': 'ListItem', position: 3, name: s.navLabel, item: origin + '/servicios/' + s.slug },
  ] },
];
---

<BaseLayout title={`${s.title} — CURVA`} description={s.description} jsonLd={jsonLd}>
  <Nav calLink={calLink} />

  <!-- ============== HERO ============== -->
  <section class="pt-32 sm:pt-36 pb-16 px-6 sm:px-10 bg-sand-50 relative overflow-hidden">
    <div class="mx-auto max-w-7xl relative z-10">
      <nav aria-label="Migas" class="reveal flex items-center gap-2 text-sm text-sand-500 mb-10">
        <a href="/" class="hover:text-ink transition-colors">Inicio</a>
        <span class="text-sand-300">/</span>
        <a href="/#servicios" class="hover:text-ink transition-colors">Servicios</a>
        <span class="text-sand-300">/</span>
        <span class="text-ink font-medium">{s.navLabel}</span>
      </nav>
      <div class="grid lg:grid-cols-[1.25fr_0.75fr] gap-10 lg:gap-16 items-start">
        <div>
          <p class={`reveal eyebrow mb-4 ${accentText[s.accent]}`}>{s.tagline}</p>
          <h1 class="reveal display text-4xl sm:text-5xl lg:text-[3.6rem] font-semibold tracking-tight leading-[1.04] mb-6 text-ink">{s.headline}</h1>
          <p class="reveal text-lg sm:text-xl text-sand-600 leading-relaxed max-w-2xl">{s.description}</p>
          <div class="reveal mt-8 flex flex-col sm:flex-row gap-3">
            <a href={calLink} target="_blank" rel="noopener" class="btn-pop group inline-flex items-center justify-center gap-2 text-base font-semibold bg-ember text-white px-7 py-4 rounded-full hover:bg-ember-600 hover:gap-3">
              Agendar llamada de exploración
              <svg class="w-4 h-4 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path></svg>
            </a>
          </div>
        </div>
        <div class="reveal reveal-scale reveal-d1 lg:pt-1">
          <div class="lift rounded-3xl border border-sand-200 bg-white p-6 sm:p-7">
            <p class="eyebrow text-sand-400 mb-4">Qué incluye</p>
            <div class="flex flex-wrap gap-2">
              {s.tags.map((tag) => (<span class="px-3.5 py-1.5 bg-sand-50 rounded-full text-[13px] font-medium text-sand-700 border border-sand-200">{tag}</span>))}
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="parallax pointer-events-none absolute -bottom-2 inset-x-0" data-parallax="16">
      <Curve variant="divider" draw="scroll" class="w-full h-20 opacity-60" />
    </div>
  </section>

  {s.video && (
    <section data-video-wrap class="surface-ink text-sand-50 py-20 sm:py-24 px-6 sm:px-10">
      <div class="mx-auto max-w-7xl grid lg:grid-cols-2 gap-10 lg:gap-16 items-center">
        <div class="space-y-5 order-2 lg:order-1">
          <p class={`eyebrow ${accentText[s.accent]}`}>{s.video.eyebrow}</p>
          <h2 class="display text-3xl sm:text-4xl font-semibold leading-snug">{s.video.title}</h2>
          <p class="text-sand-300 text-lg leading-relaxed">{s.video.desc}</p>
        </div>
        <div class="flex justify-center order-1 lg:order-2">
          <div class="w-[240px] sm:w-[280px] aspect-[9/16] rounded-3xl overflow-hidden shadow-2xl bg-black relative">
            <VideoReel src={s.video.src} class="w-full h-full object-cover" />
            <button data-audio-toggle aria-label="Activar o silenciar audio" class="absolute bottom-4 right-4 w-10 h-10 rounded-full bg-white/90 flex items-center justify-center shadow-lg transition-transform hover:scale-110">
              <svg data-audio-icon class="w-5 h-5 text-ink" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z"></path><path stroke-linecap="round" stroke-linejoin="round" d="M17 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2"></path></svg>
              <svg data-audio-icon class="w-5 h-5 text-ink hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z"></path><path stroke-linecap="round" stroke-linejoin="round" d="M15.536 8.464a5 5 0 010 7.072m2.828-9.9a9 9 0 010 12.728"></path></svg>
            </button>
          </div>
        </div>
      </div>
    </section>
  )}

  {s.bloques && (
    <section class="py-20 sm:py-24 px-6 sm:px-10 bg-white border-t border-sand-200">
      <div class="mx-auto max-w-7xl">
        <p class="reveal eyebrow text-sand-400 mb-10">{s.bloques.title}</p>
        <div class="grid sm:grid-cols-2 gap-5">
          {s.bloques.items.map((b, i) => (
            <div class={`reveal reveal-d${Math.min(i + 1, 4)} lift surface-ink text-sand-50 p-8 rounded-3xl`}>
              <p class="display font-semibold text-lg mb-2">{b.title}</p>
              <p class="text-[15px] text-sand-300 leading-relaxed">{b.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  {s.herramientas && (
    <section class="py-20 sm:py-24 px-6 sm:px-10 bg-white border-t border-sand-200">
      <div class="mx-auto max-w-7xl">
        <p class="reveal eyebrow text-sand-400 mb-10">{s.herramientas.title}</p>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
          {s.herramientas.items.map((h, i) => (
            <div class={`reveal reveal-d${Math.min(i + 1, 4)} lift bg-sand-50 border border-sand-200 rounded-2xl p-6 text-center`}>
              <p class="font-bold text-ink">{h.name}</p>
              <p class="text-xs text-sand-500 mt-1">{h.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  {s.incluye && (
    <section class="py-20 sm:py-24 px-6 sm:px-10 bg-white border-t border-sand-200">
      <div class="mx-auto max-w-7xl">
        <p class="reveal eyebrow text-sand-400 mb-10">{s.incluye.title}</p>
        <div class="grid sm:grid-cols-2 gap-5">
          {s.incluye.items.map((b, i) => (
            <div class={`reveal reveal-d${Math.min(i + 1, 4)} lift bg-sand-50 border border-sand-200 p-8 rounded-3xl`}>
              <p class="display font-semibold text-lg mb-2 text-ink">{b.title}</p>
              <p class="text-[15px] text-sand-600 leading-relaxed">{b.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  {s.proceso && (
    <section class="surface-ink-soft text-sand-50 py-20 sm:py-24 px-6 sm:px-10">
      <div class="mx-auto max-w-7xl">
        <p class={`eyebrow mb-12 ${accentText[s.accent]}`}>{s.proceso.title}</p>
        <div class={`grid gap-x-8 gap-y-12 ${s.proceso.pasos.length === 3 ? 'sm:grid-cols-3' : 'sm:grid-cols-2'}`}>
          {s.proceso.pasos.map((p) => (
            <div>
              <p class="display curve-text text-5xl font-semibold mb-5">{p.num}</p>
              <div class="border-t border-white/15 pt-5">
                {p.title && <p class="display font-semibold text-lg mb-2">{p.title}</p>}
                <p class="text-[15px] text-sand-300 leading-relaxed">{p.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  {s.resultados && (
    <section class="surface-ink text-sand-50 py-20 sm:py-24 px-6 sm:px-10">
      <div class="mx-auto max-w-7xl">
        <p class={`eyebrow mb-12 ${accentText[s.accent]}`}>{s.resultados.title}</p>
        <div class="grid sm:grid-cols-3 gap-10">
          {s.resultados.items.map((m, i) => (
            <div class={`reveal reveal-d${Math.min(i + 1, 4)} border-t border-white/15 pt-6`}>
              <p data-count={m.value} class="display text-5xl sm:text-6xl font-semibold curve-text">{m.value}</p>
              <p class="text-base text-sand-300 mt-3">{m.label}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  {s.casoDestacado && (
    <section class="surface-ink-soft text-sand-50 py-20 sm:py-24 px-6 sm:px-10">
      <div class="mx-auto max-w-7xl grid lg:grid-cols-2 gap-10 lg:gap-16 items-center">
        <div>
          <p class={`eyebrow mb-4 ${accentText[s.accent]}`}>{s.casoDestacado.label}</p>
          <h2 class="display text-3xl sm:text-4xl font-semibold mb-4 leading-snug">{s.casoDestacado.title}</h2>
          <p class="text-lg text-sand-300 leading-relaxed">{s.casoDestacado.desc}</p>
        </div>
        {s.casoDestacado.metrics && (
          <div class="grid grid-cols-3 gap-6">
            {s.casoDestacado.metrics.map((m) => (
              <div class="border-t border-white/15 pt-5"><p data-count={m.value} class="display text-3xl sm:text-4xl font-semibold curve-text">{m.value}</p><p class="text-sm text-sand-400 mt-2">{m.label}</p></div>
            ))}
          </div>
        )}
      </div>
    </section>
  )}

  {s.casos && (
    <section class="py-20 sm:py-24 px-6 sm:px-10 bg-white border-t border-sand-200">
      <div class="mx-auto max-w-7xl">
        <p class="reveal eyebrow text-sand-400 mb-10">{s.casos.title}</p>
        <div class="grid sm:grid-cols-2 gap-6">
          {s.casos.items.map((c, i) => (
            <div class={`reveal reveal-d${Math.min(i + 1, 4)} lift surface-ink text-sand-50 p-8 sm:p-9 rounded-3xl`}>
              <p class={`eyebrow mb-3 ${accentText[s.accent]}`}>Caso</p>
              <p class="display font-semibold text-xl mb-2">{c.name}</p>
              <p class="text-[15px] text-sand-300 leading-relaxed mb-5">{c.desc}</p>
              <div class="flex gap-2 flex-wrap mb-5">
                {c.tags.map((t) => (<span class="px-2.5 py-1 rounded-full bg-white/10 text-[11px] font-medium text-sand-200">{t}</span>))}
              </div>
              {c.links && (
                <div class="flex gap-5">
                  {c.links.map((l) => (<a href={l.href} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-sm font-semibold text-sand-50 hover:text-sand-300 transition-colors">{l.label} →</a>))}
                </div>
              )}
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  {s.galeria && (
    <section class="py-20 sm:py-24 px-6 sm:px-10 bg-white border-t border-sand-200">
      <div class="mx-auto max-w-7xl">
        <p class="reveal eyebrow text-sand-400 mb-8">{s.galeria.title}</p>
        <div data-showcase class="flex gap-4 overflow-x-auto pb-4 snap-x snap-mandatory scrollbar-hide">
          {s.galeria.items.map((v) => (
            <div class="snap-start flex-shrink-0 flex flex-col items-center gap-2">
              <div class="w-[200px] sm:w-[240px] aspect-[9/16] rounded-3xl overflow-hidden bg-black shadow-xl">
                <VideoReel src={v.src} class="w-full h-full object-cover" />
              </div>
              <p class="text-xs font-semibold text-sand-500">{v.label}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  {s.senales && (
    <section class="py-20 sm:py-24 px-6 sm:px-10 bg-sand-50 border-t border-sand-200">
      <div class="mx-auto max-w-7xl grid lg:grid-cols-[0.9fr_1.1fr] gap-12 lg:gap-24">
        <div class="lg:sticky lg:top-28 self-start">
          <p class={`eyebrow mb-4 ${accentText[s.accent]}`}>Diagnóstico rápido</p>
          <h2 class="display text-3xl sm:text-4xl lg:text-5xl font-semibold tracking-tight leading-[1.06] text-ink">{s.senales.title}</h2>
        </div>
        <ul class="border-t border-sand-200">
          {s.senales.items.map((item, i) => (
            <li class={`reveal reveal-d${Math.min(i + 1, 4)} flex gap-6 items-baseline py-5 border-b border-sand-200`}>
              <span class={`display text-base font-semibold tabular-nums ${accentText[s.accent]}`}>0{i + 1}</span>
              <p class="text-lg sm:text-xl text-ink leading-snug">{item}</p>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <!-- PREV / NEXT -->
  <section class="px-6 sm:px-10 py-14 bg-sand-50 border-t border-sand-200">
    <div class="mx-auto max-w-7xl grid sm:grid-cols-2 gap-4">
      <a href={`/servicios/${prev.slug}`} class="lift group rounded-3xl border border-sand-200 bg-white p-7 hover:border-sand-400">
        <p class="eyebrow text-sand-400 mb-2">Anterior</p>
        <p class="display font-semibold text-ink flex items-center gap-2"><svg class="w-4 h-4 text-sand-400 group-hover:-translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5"></path></svg>{prev.navLabel}</p>
      </a>
      <a href={`/servicios/${next.slug}`} class="lift group rounded-3xl border border-sand-200 bg-white p-7 hover:border-sand-400 sm:text-right">
        <p class="eyebrow text-sand-400 mb-2">Siguiente</p>
        <p class="display font-semibold text-ink flex items-center gap-2 sm:justify-end">{next.navLabel}<svg class="w-4 h-4 text-sand-400 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"></path></svg></p>
      </a>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 sm:py-32 px-6 sm:px-10 surface-ink text-sand-50">
    <div class="reveal mx-auto max-w-3xl text-center">
      <h2 class="display text-3xl sm:text-4xl lg:text-5xl font-semibold tracking-tight leading-[1.06]">{s.cta}</h2>
      <p class="mt-5 text-lg text-sand-300 max-w-md mx-auto">30 minutos. Te decimos derecho si te podemos ayudar o no.</p>
      <a href={calLink} target="_blank" rel="noopener" class="btn-pop group mt-8 inline-flex items-center gap-2 text-base font-semibold bg-ember text-white px-8 py-4 rounded-full hover:bg-ember-600 hover:gap-3">
        Agendar llamada de exploración
        <svg class="w-4 h-4 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path></svg>
      </a>
    </div>
  </section>

  <a href={waLink} target="_blank" rel="noopener" class="fixed bottom-6 right-6 z-50 w-14 h-14 bg-[#25D366] rounded-full flex items-center justify-center shadow-lg hover:scale-105 transition-all" aria-label="Contactar por WhatsApp">
    <svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"></path></svg>
  </a>

  <Footer calLink={calLink} waLink={waLink} />
</BaseLayout>

<style>
  .scrollbar-hide { scrollbar-width: none; -webkit-overflow-scrolling: touch; }
  .scrollbar-hide::-webkit-scrollbar { display: none; }
</style>
