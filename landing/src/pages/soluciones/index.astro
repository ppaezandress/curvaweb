---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import Curve from '../../components/Curve.astro';
import { soluciones } from '../../data/soluciones';

const calLink = 'https://cal.com/andres-paez/30min';
const waLink = 'https://wa.me/5215611846200?text=Hola%2C%20me%20interesa%20saber%20m%C3%A1s%20sobre%20las%20soluciones%20digitales%20de%20CURVA';

const accentText = { ember: 'text-ember', gold: 'text-gold', jade: 'text-gold' } as const;
const accentBar = { ember: 'bg-ember', gold: 'bg-gold', jade: 'bg-gold' } as const;
const accentSoft = { ember: 'bg-ember/12', gold: 'bg-gold/15', jade: 'bg-gold/12' } as const;

// Iconos por tipo de solución (trazo, coherentes con el resto del sitio).
const icons: Record<string, string> = {
  globe: 'M12 21a9 9 0 100-18 9 9 0 000 18zm0 0c2.5-2.5 3.5-6 3.5-9S14.5 5.5 12 3M12 21c-2.5-2.5-3.5-6-3.5-9S9.5 5.5 12 3M3.5 9h17M3.5 15h17',
  cube: 'M21 7.5l-9-5-9 5m18 0l-9 5m9-5v9l-9 5m0-9l-9-5m9 5v9m0-14l9 5',
  claude: 'M12 3v18M5 7l14 10M5 17L19 7',
  notion: 'M5 4h11l3 3v13H5V4zm3 5h8M8 12h8M8 15h5',
  template: 'M4 5h16v4H4V5zm0 8h7v6H4v-6zm11 0h5v6h-5v-6z',
};

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Soluciones digitales — CURVA',
  itemListElement: soluciones.map((s, i) => ({ '@type': 'ListItem', position: i + 1, name: s.titulo })),
};
---

<BaseLayout title="Soluciones digitales — CURVA" description="Páginas web, sistemas y apps a la medida, clases de Claude y Notion, y plantillas listas para comprar. Entregables que puedes tener con un solo aliado." jsonLd={jsonLd}>
  <Nav calLink={calLink} />

  <a href="#web" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:bg-ember focus:text-white focus:px-4 focus:py-2 focus:rounded-full focus:text-sm focus:font-semibold">Saltar al contenido</a>

  <!-- ============== HERO ============== -->
  <section class="surface-ink grain text-sand-50 relative pt-32 sm:pt-40 pb-20 sm:pb-28 px-6 sm:px-10 overflow-hidden">
    <div class="glow-orb" style="width:32rem;height:32rem;top:-8rem;right:-6rem;background:radial-gradient(circle,rgba(37,99,235,0.5),transparent 70%);"></div>
    <div class="glow-orb" style="width:26rem;height:26rem;bottom:-8rem;left:-6rem;background:radial-gradient(circle,rgba(56,189,248,0.4),transparent 70%);animation-delay:-7s;"></div>
    <div class="mx-auto max-w-6xl relative z-10">
      <nav aria-label="Migas" class="reveal flex items-center gap-2 text-sm text-sand-400 mb-8">
        <a href="/" class="hover:text-sand-50 transition-colors">Inicio</a>
        <span class="text-sand-600">/</span>
        <span class="text-sand-100 font-medium">Soluciones digitales</span>
      </nav>
      <p class="reveal eyebrow-lead text-ember-300 mb-5">Soluciones digitales</p>
      <h1 class="reveal display text-4xl sm:text-5xl lg:text-[3.8rem] font-semibold tracking-tight leading-[1.04] max-w-4xl text-balance">Lo construimos nosotros. Tú solo lo usas.</h1>
      <p class="reveal mt-6 text-lg sm:text-xl text-sand-300 leading-relaxed max-w-2xl">Web, sistemas y apps a la medida, clases y plantillas. Desde algo que compras en un clic hasta un sistema complejo hecho de punta a punta — con un solo aliado.</p>
      <div class="reveal mt-9 flex flex-wrap gap-2.5">
        {soluciones.map((s) => (
          <a href={`#${s.id}`} class="inline-flex items-center gap-2 rounded-full border border-white/12 bg-white/[0.04] px-4 py-2 text-sm text-sand-200 hover:border-white/25 hover:bg-white/[0.08] transition-colors">{s.titulo}</a>
        ))}
      </div>
    </div>
    <div class="parallax pointer-events-none absolute -bottom-2 inset-x-0" data-parallax="16">
      <Curve variant="divider" draw="scroll" class="w-full h-20 opacity-40" />
    </div>
  </section>

  <!-- ============== SOLUCIONES ============== -->
  <section class="py-20 sm:py-28 px-6 sm:px-10 bg-white">
    <div class="mx-auto max-w-6xl space-y-6">
      {soluciones.filter((s) => !s.tienda).map((s, i) => (
        <div id={s.id} class={`scroll-mt-24 reveal reveal-d${Math.min(i + 1, 4)} lift rounded-3xl border border-sand-200 bg-sand-50 p-8 sm:p-10 grid sm:grid-cols-[auto_1fr] gap-6 items-start`}>
          <div class={`w-14 h-14 rounded-2xl ${accentSoft[s.accent]} flex items-center justify-center flex-shrink-0`}>
            <svg class={`w-7 h-7 ${accentText[s.accent]}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6"><path stroke-linecap="round" stroke-linejoin="round" d={icons[s.icon]}></path></svg>
          </div>
          <div>
            <div class="flex flex-wrap items-center gap-3">
              <h2 class="display text-2xl sm:text-3xl font-semibold text-ink">{s.titulo}</h2>
              {s.destacado && <span class={`px-2.5 py-1 rounded-full ${accentSoft[s.accent]} ${accentText[s.accent]} text-[11px] font-semibold uppercase tracking-wide`}>De punta a punta</span>}
            </div>
            <p class="mt-3 text-lg text-sand-600 leading-relaxed max-w-2xl">{s.subtitulo}</p>
            {s.bullets && (
              <ul class="mt-5 flex flex-wrap gap-2">
                {s.bullets.map((b) => (<li class="text-[13px] font-medium text-sand-700 bg-white border border-sand-200 rounded-full px-3 py-1.5">{b}</li>))}
              </ul>
            )}
            {s.cta && (
              <a href={s.cta.href} class={`mt-6 arrow-cta inline-flex items-center gap-2 text-sm font-semibold ${accentText[s.accent]} link-underline`}>
                {s.cta.label}
                <svg data-arrow class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path></svg>
              </a>
            )}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ============== TIENDA DE PLANTILLAS ============== -->
  {soluciones.filter((s) => s.tienda).map((s) => (
    <section id={s.id} class="scroll-mt-24 surface-ink text-sand-50 py-20 sm:py-28 px-6 sm:px-10 border-t border-white/10">
      <div class="mx-auto max-w-6xl">
        <p class="reveal eyebrow-lead text-ember-300 mb-4">Tienda</p>
        <h2 class="reveal display text-3xl sm:text-4xl font-semibold tracking-tight leading-[1.08] text-balance">{s.titulo}</h2>
        <p class="reveal mt-4 text-lg text-sand-300 leading-relaxed max-w-2xl">{s.subtitulo}</p>
        <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {s.plantillas?.map((p, i) => (
            <div class={`reveal reveal-d${Math.min(i + 1, 4)} flex flex-col rounded-3xl border border-white/10 bg-white/[0.04] p-7`}>
              <div class="w-11 h-11 rounded-xl bg-ember/15 flex items-center justify-center mb-5">
                <svg class="w-5 h-5 text-ember-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M4 5h16v4H4V5zm0 8h7v6H4v-6zm11 0h5v6h-5v-6z"></path></svg>
              </div>
              <p class="display font-semibold text-lg text-sand-50">{p.nombre}</p>
              <p class="text-[15px] text-sand-300 leading-relaxed mt-2 flex-1">{p.desc}</p>
              <div class="mt-6 flex items-center justify-between gap-3">
                <span class="display text-xl font-semibold text-sand-50">{p.precio}</span>
                <button
                  type="button"
                  data-comprar={p.id}
                  data-nombre={p.nombre}
                  data-monto={p.precioMXN}
                  class="btn-pop inline-flex items-center gap-2 text-sm font-semibold bg-ember text-white px-5 py-2.5 rounded-full hover:bg-ember-600 whitespace-nowrap"
                >
                  Comprar
                  <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.836L5.383 6m0 0l1.44 6.44a1.5 1.5 0 001.464 1.16h7.09a1.5 1.5 0 001.464-1.16L19.5 6H5.383zM9 20.25a.75.75 0 11-1.5 0 .75.75 0 011.5 0zm8 0a.75.75 0 11-1.5 0 .75.75 0 011.5 0z"></path></svg>
                </button>
              </div>
            </div>
          ))}
        </div>
        <p class="mt-6 text-sm text-sand-400">Pagas aquí mismo, la plantilla te llega a tu correo y lista para usar.</p>
      </div>
    </section>
  ))}

  <!-- ============== CTA FINAL ============== -->
  <section class="py-24 sm:py-32 px-6 sm:px-10 bg-sand-50 border-t border-sand-200">
    <div class="reveal mx-auto max-w-3xl text-center">
      <h2 class="display text-3xl sm:text-4xl lg:text-5xl font-semibold tracking-tight leading-[1.06] text-ink">¿Tienes algo más grande en mente?</h2>
      <p class="mt-5 text-lg text-sand-600 max-w-md mx-auto">Cuéntanos qué necesitas construir y te decimos cómo lo hacemos.</p>
      <a href={calLink} target="_blank" rel="noopener" data-magnetic="0.35" class="btn-shine btn-pop group mt-8 inline-flex items-center gap-2 text-base font-semibold bg-ember text-white px-8 py-4 rounded-full hover:bg-ember-600 hover:gap-3">
        Agendar llamada
        <svg data-arrow class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path></svg>
      </a>
    </div>
  </section>

  <a href={waLink} target="_blank" rel="noopener" class="fixed bottom-6 right-6 z-50 w-14 h-14 bg-[#25D366] rounded-full flex items-center justify-center shadow-lg hover:scale-105 transition-all" aria-label="Contactar por WhatsApp">
    <svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"></path></svg>
  </a>

  <Footer calLink={calLink} waLink={waLink} />
</BaseLayout>
