---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import Curve from '../../components/Curve.astro';
import { soluciones } from '../../data/soluciones';

const calLink = 'https://cal.com/andres-paez/30min';
import { waLink as buildWa } from '../../data/site';
const waLink = buildWa('Hola 👋, me interesa saber más sobre las soluciones digitales de CURVA');

// gold/jade (cian #38bdf8) NO pasan contraste como texto sobre fondo claro → azul (ember).
const accentText = { ember: 'text-ember', gold: 'text-ember', jade: 'text-ember' } as const;
const accentSoft = { ember: 'bg-ember/12', gold: 'bg-gold/15', jade: 'bg-gold/12' } as const;

// Iconos por tipo de solución (trazo, coherentes con el resto del sitio).
const icons: Record<string, string> = {
  globe: 'M12 21a9 9 0 100-18 9 9 0 000 18zm0 0c2.5-2.5 3.5-6 3.5-9S14.5 5.5 12 3M12 21c-2.5-2.5-3.5-6-3.5-9S9.5 5.5 12 3M3.5 9h17M3.5 15h17',
  cube: 'M21 7.5l-9-5-9 5m18 0l-9 5m9-5v9l-9 5m0-9l-9-5m9 5v9m0-14l9 5',
  claude: 'M12 3v18M5 7l14 10M5 17L19 7',
  notion: 'M5 4h11l3 3v13H5V4zm3 5h8M8 12h8M8 15h5',
  template: 'M4 5h16v4H4V5zm0 8h7v6H4v-6zm11 0h5v6h-5v-6z',
};

// Punto de acento por producto (hilo cromático hero → escena).
const dot: Record<string, string> = {
  web: '#2563eb', sistemas: '#38bdf8', 'clases-claude': '#7c3aed',
  'clases-notion': '#2563eb', plantillas: '#38bdf8',
};
// Halo atmosférico detrás de cada escena.
const glow: Record<string, string> = {
  web: 'rgba(37,99,235,0.24)', sistemas: 'rgba(56,189,248,0.26)',
  'clases-claude': 'rgba(124,58,237,0.22)', 'clases-notion': 'rgba(37,99,235,0.20)',
};
// Etiqueta de categoría de la vitrina (no marketing: nombra el medio).
const kicker: Record<string, string> = {
  web: 'Sitio web', sistemas: 'Software a la medida',
  'clases-claude': 'Formación · IA', 'clases-notion': 'Formación · Notion',
};
// Barra de dirección / etiqueta de ventana de cada escena (realismo).
const sceneUrl: Record<string, string> = {
  web: 'curva.mx', sistemas: 'app.operacion.mx',
  'clases-claude': 'claude.ai', 'clases-notion': 'notion.so',
};
// Etiqueta del chip flotante (estado del producto).
const chipLabel: Record<string, string> = {
  web: 'Publicado', sistemas: 'En vivo',
  'clases-claude': 'Claude · IA', 'clases-notion': 'Sincronizado',
};

const showroom = soluciones.filter((s) => !s.tienda);

const origin = (Astro.site ?? new URL(Astro.url.origin)).origin;
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'Soluciones digitales — CURVA',
    itemListElement: soluciones.map((s, i) => ({ '@type': 'ListItem', position: i + 1, name: s.titulo })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Inicio', item: origin + '/' },
      { '@type': 'ListItem', position: 2, name: 'Soluciones digitales', item: origin + '/soluciones' },
    ],
  },
];
---

<BaseLayout title="Soluciones digitales — CURVA" description="Páginas web, sistemas y apps a la medida, clases de Claude y Notion, y plantillas listas para comprar. Entregables que puedes tener con un solo aliado." jsonLd={jsonLd} thread>
  <Nav calLink={calLink} />

  <a href="#contenido" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:bg-ember focus:text-white focus:px-4 focus:py-2 focus:rounded-full focus:text-sm focus:font-semibold">Saltar al contenido</a>

  <main id="contenido" tabindex="-1">

  <!-- ============== HERO — entrada al showroom ============== -->
  <section class="sol-hero surface-ink grain text-sand-50 relative pt-32 sm:pt-40 pb-24 sm:pb-32 px-6 sm:px-10 overflow-hidden">
    <div class="glow-orb" style="width:34rem;height:34rem;top:-10rem;right:-8rem;background:radial-gradient(circle,rgba(37,99,235,0.5),transparent 70%);"></div>
    <div class="glow-orb" style="width:28rem;height:28rem;bottom:-10rem;left:-7rem;background:radial-gradient(circle,rgba(56,189,248,0.42),transparent 70%);animation-delay:-7s;"></div>
    <span aria-hidden="true" class="sol-ghost display">Showroom</span>

    <div class="mx-auto max-w-6xl relative z-10">
      <nav aria-label="Migas" class="reveal flex items-center gap-2 text-sm text-sand-400 mb-8">
        <a href="/" class="hover:text-sand-50 transition-colors">Inicio</a>
        <span class="text-sand-600">/</span>
        <span class="text-sand-100 font-medium">Soluciones digitales</span>
      </nav>
      <p class="reveal eyebrow-lead text-ember-300 mb-6">Soluciones digitales</p>
      <h1 data-wordfade class="reveal display text-[2.6rem] sm:text-6xl lg:text-[5.2rem] font-semibold tracking-[-0.03em] leading-[0.98] max-w-4xl text-balance">Lo construimos nosotros. Tú solo lo usas.</h1>
      <p class="reveal reveal-d1 mt-7 text-lg sm:text-xl text-sand-300 leading-relaxed max-w-2xl text-pretty">Web, sistemas y apps a la medida, clases y plantillas. Desde algo que compras en un clic hasta un sistema complejo hecho de punta a punta — con un solo aliado.</p>

      <!-- Índice del showroom: cada pieza, con su color -->
      <div class="reveal reveal-d2 mt-11 flex flex-wrap items-center gap-2.5">
        <span class="sol-index-label mr-1 hidden sm:inline-flex">El índice</span>
        {soluciones.map((s) => (
          <a href={`#${s.id}`} class="sol-index group inline-flex items-center gap-2.5 rounded-full border border-white/12 bg-white/[0.04] pl-3 pr-3.5 py-2 text-sm text-sand-200 hover:text-white transition-colors">
            <span class="sol-index-dot" style={`--d:${dot[s.id] ?? '#2563eb'}`}></span>
            {s.titulo}
            <svg class="sol-index-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path></svg>
          </a>
        ))}
      </div>
    </div>

    <div class="parallax pointer-events-none absolute -bottom-2 inset-x-0" data-parallax="16">
      <Curve variant="divider" draw="scroll" class="w-full h-20 opacity-40" />
    </div>
  </section>

  <!-- ============== SHOWROOM — cada producto es una escena ============== -->
  <section class="sol-showroom grain py-24 sm:py-32 px-6 sm:px-10 bg-white relative overflow-hidden">
    <div class="sol-amb" style="width:40rem;height:40rem;top:-6rem;left:-12rem;background:radial-gradient(circle,rgba(37,99,235,0.10),transparent 70%);"></div>
    <div class="sol-amb" style="width:34rem;height:34rem;bottom:8rem;right:-14rem;background:radial-gradient(circle,rgba(56,189,248,0.10),transparent 70%);"></div>

    <div class="mx-auto max-w-6xl relative z-10">
      <div class="max-w-2xl mb-16 sm:mb-24">
        <p class="reveal eyebrow-lead text-ember mb-5">El catálogo</p>
        <h2 class="reveal display text-3xl sm:text-5xl font-semibold tracking-[-0.025em] leading-[1.04] text-ink text-balance">Escoge lo que necesitas. Nosotros lo construimos.</h2>
      </div>

      <div class="space-y-28 sm:space-y-40">
        {showroom.map((s, i) => (
          <article
            id={s.id}
            class={`sol-stage scroll-mt-28 grid lg:grid-cols-12 gap-x-10 gap-y-12 items-center ${s.destacado ? 'is-featured' : ''}`}
          >
            {/* ---------- Columna de texto ---------- */}
            <div class={`reveal lg:col-span-5 ${i % 2 === 1 ? 'lg:order-2 lg:pl-4' : 'lg:order-1'}`}>
              <div class="flex items-center gap-3 mb-6">
                <span class={`sol-ico w-11 h-11 rounded-2xl ${accentSoft[s.accent]} flex items-center justify-center flex-shrink-0`}>
                  <svg class={`w-5 h-5 ${accentText[s.accent]}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d={icons[s.icon]}></path></svg>
                </span>
                <span class="text-[11px] font-semibold uppercase tracking-[0.16em] text-sand-500">{kicker[s.id]}</span>
                {s.destacado && <span class="ml-auto lg:ml-0 inline-flex items-center gap-1.5 rounded-full bg-ink text-white text-[10px] font-bold uppercase tracking-wider px-3 py-1.5">De punta a punta</span>}
              </div>

              <h3 class="display text-3xl sm:text-[2.5rem] font-semibold text-ink leading-[1.03] tracking-[-0.025em]">{s.titulo}</h3>
              <p class="mt-5 text-[17px] text-sand-600 leading-relaxed max-w-md text-pretty">{s.subtitulo}</p>

              {s.bullets && (
                <ul class="mt-7 flex flex-col gap-3">
                  {s.bullets.map((b) => (
                    <li class="flex items-start gap-3 text-[15px] text-sand-700">
                      <span class="sol-check mt-0.5 flex-shrink-0"><svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M20 6L9 17l-5-5"></path></svg></span>
                      {b}
                    </li>
                  ))}
                </ul>
              )}

              {s.cta && s.cta.href === '#' ? (
                <span class="mt-8 self-start inline-flex items-center gap-2 rounded-full bg-sand-100 border border-sand-200 px-4 py-2 text-xs font-semibold text-sand-500">
                  <span class="w-1.5 h-1.5 rounded-full bg-sand-400"></span>Próximamente
                </span>
              ) : s.cta && (
                <a href={s.cta.href} class={`mt-8 arrow-cta inline-flex items-center gap-2 text-sm font-semibold ${accentText[s.accent]} link-underline`}>{s.cta.label}<svg data-arrow class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path></svg></a>
              )}
            </div>

            {/* ---------- Columna de escena (mockup vivo) ---------- */}
            <div class={`reveal reveal-scale reveal-d1 lg:col-span-7 ${i % 2 === 1 ? 'lg:order-1' : 'lg:order-2'}`}>
              <div class="sol-scene relative mx-auto max-w-[560px]">
                <div class="sol-orb" style={`--c:${glow[s.id] ?? 'rgba(37,99,235,0.2)'}`}></div>
                <div class="sol-frame-back" aria-hidden="true"></div>
                <div class="sol-frame" data-tilt="6" aria-hidden="true">

                  {/* ===== Escena: Páginas web — navegador con landing viva ===== */}
                  {s.icon === 'globe' && (
                    <div class="sol-screen">
                      <div class="sol-chrome">
                        <span class="sol-dot"></span><span class="sol-dot"></span><span class="sol-dot"></span>
                        <span class="sol-omni"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 11V7a4 4 0 118 0v4M6 11h12v9H6z"></path></svg>{sceneUrl[s.id]}</span>
                        <span class="sol-chrome-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v6h6M20 20v-6h-6M20 9a8 8 0 00-14-3M4 15a8 8 0 0014 3"></path></svg></span>
                      </div>
                      <div class="p-5 sm:p-6">
                        <div class="flex items-center justify-between mb-6">
                          <span class="flex items-center gap-1.5"><span class="w-4 h-4 rounded-md bg-gradient-to-br from-ember to-jade"></span><span class="text-[10px] font-semibold text-ink display">Estudio</span></span>
                          <span class="hidden sm:flex items-center gap-3.5 text-[9px] font-medium text-sand-500">
                            <span>Trabajo</span><span>Servicios</span><span>Contacto</span>
                            <span class="rounded-full bg-ink text-white px-2.5 py-1 text-[8px] font-semibold">Cotizar</span>
                          </span>
                        </div>
                        <div class="grid grid-cols-5 gap-4 items-center">
                          <div class="col-span-3">
                            <span class="inline-block text-[7px] font-bold uppercase tracking-[0.18em] text-ember mb-2">Estudio digital</span>
                            <p class="display text-[15px] sm:text-[17px] font-semibold text-ink leading-[1.08] tracking-[-0.02em]">Tu marca, clara<br/>y lista para vender.</p>
                            <div class="mt-2.5 space-y-1.5">
                              <span class="block h-1.5 w-full rounded-full bg-sand-200"></span>
                              <span class="block h-1.5 w-3/5 rounded-full bg-sand-200"></span>
                            </div>
                            <span class="mt-3.5 inline-flex items-center gap-1.5 rounded-full bg-gradient-to-r from-ember to-jade px-3 py-1.5 text-[9px] font-semibold text-white shadow-lg shadow-ember/25">Ver proyectos<svg class="w-2.5 h-2.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14m-6-6l6 6-6 6"></path></svg></span>
                          </div>
                          <div class="col-span-2 sol-pop sol-pop-1 aspect-square rounded-xl bg-gradient-to-br from-ember/25 via-jade/18 to-gold/18 border border-white/60 shadow-xl grid place-items-center relative overflow-hidden">
                            <svg viewBox="0 0 40 40" class="w-2/3 h-2/3" fill="none"><path d="M4 30 C12 30 15 12 24 12 C31 12 34 8 36 6" stroke="#2563eb" stroke-width="2.4" stroke-linecap="round" class="sol-draw" pathLength="1"></path></svg>
                            <span class="sol-badge-float"><span class="sol-badge-up">▲</span><span data-count="+38%">+38%</span></span>
                          </div>
                        </div>
                        <div class="grid grid-cols-3 gap-3 mt-6">
                          {['Diseño','Veloz','SEO'].map((f, k) => (
                            <div class="rounded-lg border border-sand-100 bg-sand-50/70 p-2.5 space-y-1.5">
                              <span class={`flex items-center justify-center w-5 h-5 rounded-lg ${k === 0 ? 'bg-ember/12 text-ember' : k === 1 ? 'bg-jade/15 text-ember' : 'bg-gold/12 text-ember'}`}><svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path stroke-linecap="round" stroke-linejoin="round" d={k === 0 ? 'M12 3l7 4v10l-7 4-7-4V7z' : k === 1 ? 'M13 2L4 14h6l-1 8 9-12h-6z' : 'M21 21l-4.3-4.3M11 18a7 7 0 100-14 7 7 0 000 14z'}></path></svg></span>
                              <span class="block text-[8px] font-semibold text-ink">{f}</span>
                              <span class="block h-1 w-2/3 rounded-full bg-sand-200"></span>
                            </div>
                          ))}
                        </div>
                      </div>
                    </div>
                  )}

                  {/* ===== Escena: Sistemas y apps — dashboard operativo ===== */}
                  {s.icon === 'cube' && (
                    <div class="sol-screen flex min-h-[320px]">
                      <div class="w-[28%] bg-ink p-3.5 flex flex-col gap-2.5">
                        <span class="flex items-center gap-1.5 mb-2"><span class="w-5 h-5 rounded-lg bg-gradient-to-br from-ember to-jade"></span><span class="text-[9px] font-semibold text-white display">Operación</span></span>
                        {[['Inicio','M3 11l9-8 9 8M5 10v10h14V10'],['Pedidos','M6 6h15l-1.5 9h-13zM6 6L5 3H3'],['Clientes','M17 20a5 5 0 00-10 0M12 11a3 3 0 100-6 3 3 0 000 6'],['Reportes','M4 20V10M10 20V4M16 20v-8M22 20H2'],['Ajustes','M12 15a3 3 0 100-6 3 3 0 000 6M19 12l1.5 2.5-2 2-2.5-.5-1 2.5h-3l-1-2.5-2.5.5-2-2L4.5 12 3 9.5l2-2 2.5.5 1-2.5h3l1 2.5 2.5-.5 2 2z']].map(([label, d], r) => (
                          <span class={`flex items-center gap-2 rounded-md px-1.5 py-1 ${r === 1 ? 'bg-white/10' : ''}`}>
                            <svg class={`w-3 h-3 ${r === 1 ? 'text-jade' : 'text-white/45'}`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d={d}></path></svg>
                            <span class={`text-[9px] font-medium ${r === 1 ? 'text-white' : 'text-white/45'}`}>{label}</span>
                          </span>
                        ))}
                        <span class="mt-auto flex items-center gap-1.5 rounded-lg bg-white/[0.07] px-2 py-1.5"><span class="w-4 h-4 rounded-full bg-gradient-to-br from-jade to-ember"></span><span class="h-1.5 w-10 rounded-full bg-white/25"></span></span>
                      </div>
                      <div class="flex-1 p-4 sm:p-5 space-y-3.5 bg-sand-50/40">
                        <div class="flex items-center justify-between">
                          <span class="text-[11px] font-semibold text-ink display">Pedidos</span>
                          <span class="flex items-center gap-2"><span class="flex items-center gap-1 h-6 rounded-full bg-white border border-sand-200 px-2 text-[8px] text-sand-400"><svg class="w-2.5 h-2.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.3-4.3M11 18a7 7 0 100-14 7 7 0 000 14z"></path></svg>Buscar</span><span class="w-6 h-6 rounded-full bg-gradient-to-br from-ember to-jade"></span></span>
                        </div>
                        <div class="grid grid-cols-3 gap-2.5">
                          {[['Ingresos','$84.2k','from-ember/12','text-ember','+12%'],['Pedidos','1,240','from-jade/12','text-ember','+8%'],['Clientes','312','from-gold/12','text-ember','+5%']].map(([label, val, g, t, delta]) => (
                            <div class={`rounded-xl bg-gradient-to-br ${g} to-transparent border border-sand-100 p-2.5`}>
                              <span class="block text-[7px] font-medium uppercase tracking-wide text-sand-500 mb-1">{label}</span>
                              <span class="block text-[13px] font-bold text-ink display tabular-nums leading-none" data-count={val}>{val}</span>
                              <span class={`mt-1 inline-flex items-center gap-0.5 text-[7px] font-semibold ${t}`}><svg class="w-2 h-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M6 15l6-6 6 6"></path></svg>{delta}</span>
                            </div>
                          ))}
                        </div>
                        <div class="sol-pop sol-pop-1 rounded-xl border border-sand-100 bg-white p-3">
                          <div class="flex items-center justify-between mb-2"><span class="text-[8px] font-semibold text-ink">Ventas · 30 días</span><span class="text-[7px] font-semibold text-ember">▲ 12.4%</span></div>
                          <svg viewBox="0 0 260 66" class="w-full h-14" fill="none" preserveAspectRatio="none">
                            <path d="M0,56 C50,56 70,20 130,26 C190,32 210,10 260,8 L260,66 L0,66 Z" fill="url(#solf-sys)" class="sol-fill"></path>
                            <path d="M0,56 C50,56 70,20 130,26 C190,32 210,10 260,8" stroke="url(#solg-sys)" stroke-width="2.6" stroke-linecap="round" class="sol-draw" pathLength="1"></path>
                            <defs>
                              <linearGradient id="solg-sys" x1="0" y1="0" x2="1" y2="0"><stop stop-color="#2563eb"></stop><stop offset="1" stop-color="#38bdf8"></stop></linearGradient>
                              <linearGradient id="solf-sys" x1="0" y1="0" x2="0" y2="1"><stop stop-color="#2563eb" stop-opacity="0.2"></stop><stop offset="1" stop-color="#2563eb" stop-opacity="0"></stop></linearGradient>
                            </defs>
                          </svg>
                        </div>
                        <div class="space-y-1.5">
                          {[['#1042','Ana Ruiz','Listo','bg-jade','text-ember','$2,400'],['#1043','Beto M.','En curso','bg-ember','text-ember','$1,150'],['#1044','Caro P.','Nuevo','bg-gold','text-ember','$980']].map(([id, name, st, c, tc, amt]) => (
                            <span class="flex items-center gap-2 rounded-lg bg-white border border-sand-100 px-2 py-1.5">
                              <span class={`w-1.5 h-1.5 rounded-full ${c}`}></span>
                              <span class="text-[8px] font-semibold text-sand-500 tabular-nums">{id}</span>
                              <span class="text-[8px] text-ink">{name}</span>
                              <span class={`ml-auto rounded-full ${c}/15 ${tc} px-1.5 py-0.5 text-[7px] font-semibold`}>{st}</span>
                              <span class="text-[8px] font-semibold text-ink tabular-nums">{amt}</span>
                            </span>
                          ))}
                        </div>
                      </div>
                    </div>
                  )}

                  {/* ===== Escena: Clases de Claude — Claude en acción ===== */}
                  {s.icon === 'claude' && (
                    <div class="sol-screen p-5 sm:p-6 min-h-[320px] flex flex-col bg-gradient-to-b from-white to-sand-50/60">
                      <div class="flex items-center gap-2.5 pb-4 mb-4 border-b border-sand-100">
                        <span class="sol-ai-orb"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v4m0 10v4m9-9h-4M7 12H3m13.5-6.5L14 8m-6 6l-2.5 2.5m0-11L8 8m6 6l2.5 2.5"></path></svg></span>
                        <span class="text-[11px] font-semibold text-ink display">Claude</span>
                        <span class="rounded-full bg-ai/10 text-ai px-1.5 py-0.5 text-[7px] font-bold uppercase tracking-wide">Opus</span>
                        <span class="ml-auto flex items-center gap-1.5 text-[9px] font-semibold uppercase tracking-wider text-ai"><span class="w-1.5 h-1.5 rounded-full bg-ai animate-pulse"></span>En vivo</span>
                      </div>
                      <div class="flex-1 flex flex-col gap-3">
                        <div class="self-end max-w-[76%] rounded-2xl rounded-br-md accent-ai px-3.5 py-2.5 shadow-lg shadow-ai/20">
                          <p class="text-[10px] leading-snug text-white">Resume mis ventas de la semana</p>
                        </div>
                        <div class="sol-pop sol-pop-1 self-start max-w-[82%] rounded-2xl rounded-bl-md bg-white border border-sand-200 px-3.5 py-3 shadow-sm space-y-2">
                          <p class="text-[10px] leading-snug text-ink">Claro. Esta semana cerraste:</p>
