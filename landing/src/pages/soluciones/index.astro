                        <span class="flex-1 rounded-lg bg-gradient-to-br from-ember/12 to-transparent border border-sand-100 p-1.5"><span class="block text-[9px] font-bold text-ink display leading-none">$84k</span><span class="block text-[6px] text-sand-400 mt-0.5">Ingresos</span></span>
                        <span class="flex-1 rounded-lg bg-gradient-to-br from-jade/12 to-transparent border border-sand-100 p-1.5"><span class="block text-[9px] font-bold text-ember display leading-none">+12%</span><span class="block text-[6px] text-sand-400 mt-0.5">vs. mes</span></span>
                      </div>
                      <svg viewBox="0 0 200 42" class="w-full h-10" fill="none" preserveAspectRatio="none"><path d="M0,36 C40,36 55,12 100,16 C145,20 160,4 200,3" stroke="url(#solg-fin)" stroke-width="2.2" stroke-linecap="round"></path><defs><linearGradient id="solg-fin" x1="0" y1="0" x2="1" y2="0"><stop stop-color="#2563eb"></stop><stop offset="1" stop-color="#38bdf8"></stop></linearGradient></defs></svg>
                    </div>
                  )}
                  {!['crm-simple','operacion-pyme','finanzas-negocio'].includes(p.id) && (
                    <div class="space-y-2">{[0,1,2].map((r) => <span class={`block h-2 rounded-full bg-sand-200 ${r === 0 ? 'w-1/2' : r === 1 ? 'w-full' : 'w-2/3'}`}></span>)}</div>
                  )}
                </div>
              </div>

              {/* Cuerpo */}
              <div class="p-6 flex flex-col flex-1">
                <p class="display font-semibold text-lg text-sand-50">{p.nombre}</p>
                <p class="text-[14px] text-sand-300 leading-relaxed mt-2 flex-1">{p.desc}</p>
                <div class="mt-6 flex items-end justify-between gap-3">
                  <span>
                    <span class="block text-[11px] uppercase tracking-wider text-sand-500 mb-0.5">Pago único</span>
                    <span data-count={p.precio} class="sol-price display font-semibold text-sand-50 tabular-nums">{p.precio}</span>
                  </span>
                  <button
                    type="button"
                    data-comprar={p.id}
                    data-nombre={p.nombre}
                    data-monto={p.precioMXN}
                    class="btn-pop group/btn inline-flex items-center gap-2.5 text-sm font-semibold bg-ember text-white pl-5 pr-2 py-2 rounded-full hover:bg-ember-600 whitespace-nowrap transition-colors"
                  >
                    Comprar
                    <span class="w-8 h-8 rounded-full bg-white/20 grid place-items-center transition-transform duration-300 group-hover/btn:translate-x-0.5 group-hover/btn:-translate-y-px">
                      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.836L5.383 6m0 0l1.44 6.44a1.5 1.5 0 001.464 1.16h7.09a1.5 1.5 0 001.464-1.16L19.5 6H5.383zM9 20.25a.75.75 0 11-1.5 0 .75.75 0 011.5 0zm8 0a.75.75 0 11-1.5 0 .75.75 0 011.5 0z"></path></svg>
                    </span>
                  </button>
                </div>
              </div>
            </article>
          ))}
        </div>
        <p class="mt-8 text-sm text-sand-400">Pagas aquí mismo, la plantilla te llega a tu correo y lista para usar.</p>
      </div>
    </section>
  ))}

  <!-- ============== CTA FINAL ============== -->
  <section class="py-24 sm:py-32 px-6 sm:px-10 bg-sand-50 border-t border-sand-200">
    <div class="reveal mx-auto max-w-3xl text-center">
      <h2 class="display text-3xl sm:text-4xl lg:text-5xl font-semibold tracking-[-0.025em] leading-[1.06] text-ink text-balance">¿Tienes algo más grande en mente?</h2>
      <p class="mt-5 text-lg text-sand-600 max-w-md mx-auto text-pretty">Cuéntanos qué necesitas construir y te decimos cómo lo hacemos.</p>
      <a href={calLink} target="_blank" rel="noopener" data-magnetic="0.35" class="btn-shine btn-pop group mt-9 inline-flex items-center gap-2 text-base font-semibold bg-ember text-white px-8 py-4 rounded-full hover:bg-ember-600 hover:gap-3">
        Agendar llamada
        <svg data-arrow class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path></svg>
      </a>
    </div>
  </section>

  <a href={waLink} target="_blank" rel="noopener" class="fixed bottom-6 right-6 z-50 w-14 h-14 bg-[#25D366] rounded-full flex items-center justify-center shadow-lg hover:scale-105 transition-all" aria-label="Contactar por WhatsApp">
    <svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"></path></svg>
  </a>

  </main>

  <Footer calLink={calLink} waLink={waLink} />
</BaseLayout>

<style>
  /* ============ Palabra fantasma del hero ============ */
  .sol-ghost {
    position: absolute;
    top: 4rem; right: -1rem;
    font-size: clamp(6rem, 22vw, 19rem);
    font-weight: 800;
    line-height: 0.8;
    letter-spacing: -0.045em;
    color: #fff;
    opacity: 0.04;
    pointer-events: none;
    z-index: 0;
    user-select: none;
  }

  /* ============ Índice del hero ============ */
  .sol-index-label {
    align-items: center;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-sand-500);
  }
  .sol-index {
    transition: color 0.3s var(--ease-pitch), background-color 0.3s var(--ease-pitch),
      border-color 0.3s var(--ease-pitch), transform 0.3s var(--ease-pitch);
  }
  .sol-index-dot {
    width: 0.5rem; height: 0.5rem; border-radius: 9999px;
    background: var(--d);
    box-shadow: 0 0 0 0 color-mix(in srgb, var(--d) 60%, transparent);
    transition: transform 0.3s var(--ease-pitch), box-shadow 0.4s var(--ease-pitch);
  }
  .sol-index-arrow {
    width: 0; height: 0.85rem; opacity: 0;
    margin-left: -0.35rem;
    transition: width 0.3s var(--ease-pitch), opacity 0.3s var(--ease-pitch), margin 0.3s var(--ease-pitch);
  }
  @media (hover: hover) and (pointer: fine) {
    .sol-index:hover {
      background: rgba(255, 255, 255, 0.09);
      border-color: color-mix(in srgb, var(--d, #2563eb) 45%, transparent);
      transform: translateY(-2px);
    }
    .sol-index:hover .sol-index-dot { transform: scale(1.35); box-shadow: 0 0 12px 0 var(--d); }
    .sol-index:hover .sol-index-arrow { width: 0.85rem; opacity: 1; margin-left: 0; }
  }

  /* ============ Atmósfera del showroom ============ */
  .sol-amb { position: absolute; border-radius: 9999px; filter: blur(10px); pointer-events: none; z-index: 0; }

  /* ============ Escena / mockup vivo ============ */
  .sol-scene { perspective: 1600px; }
  .sol-orb {
    position: absolute; inset: 4% 2%;
    border-radius: 9999px;
    background: radial-gradient(circle, var(--c), transparent 70%);
    filter: blur(48px);
    z-index: -2;
    opacity: 0.9;
    transition: opacity 0.6s var(--ease-pitch), transform 0.6s var(--ease-pitch);
  }
  .sol-scene:hover .sol-orb { opacity: 1; transform: scale(1.08); }

  /* Capa trasera: profundidad tipo cascada Z */
  .sol-frame-back {
    position: absolute; inset: 0;
    border-radius: 1.35rem;
    background: linear-gradient(180deg, #ffffff, #e9f0fb);
    border: 1px solid var(--color-sand-200);
    box-shadow: 0 30px 60px -42px rgba(15, 30, 61, 0.32);
    transform: translate(20px, 24px) rotate(1.6deg) scale(0.965);
    opacity: 0.5;
    z-index: -1;
    transition: transform 0.7s var(--ease-pitch), opacity 0.7s var(--ease-pitch);
  }
  .sol-scene:hover .sol-frame-back { transform: translate(30px, 34px) rotate(2.4deg) scale(0.955); opacity: 0.7; }

  /* El marco (bandeja de aluminio con la pantalla dentro) */
  .sol-frame {
    position: relative;
    border-radius: 1.35rem;
    background: linear-gradient(155deg, #ffffff 0%, #eaf1fb 100%);
    border: 1px solid rgba(255, 255, 255, 0.9);
    box-shadow:
      0 1px 0 0 rgba(255, 255, 255, 0.9) inset,
      0 0 0 1px rgba(15, 30, 61, 0.06),
      0 2px 6px -2px rgba(15, 30, 61, 0.12),
      0 48px 96px -46px rgba(15, 30, 61, 0.5);
    padding: 0.55rem;
    transform-style: preserve-3d;
    will-change: transform;
  }
  .sol-screen {
    position: relative;
    border-radius: 1rem;
    background: #fff;
    border: 1px solid var(--color-sand-100);
    overflow: hidden;
  }
  /* Barra superior del navegador (chrome) */
  .sol-chrome {
    display: flex; align-items: center; gap: 0.4rem;
    padding: 0.55rem 0.85rem;
    border-bottom: 1px solid var(--color-sand-100);
    background: linear-gradient(180deg, #fbfcfe, #f4f7fc);
  }
  .sol-dot { width: 0.5rem; height: 0.5rem; border-radius: 9999px; background: var(--color-sand-300); }
  .sol-dot:nth-child(1) { background: #f0b6b0; }
  .sol-dot:nth-child(2) { background: #f3d59a; }
  .sol-dot:nth-child(3) { background: #b3ddb0; }
  .sol-omni {
    margin-left: 0.6rem; flex: 1;
    display: inline-flex; align-items: center; gap: 0.3rem;
    height: 1.15rem; padding: 0 0.6rem;
    border-radius: 9999px;
    background: #fff; border: 1px solid var(--color-sand-200);
    font-size: 0.55rem; font-weight: 500; color: var(--color-sand-500);
  }
  .sol-omni svg { width: 0.55rem; height: 0.55rem; color: var(--color-sand-400); }
  .sol-chrome-ico { display: grid; place-items: center; width: 0.9rem; height: 0.9rem; color: var(--color-sand-400); }
  .sol-chrome-ico svg { width: 0.75rem; height: 0.75rem; }

  /* Palomita de bullets (columna de texto) */
  .sol-check {
    display: inline-grid; place-items: center;
    width: 1.15rem; height: 1.15rem; border-radius: 9999px;
    color: var(--color-ember);
    background: color-mix(in srgb, var(--color-ember) 12%, transparent);
  }

  /* Barra de estadística flotante en la escena web */
  .sol-badge-float {
    position: absolute; right: -0.35rem; bottom: -0.35rem;
    display: inline-flex; align-items: center; gap: 0.2rem;
    padding: 0.25rem 0.4rem; border-radius: 0.5rem;
    background: #fff; border: 1px solid var(--color-sand-200);
    box-shadow: 0 8px 18px -10px rgba(15, 30, 61, 0.4);
    font-size: 0.55rem; font-weight: 700; color: var(--color-ink);
    font-variant-numeric: tabular-nums;
  }
  .sol-badge-up { color: #16a34a; font-size: 0.45rem; }

  /* Trazo que se dibuja al revelar la escena */
  .sol-draw { stroke-dasharray: 1; stroke-dashoffset: 1; }
  .sol-fill { opacity: 0; transition: opacity 0.9s var(--ease-pitch) 0.5s; }
  .reveal.is-visible .sol-draw { animation: sol-draw 1.5s var(--ease-pitch) 0.3s forwards; }
  .reveal.is-visible .sol-fill { opacity: 1; }
  @keyframes sol-draw { to { stroke-dashoffset: 0; } }
  :global(html:not(.js)) .sol-draw { stroke-dashoffset: 0; }
  :global(html:not(.js)) .sol-fill { opacity: 1; }

  /* Barrido de luz (sheen) al hover de la escena */
  .sol-screen::after {
    content: ""; position: absolute; inset: 0; z-index: 6; pointer-events: none;
    background: linear-gradient(115deg, transparent 34%, rgba(255, 255, 255, 0.5) 48%, transparent 60%);
    transform: translateX(-140%);
    opacity: 0;
  }
  @media (hover: hover) and (pointer: fine) {
    .sol-scene:hover .sol-screen::after { animation: sol-sheen 0.95s var(--ease-pitch); }
  }
  @keyframes sol-sheen {
    0% { transform: translateX(-140%); opacity: 0; }
    24% { opacity: 0.6; }
    100% { transform: translateX(140%); opacity: 0; }
