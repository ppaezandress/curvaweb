# CURVA Socios — variables de entorno
# Copia a .env.local y llena. Reusa los mismos valores de Curva Tiempos donde aplique.

# --- Notion (REUSAR de Curva Tiempos) ---
CURVA_NOTION_TOKEN=ntn_...          # mismo token de integración de Notion
NOTION_DB_CRM=...                   # DB de clientes/leads (misma que Tiempos)

# --- Supabase (REUSAR de Curva Tiempos) ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=...
SUPABASE_SERVICE_ROLE_KEY=...       # solo servidor (Storage de facturas)

# --- Facturas ---
# Por defecto las facturas se leen del XML (CFDI) GRATIS, sin IA. No necesitas nada aquí.
# Lo de abajo es OPCIONAL: solo si quieres leer FOTOS de tickets sin XML con Claude visión (cuesta tokens).
# FACTURAS_VISION=on                 # actívalo para habilitar la lectura por foto
# ANTHROPIC_API_KEY=sk-ant-...       # solo si FACTURAS_VISION=on · https://console.anthropic.com/settings/keys

# --- Acceso (solo socios) ---
ADMIN_EMAILS=andres@...,balmo@...
